@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Station Details";
    var fillRateValue = (Model.TotalCapacity > 0) ? (Model.CurrentCount * 100.0 / Model.TotalCapacity) : 0;
    var pbColor = fillRateValue > 90 ? "bg-danger" : (fillRateValue < 20 ? "bg-warning" : "bg-success");
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold"><i class="bi bi-info-circle-fill text-info me-2"></i>Station Details</h1>
            <p class="text-muted mb-0">Detailed view of station information and capacity metrics.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.StationId" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-pencil-square me-2"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-arrow-left me-2"></i>Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Overview Card -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-2">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <span class="badge @(Model!.IsActive ? "bg-success bg-opacity-10 text-success border border-success border-opacity-25" : "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25") px-3 py-2 rounded-pill fw-medium mb-3 d-inline-block">
                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> @(Model!.IsActive ? "Active & Operational" : "Currently Inactive")
                            </span>
                            <h2 class="fw-bold text-dark mb-1">@Model.Name</h2>
                            <p class="text-muted"><i class="bi bi-geo-alt text-primary me-2"></i>@Model.Address</p>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px; flex-shrink: 0;">
                            <i class="bi bi-shop text-primary fs-3"></i>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 my-4">

                    <h6 class="fw-bold text-secondary mb-4 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Operating Dimensions</h6>
                    
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <div class="p-4 bg-light rounded-4 border border-light-subtle h-100">
                                <div class="text-muted small mb-2 fw-medium">Total Capacity</div>
                                <div class="fs-3 fw-bold text-dark"><i class="bi bi-grid-3x3-gap me-2 text-secondary opacity-50"></i>@Model.TotalCapacity <span class="fs-6 fw-normal text-muted">slots</span></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-4 bg-light rounded-4 border border-light-subtle h-100">
                                <div class="text-muted small mb-2 fw-medium">Current Inventory</div>
                                <div class="fs-3 fw-bold text-dark text-primary"><i class="bi bi-bicycle me-2 text-secondary opacity-50"></i>@Model.CurrentCount <span class="fs-6 fw-normal text-muted">vehicles</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side Panel -->
        <div class="col-lg-4">
            <!-- Map Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-0">
                    <div id="map" style="height: 250px; z-index: 1;"></div>
                    <div class="p-3 bg-light text-center small text-muted font-monospace">
                        @Model.Latitude.ToString("0.00000"), @Model.Longitude.ToString("0.00000")
                    </div>
                </div>
            </div>
            <!-- Capacity Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-secondary mb-4 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Capacity Status</h6>
                    
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <span class="fs-1 fw-bold text-dark lh-1">@fillRateValue.ToString("0")%</span>
                        <span class="text-muted pb-1 fw-medium">Filled</span>
                    </div>
                    
                    <div class="progress mb-3 shadow-sm bg-light" style="height: 12px; border-radius: 10px;">
                        <div class="progress-bar @pbColor progress-bar-striped progress-bar-animated opacity-75" role="progressbar" style="width: @fillRateValue%" aria-valuenow="@fillRateValue" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    
                    <p class="small text-muted fw-medium mb-0 mt-3 p-3 bg-light rounded-3">
                        @if (fillRateValue >= 90) { <span><i class="bi bi-exclamation-triangle text-danger me-1"></i> Highly congested. Moving vehicles recommended.</span> }
                        else if (fillRateValue <= 20) { <span><i class="bi bi-info-circle text-warning me-1"></i> Low inventory. Consider restocking vehicles.</span> }
                        else { <span><i class="bi bi-check-circle text-success me-1"></i> Capacity levels are optimal and stable.</span> }
                    </p>
                </div>
            </div>
            
            <!-- Danger Zone Card -->
            <div class="card border-0 shadow-sm rounded-4 bg-danger bg-opacity-10 border border-danger border-opacity-10">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-danger mb-3"><i class="bi bi-shield-x me-2"></i>Danger Zone</h6>
                    <p class="small text-danger opacity-75 mb-4 fw-medium">Deleting this station will permanently remove it from the system. Ensure all vehicles are relocated first.</p>
                    <a asp-action="Delete" asp-route-id="@Model.StationId" class="btn btn-outline-danger w-100 rounded-pill fw-bold border-2 hover-lift shadow-sm">
                        Proceed to Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift { transition: transform 0.15s ease-in-out, box-shadow 0.15s ease-in-out; }
    .hover-lift:hover { transform: translateY(-2px); box-shadow: 0 0.25rem 0.5rem rgba(0,0,0,0.1) !important;}
</style>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var lat = @Model.Latitude;
            var lng = @Model.Longitude;
            
            // If completely 0,0, map won't look great, but it's read-only anyway.
            var map = L.map('map').setView([lat, lng], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map)
                .bindPopup('<b>@Model.Name</b><br>@Model.Address').openPopup();
        });
    </script>
}
