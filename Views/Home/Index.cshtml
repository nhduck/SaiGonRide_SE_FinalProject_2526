@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // ── Station data from server ──
    const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
    const stationData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(s => new {
        id = s.StationId,
        name = s.Name,
        address = s.Address,
        lat = s.Latitude,
        lng = s.Longitude,
        current = s.CurrentCount,
        capacity = s.TotalCapacity,
        fillRate = Math.Round(s.FillRate * 100),
        isActive = s.IsActive,
        isEmpty = s.IsEmpty,
        hasElectric = s.Vehicles.Any(v => v.Type == RentalVehicleService.Models.VehicleType.Electric && v.State == RentalVehicleService.Models.VehicleState.Available),
        stdCount = s.Vehicles.Count(v => v.Type == RentalVehicleService.Models.VehicleType.Standard && v.State == RentalVehicleService.Models.VehicleState.Available),
        elecCount = s.Vehicles.Count(v => v.Type == RentalVehicleService.Models.VehicleType.Electric && v.State == RentalVehicleService.Models.VehicleState.Available)
    })));

    // ── Leaflet Map ──
    let stationMap = null;
    let mapMarkers = [];

    function createMarkerIcon(hasElectric, isActive, isEmpty) {
        const bikeSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#fff" viewBox="0 0 16 16"><path d="M4 4.5a.5.5 0 0 1 .5-.5H6a.5.5 0 0 1 0 1v.5h4.14l.386-1.158A.5.5 0 0 1 11 4h1a.5.5 0 0 1 0 1h-.64l-.311.935.807 1.29a3 3 0 1 1-.848.53l-.508-.812-2.076 3.322A.5.5 0 0 1 8 10.5H5.959a3 3 0 1 1-1.815-3.274L5 5.856V5h-.5a.5.5 0 0 1-.5-.5m1.5 2.443-.508.814c.5.444.85 1.054.967 1.743h1.139zM8 9.057 9.598 6.5H6.402zM4.937 9.5a2 2 0 0 0-.652-1.157L3.167 10.5H4.937zM3 12a2 2 0 1 0-1-3.732L.868 10.5A2 2 0 0 0 3 12m10-4a2 2 0 1 0-.001 4.001A2 2 0 0 0 13 8"/></svg>`;

        let className = 'sr-marker-container';
        if (isActive) className += ' sr-marker-active';
        
        let colorClass = 'sr-marker-green';
        if (!isActive) colorClass = 'sr-marker-red';
        else if (isEmpty) colorClass = 'sr-marker-gray';
        else if (hasElectric) colorClass = 'sr-marker-blue';

        let badgeHtml = '';
        if (hasElectric && isActive) {
            badgeHtml = `
                <div class="sr-marker-badge">
                    <svg width="11" height="14" viewBox="0 0 28 38" fill="none"><polygon points="17,0 9,18 15,18 8,38 24,13 17,13 25,0" fill="#fff"/></svg>
                </div>`;
        }

        return L.divIcon({
            className: 'sr-custom-marker-wrapper',
            html: `
                <div class="${className} ${colorClass}">
                    <div class="sr-marker-body">
                        ${bikeSvg}
                    </div>
                    ${badgeHtml}
                </div>`,
            iconSize: [42, 52],
            iconAnchor: [21, 48],
            popupAnchor: [0, -44]
        });
    }

    function getPopupContent(s) {
        const dict = window.getDict ? window.getDict() : {};
        const name = dict[s.name] || s.name;
        const addr = dict[s.address] || s.address;
        const fillClass = s.fillRate < 60 ? 'bg-success' : (s.fillRate < 85 ? 'bg-warning text-dark' : 'bg-danger');
        
        const stdLabel = dict['map_legend_standard'] || 'Standard';
        const elecLabel = dict['map_legend_electric'] || 'Electric';
        const rentNowLabel = dict['stat_btn_rent_now'] || 'Rent Now';
        const loginLabel = dict['stat_btn_login'] || 'Log in to rent';

        let actionBtns = '';
        if (s.isActive) {
            if (isAuthenticated) {
                actionBtns = `
                    <div class="sr-popup-actions w-100 mt-2">
                        <button class="btn btn-success btn-sm btn-open-modal w-100 py-2 rounded-pill shadow-sm" data-station-id="${s.id}" data-type="All">
                            <i class="bi bi-qr-code-scan me-1"></i> <span data-i18n="stat_btn_rent_now">${rentNowLabel}</span>
                        </button>
                    </div>`;
            } else {
                actionBtns = `
                    <div class="sr-popup-actions w-100 mt-2">
                        <a href="/Account/Login" class="btn btn-outline-success btn-sm w-100 py-2 rounded-pill">
                            <i class="bi bi-box-arrow-in-right me-1"></i> <span data-i18n="stat_btn_login">${loginLabel}</span>
                        </a>
                    </div>`;
            }
        }

        return `<div class="sr-popup-inner">
            <h6 data-i18n="${s.name}">${name}</h6>
            <div class="sr-popup-addr"><i class="bi bi-geo-alt-fill text-danger me-1"></i><span data-i18n="${s.address}">${addr}</span></div>
            <div class="sr-popup-stats mb-2 border-top pt-2">
                <div class="d-flex justify-content-between w-100 mb-1">
                    <span class="text-muted small"><i class="bi bi-bicycle me-1"></i><span data-i18n="map_legend_standard">${stdLabel}</span>:</span>
                    <span class="fw-bold">${s.stdCount}</span>
                </div>
                <div class="d-flex justify-content-between w-100 mb-2">
                    <span class="text-muted small"><i class="bi bi-lightning-charge-fill me-1 text-warning"></i><span data-i18n="map_legend_electric">${elecLabel}</span>:</span>
                    <span class="fw-bold">${s.elecCount}</span>
                </div>
                <div class="d-flex justify-content-between align-items-center w-100">
                    <span class="badge ${fillClass} rounded-pill">${s.fillRate}% <span data-i18n="stat_pct_full">full</span></span>
                    <small class="text-muted"><strong>${s.current}</strong>/${s.capacity} <span data-i18n="stat_veh">vehicles</span></small>
                </div>
            </div>
            ${actionBtns}
        </div>`;
    }

    function initStationMap() {
        if (stationMap) return;
        const mapEl = document.getElementById('stationMap');
        if (!mapEl) return;

        stationMap = L.map('stationMap', {
            scrollWheelZoom: true,
            zoomControl: true
        }).setView([10.7900, 106.7000], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19
        }).addTo(stationMap);

        stationData.forEach(s => {
            if (!s.lat || !s.lng) return;
            const icon = createMarkerIcon(s.hasElectric, s.isActive, s.isEmpty);
            const marker = L.marker([s.lat, s.lng], { icon })
                .addTo(stationMap)
                .bindPopup(getPopupContent(s), { className: 'sr-leaflet-popup', maxWidth: 320 });
            marker._srStation = s;
            mapMarkers.push(marker);
        });

        // Fit bounds to all markers
        if (mapMarkers.length > 0) {
            const group = L.featureGroup(mapMarkers);
            stationMap.fitBounds(group.getBounds().pad(0.08));
        }

        // Force resize after a short delay (for hidden containers)
        setTimeout(() => stationMap.invalidateSize(), 200);
    }

    // ── View Toggle Logic ──
    function toggleStationView(view) {
        const mapPanel = document.getElementById('mapViewPanel');
        const listPanel = document.getElementById('stationListPanel');
        const btnMap = document.getElementById('btnViewMap');
        const btnList = document.getElementById('btnViewList');

        if (view === 'map') {
            if (mapPanel) {
                mapPanel.classList.remove('d-none');
                mapPanel.style.setProperty('display', 'block', 'important');
            }
            if (listPanel) {
                listPanel.classList.add('d-none');
                listPanel.style.setProperty('display', 'none', 'important');
            }
            btnMap?.classList.add('active');
            btnList?.classList.remove('active');
            if (stationMap) {
                setTimeout(() => {
                    stationMap.invalidateSize();
                }, 100);
            }
        } else {
            if (mapPanel) {
                mapPanel.classList.add('d-none');
                mapPanel.style.setProperty('display', 'none', 'important');
            }
            if (listPanel) {
                listPanel.classList.remove('d-none');
                listPanel.style.setProperty('display', 'block', 'important');
                
                // Force cards to be visible and have height
                document.querySelectorAll('.station-item').forEach(el => {
                    if (!el.classList.contains('filtered-out')) {
                        el.style.setProperty('display', 'block', 'important');
                    }
                });
            }
            btnMap?.classList.remove('active');
            btnList?.classList.add('active');
        }
    }

    // ── Scroll fade ──
    const scrollContainer = document.getElementById('stationListScroll');
    if (scrollContainer) {
        scrollContainer.addEventListener('scroll', function() {
            const parent = this.closest('.sr-scroll-fade');
            if (!parent) return;
            const atBottom = this.scrollHeight - this.scrollTop - this.clientHeight < 10;
            parent.classList.toggle('scrolled-bottom', atBottom);
        });
    }

    // ── Init map on load & Attach events ──
    document.addEventListener('DOMContentLoaded', () => {
        initStationMap();
        
        // Attach View Toggle events
        document.getElementById('btnViewMap')?.addEventListener('click', () => toggleStationView('map'));
        document.getElementById('btnViewList')?.addEventListener('click', () => toggleStationView('list'));
    });

    // ── QR Scanner ──
    let html5QrCode;
    $(document).ready(function () {
        let html5QrCode = null;

        function stopCamera() {
            if (html5QrCode) {
                html5QrCode.stop().then(() => {
                    html5QrCode.clear();
                    html5QrCode = null;
                }).catch(err => {
                    html5QrCode = null;
                });
            }
        }

        $(document).on('click', '.btn-open-scanner', function () {
            var stationId = $(this).data('station-id');
            $('#dynamicVehicleModal').modal('hide');

            setTimeout(function () {
                $('#qrScannerModal').modal('show');
                stopCamera();
                html5QrCode = new Html5Qrcode("reader");
                const config = { fps: 10, qrbox: { width: 250, height: 250 } };
                html5QrCode.start({ facingMode: "user" }, config,
                    (decodedText) => {
                        stopCamera();
                        window.location.href = decodedText + "&startStationId=" + stationId;
                    },
                    () => {}
                ).catch(err => {
                    console.error("Camera error: ", err);
                    alert(getI18nText("modal_camera_error"));
                });
            }, 400);
        });

        // ── Live Search (filters both list AND map) ──
        const searchFilter = function (query) {
            const q = (query || "").toLowerCase().trim();

            // Filter list items
            document.querySelectorAll('.station-item').forEach(el => {
                const name = el.dataset.name || "";
                const addr = el.dataset.address || "";
                const match = !q || name.includes(q) || addr.includes(q);
                
                if (match) {
                    el.classList.remove('filtered-out');
                    el.style.setProperty('display', 'block', 'important');
                } else {
                    el.classList.add('filtered-out');
                    el.style.setProperty('display', 'none', 'important');
                }
            });

            // Filter map markers
            const dict = window.getDict ? window.getDict() : {};
            mapMarkers.forEach(marker => {
                const s = marker._srStation;
                const name = (dict[s.name] || s.name).toLowerCase();
                const addr = (dict[s.address] || s.address).toLowerCase();
                const match = !q || name.includes(q) || addr.includes(q) || s.name.toLowerCase().includes(q) || s.address.toLowerCase().includes(q);
                if (match) {
                    if (!stationMap.hasLayer(marker)) marker.addTo(stationMap);
                } else {
                    stationMap.removeLayer(marker);
                }
            });
        };

        document.getElementById('liveSearchBox')?.addEventListener('input', function () {
            searchFilter(this.value);
            // Sync with navbar search if it exists
            const navSearch = document.querySelector('input[name="query"]');
            if (navSearch) navSearch.value = this.value;
        });

    const navSearchInput = document.querySelector('input[name="query"]');
    navSearchInput?.addEventListener('input', function () {
        searchFilter(this.value);
        // Sync with live search box
        const mainSearch = document.getElementById('liveSearchBox');
        if (mainSearch) mainSearch.value = this.value;
    });

    // Prevent navbar search form from reloading on Home page
    const navSearchForm = document.querySelector('.sr-search-form');
    navSearchForm?.addEventListener('submit', function (e) {
        if (window.location.pathname === '/' || window.location.pathname === '/Home/Index' || window.location.pathname === '') {
            e.preventDefault();
            searchFilter(navSearchInput.value);
        }
    });

        // Translate open popup when language changes
        document.addEventListener('languageChanged', function() {
            if (stationMap) {
                stationMap.eachLayer(function(layer) {
                    if (layer instanceof L.Marker && layer.getPopup() && layer.getPopup().isOpen()) {
                        layer.setPopupContent(getPopupContent(layer._srStation));
                    }
                });
            }
        });

        $('#qrScannerModal').on('hidden.bs.modal', function () {
            stopCamera();
        });
    });

    // ── Counter Animation ──
    function animateCount(el) {
        const target = parseInt(el.dataset.target, 10);
        const duration = 1600;
        const step = target / (duration / 16);
        let current = 0;
        const timer = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = Math.floor(current).toLocaleString('en-US') + '+';
            if (current >= target) clearInterval(timer);
        }, 16);
    }

    const counters = document.querySelectorAll('.sr-stat-number[data-target]');
    const countObs = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) { animateCount(e.target); countObs.unobserve(e.target); }
        });
    }, { threshold: .5 });
    counters.forEach(c => countObs.observe(c));

    // ── Rental Modal ──
    $(document).ready(function () {
        $(document).on('click', '.btn-open-modal', function () {
            var stationId = $(this).data('station-id');
            var type = $(this).data('type');

            $('#modal-content-container').html(`
                <div class="text-center p-5">
                    <div class="spinner-border text-success" role="status"></div>
                    <p class="mt-3 text-muted fw-semibold" data-i18n="modal_finding_vehicle">${getI18nText("modal_finding_vehicle")}</p>
                </div>
            `);
            $('#dynamicVehicleModal').modal('show');

            $.ajax({
                url: '/Rental/GetAvailableVehicles',
                type: 'GET',
                data: { stationId: stationId, type: type },
                success: function (result) {
                    $('#modal-content-container').html(result);
                    if (window.applyTranslations && window.getDict) {
                        window.applyTranslations(window.getDict());
                    }
                },
                error: function () {
                    $('#modal-content-container').html(`
                        <div class="p-5 text-center">
                            <i class="bi bi-x-circle text-danger fs-1 mb-2"></i>
                            <h5 class="text-dark fw-bold" data-i18n="modal_conn_error">${getI18nText("modal_conn_error")}</h5>
                            <p class="text-muted" data-i18n="modal_conn_error_desc">${getI18nText("modal_conn_error_desc")}</p>
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4 mt-2" data-bs-dismiss="modal" data-i18n="modal_close">${getI18nText("modal_close")}</button>
                        </div>
                    `);
                }
            });
        });
    });
</script>
}