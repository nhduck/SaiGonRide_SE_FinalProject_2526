@model IEnumerable<RentalVehicleService.Models.Station> 
<RentalVehicleService.Models.Vehicle>

@{
    ViewData["Title"] = "Station Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">🚉 Station Management</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold">+ Add New Station</a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            // Tính phần trăm lấp đầy bãi xe
            var fillPct = (int)(item.FillRate * 100);
            var barColor = item.IsLowInventory ? "bg-danger" : (fillPct >= 80 ? "bg-warning" : "bg-success");

            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@item.Name</h5>
                            @if (item.IsLowInventory)
                            {
                                <span class="badge bg-danger rounded-pill">⚠ Low Inventory</span>
                            }
                            else if (!item.IsActive)
                            {
                                <span class="badge bg-secondary rounded-pill">Đã đóng cửa</span>
                            }
                        </div>

                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill"></i> @item.Address
                        </p>

                        <div class="d-flex justify-content-between mb-1">
                            <small class="fw-semibold">Sức chứa: @item.CurrentCount / @item.TotalCapacity xe</small>
                            <small class="fw-bold text-muted">@fillPct%</small>
                        </div>

                        <div class="progress mb-4" style="height: 8px;">
                            <div class="progress-bar @barColor" role="progressbar" style="width: @fillPct%" aria-valuenow="@fillPct" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <div class="btn-group w-100" role="group">
                            <a asp-action="Edit" asp-route-id="@item.StationId" class="btn btn-outline-warning btn-sm">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.StationId" class="btn btn-outline-info btn-sm">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.StationId" class="btn btn-outline-danger btn-sm">Xóa</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>