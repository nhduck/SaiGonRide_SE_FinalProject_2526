@model RentalVehicleService.Models.BugReport
@{
    ViewData["Title"] = "Report an Issue";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool success = TempData["ReportSuccess"] != null && (bool)TempData["ReportSuccess"];
}

<div class="report-issue-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">

                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Report an Issue</li>
                    </ol>
                </nav>

                <!-- Header -->
                <div class="text-center mb-5">
                    <div class="report-icon-wrap mx-auto mb-3">
                        <i class="bi bi-flag-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-2" data-i18n="report_title">Report an Issue</h2>
                    <p class="text-muted" data-i18n="report_subtitle">
                        Found a bug or problem? Let us know and we'll fix it as soon as possible.
                    </p>
                </div>

                <!-- Success Message -->
                @if (success)
                {
                    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-3 mb-4" role="alert">
                        <div class="success-check-wrap flex-shrink-0">
                            <i class="bi bi-check-circle-fill fs-4 text-success"></i>
                        </div>
                        <div>
                            <strong data-i18n="report_success_title">Report submitted!</strong>
                            <p class="mb-0 small text-muted" data-i18n="report_success_desc">
                                Thank you for helping us improve SaigonRide. Our team will review your report shortly.
                            </p>
                        </div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Form Card -->
                <div class="card border-0 shadow-sm report-card">
                    <div class="card-body p-4 p-md-5">
                        <form asp-action="ReportIssue" asp-controller="Home" method="post" id="reportForm" novalidate>
                            @Html.AntiForgeryToken()

                            <!-- Title -->
                            <div class="mb-4">
                                <label asp-for="Title" class="form-label fw-semibold">
                                    <i class="bi bi-type me-1 text-success"></i>
                                    <span data-i18n="report_field_title">Issue Title</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Title"
                                       class="form-control form-control-lg"
                                       placeholder="Brief description of the issue..."
                                       data-i18n="[placeholder]report_placeholder_title"
                                       maxlength="100" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                                <div class="form-text text-end">
                                    <span id="titleCount">0</span>/100
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="mb-4">
                                <label asp-for="ReporterEmail" class="form-label fw-semibold">
                                    <i class="bi bi-envelope me-1 text-success"></i>
                                    <span data-i18n="report_field_email">Your Email</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="ReporterEmail"
                                       type="email"
                                       class="form-control form-control-lg"
                                       placeholder="your@email.com"
                                       data-i18n="[placeholder]report_placeholder_email" />
                                <span asp-validation-for="ReporterEmail" class="text-danger small"></span>
                                <div class="form-text" data-i18n="report_email_hint">
                                    We may contact you for more details.
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="mb-5">
                                <label asp-for="Description" class="form-label fw-semibold">
                                    <i class="bi bi-chat-text me-1 text-success"></i>
                                    <span data-i18n="report_field_desc">Description</span>
                                    <span class="text-danger">*</span>
                                </label>
                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="6"
                                          placeholder="Please describe the issue in detail. What happened? What did you expect to happen? Steps to reproduce..."
                                          data-i18n="[placeholder]report_placeholder_desc"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <!-- Submit -->
                            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                <a href="/" class="btn btn-outline-secondary px-4" data-i18n="report_back">
                                    <i class="bi bi-arrow-left me-1"></i> Back to Home
                                </a>
                                <button type="submit" class="btn btn-success btn-lg px-5" id="submitBtn">
                                    <span class="btn-text">
                                        <i class="bi bi-send-fill me-2"></i>
                                        <span data-i18n="report_submit">Submit Report</span>
                                    </span>
                                    <span class="btn-loading d-none">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        Submitting...
                                    </span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Info -->
                <div class="row g-3 mt-4">
                    <div class="col-md-4">
                        <div class="info-card text-center p-3">
                            <i class="bi bi-shield-check text-success fs-4 mb-2 d-block"></i>
                            <div class="small fw-semibold" data-i18n="report_info_secure">Secure & Private</div>
                            <div class="x-small text-muted" data-i18n="report_info_secure_desc">Your data is safe with us</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-card text-center p-3">
                            <i class="bi bi-clock text-success fs-4 mb-2 d-block"></i>
                            <div class="small fw-semibold" data-i18n="report_info_fast">Fast Response</div>
                            <div class="x-small text-muted" data-i18n="report_info_fast_desc">We review within 24–48 hours</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-card text-center p-3">
                            <i class="bi bi-people text-success fs-4 mb-2 d-block"></i>
                            <div class="small fw-semibold" data-i18n="report_info_team">Dedicated Team</div>
                            <div class="x-small text-muted" data-i18n="report_info_team_desc">Real people handle your report</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        // Character counter for title
        const titleInput = document.getElementById('Title');
        const titleCount = document.getElementById('titleCount');
        if (titleInput) {
            titleInput.addEventListener('input', function () {
                titleCount.textContent = this.value.length;
                titleCount.className = this.value.length >= 90 ? 'text-warning fw-bold' : '';
            });
        }

        // Loading state on submit
        document.getElementById('reportForm').addEventListener('submit', function (e) {
            const btn = document.getElementById('submitBtn');
            // Only show loading if form is valid
            if (this.checkValidity()) {
                btn.querySelector('.btn-text').classList.add('d-none');
                btn.querySelector('.btn-loading').classList.remove('d-none');
                btn.disabled = true;
            }
        });
    </script>
}

<style>
    .report-issue-page {
        min-height: 80vh;
        background: linear-gradient(135deg, #f0fdf4 0%, #f8fafc 100%);
    }

    .report-icon-wrap {
        width: 72px;
        height: 72px;
        background: linear-gradient(135deg, #16a34a, #22c55e);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
        box-shadow: 0 8px 24px rgba(22, 163, 74, 0.3);
    }

    .report-card {
        border-radius: 16px;
        overflow: hidden;
    }

    .form-control:focus {
        border-color: #16a34a;
        box-shadow: 0 0 0 0.2rem rgba(22, 163, 74, 0.15);
    }

    .form-control-lg {
        border-radius: 8px;
    }

    .btn-success {
        background: linear-gradient(135deg, #16a34a, #15803d);
        border: none;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .btn-success:hover {
        background: linear-gradient(135deg, #15803d, #166534);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(22, 163, 74, 0.35);
    }

    .info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .x-small {
        font-size: 0.75rem;
    }
</style>
