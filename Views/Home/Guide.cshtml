@{
    ViewData["Title"] = "How to Rent";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">🚀 How to Rent a Vehicle</h1>
        <p class="text-muted lead">Your comprehensive guide to using SaigonRide</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Step 1 -->
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 bg-sr-green-light d-flex align-items-center justify-content-center p-4">
                        <div class="text-center">
                            <i class="bi bi-geo-alt fs-1 text-sr-green mb-2 d-block"></i>
                            <h3 class="fw-bold text-sr-green mb-0">Step 1</h3>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-3">Find a Nearby Station</h4>
                            <p class="text-muted mb-3">
                                SaigonRide has over 50 stations distributed across Ho Chi Minh City. You can easily locate the nearest station using our <a href="/#station-search" class="text-sr-green text-decoration-none fw-semibold">Station Search map</a> on the homepage.
                            </p>
                            <ul class="text-muted small">
                                <li>Check the real-time availability of bicycles and e-scooters.</li>
                                <li>View the battery percentage of e-scooters before heading to the station.</li>
                                <li>Ensure the station is marked as "Normal" or "Full" to guarantee a ride.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 order-md-2 bg-light d-flex align-items-center justify-content-center p-4">
                        <div class="text-center">
                            <i class="bi bi-bicycle fs-1 text-primary mb-2 d-block"></i>
                            <h3 class="fw-bold text-primary mb-0">Step 2</h3>
                        </div>
                    </div>
                    <div class="col-md-8 order-md-1">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-3">Select & Unlock Your Ride</h4>
                            <p class="text-muted mb-3">
                                Once you arrive at the station, choose between our standard bicycles (for exercise and short trips) or electric scooters (for fast, effortless commuting).
                            </p>
                            <ul class="text-muted small">
                                <li>Click the "Standard" or "Electric" button on the station card to proceed to checkout.</li>
                                <li>Review the pricing (500đ/min for Standard, 1.5kđ/min for Electric).</li>
                                <li>Confirm your rental and the vehicle will automatically unlock.</li>
                            </ul>
                            <div class="alert alert-info py-2 small mb-0 mt-3 border-0 bg-opacity-10 bg-primary text-primary">
                                <i class="bi bi-info-circle me-1"></i> Make sure to inspect the vehicle quickly before riding. Start your trip with peace of mind!
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-4 bg-sr-green-light d-flex align-items-center justify-content-center p-4">
                        <div class="text-center">
                            <i class="bi bi-check-circle fs-1 text-sr-green mb-2 d-block"></i>
                            <h3 class="fw-bold text-sr-green mb-0">Step 3</h3>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="fw-bold mb-3">Return & Complete</h4>
                            <p class="text-muted mb-3">
                                Enjoy your ride! When you are finished, you can return the vehicle to <strong>any</strong> SaigonRide station, it doesn't have to be the one you started from.
                            </p>
                            <ul class="text-muted small">
                                <li>Park the vehicle securely in an available slot at the destination station.</li>
                                <li>Open the app/website and click "End Trip" on your active rental.</li>
                                <li>The system will calculate the final fare based on your total riding time.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <h5 class="fw-bold mb-3">Ready to start?</h5>
                <a href="/#station-search" class="btn btn-success px-5 py-3 fw-bold rounded-pill shadow-sm">
                    Find a Station Now
                </a>
            </div>
        </div>
    </div>
</div>
