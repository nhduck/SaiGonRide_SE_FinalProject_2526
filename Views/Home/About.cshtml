@{
    ViewData["Title"] = "About Us";
    ViewData["MetaDescription"] = "Learn about SaigonRide – the pioneer bike & e-scooter sharing startup in Ho Chi Minh City. Our mission, vision, team, and story.";
}

<!-- Hero -->
<section style="background:linear-gradient(135deg,#064e3b,#065f46);padding:5rem 0;position:relative;overflow:hidden;">
    <div style="position:absolute;top:-80px;right:-80px;width:300px;height:300px;border-radius:50%;
                background:rgba(22,163,74,.15);filter:blur(60px);"></div>
    <div class="container text-center position-relative">
        <span class="badge mb-3" style="background:rgba(74,222,128,.2);color:#4ade80;border:1px solid rgba(74,222,128,.3);
              padding:.5rem 1.25rem;border-radius:999px;font-size:.85rem;" data-i18n="about_badge">🚲 Our Story</span>
        <h1 class="display-5 fw-bold text-white mt-2 mb-3" data-i18n="about_title">About SaigonRide</h1>
        <p class="text-white-50 mx-auto" style="max-width:560px;font-size:1.05rem;line-height:1.75;" data-i18n="about_subtitle">
            Built by young people who love Saigon, we solve urban mobility the greenest way possible.
        </p>
    </div>
</section>

<!-- Mission -->
<section class="sr-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 sr-reveal sr-reveal-left">
                <span class="sr-price-badge mb-3" data-i18n="about_mission_badge">Our Mission</span>
                <h2 class="fw-bold mt-3 mb-3" style="font-size:2rem;" data-i18n="about_mission_title">Making Saigon greener, every day</h2>
                <p class="text-muted" style="line-height:1.8;" data-i18n-html="about_mission_desc1">
                    SaigonRide was founded with a simple mission: <strong>provide smart, eco-friendly urban transport</strong>
                    for the people of Ho Chi Minh City.
                </p>
                <p class="text-muted" style="line-height:1.8;" data-i18n="about_mission_desc2">
                    Every bike or e-scooter ride saves around 200g of CO₂ compared to a regular motorbike.
                    With thousands of rides per day, we are creating real, measurable change for our city together.
                </p>
                <div class="d-flex gap-4 mt-4">
                    <div>
                        <div class="fw-bold text-success fs-3">2024</div>
                        <div class="text-muted small" data-i18n="about_mission_founded">Founded</div>
                    </div>
                    <div>
                        <div class="fw-bold text-success fs-3">50+</div>
                        <div class="text-muted small" data-i18n="stat_stations">Stations</div>
                    </div>
                    <div>
                        <div class="fw-bold text-success fs-3">500+</div>
                        <div class="text-muted small" data-i18n="stat_vehicles">Vehicles</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center sr-reveal sr-reveal-right">
                <div style="font-size:9rem;filter:drop-shadow(0 20px 40px rgba(22,163,74,.2));">🌱</div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="sr-section" style="background:var(--sr-gray-50);">
    <div class="container">
        <div class="text-center mb-5 sr-reveal">
            <h2 class="fw-bold" style="font-size:2rem;" data-i18n="about_values_title">Our Core Values</h2>
        </div>
        <div class="row g-4">
            @{
                var values = new[] {
                    new { Icon="🌿", Color="#dcfce7", Title="Green & Sustainable",
                          Desc="Every decision we make is guided by reducing CO₂ emissions and protecting Saigon's environment." },
                    new { Icon="🤝", Color="#dbeafe", Title="Transparent & Trustworthy",
                          Desc="Clear pricing, no hidden charges. Your data is protected end-to-end with bank-grade security." },
                    new { Icon="⚡", Color="#fef9c3", Title="Fast & Convenient",
                          Desc="Unlock a vehicle in 10 seconds. Automatic billing. No cash, no dedicated app." },
                    new { Icon="💛", Color="#ffe4e6", Title="Community First",
                          Desc="5% of all revenue is donated to the HCMC Urban Green Tree Fund." },
                };
            }
            @foreach (var v in values)
            {
                <div class="col-md-6 col-lg-3 sr-reveal">
                    <div class="text-center p-4 h-100 bg-white rounded-4 shadow-sm border border-light">
                        <div style="font-size:2.5rem;margin-bottom:1rem;">@v.Icon</div>
                        <div style="width:48px;height:4px;background:#16a34a;border-radius:999px;margin:0 auto 1rem;"></div>
                        <h5 class="fw-bold mb-2">@v.Title</h5>
                        <p class="text-muted mb-0" style="font-size:.9rem;line-height:1.65;">@v.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Team -->
<section class="sr-section">
    <div class="container">
        <div class="text-center mb-5 sr-reveal">
            <h2 class="fw-bold" style="font-size:2rem;" data-i18n="about_team_title">Our Founding Team</h2>
            <p class="text-muted" data-i18n="about_team_subtitle">Young people passionate about tech and the city of Saigon</p>
        </div>
        <div class="row g-4 justify-content-center">
            @{
                var members = new[] {
                    new { Name="Truong Minh Thanh", Role="Developer & CEO", Emoji="🧑‍💻", School="Ton Duc Thang University" },
                    new { Name="Ngo Huynh Duc",  Role="Developer & CTO", Emoji="🧑‍💻", School="Ton Duc Thang University" },
                    new { Name="Lam Tan Dat",    Role="Leak Designer",    Emoji="🐶", School="Ton Duc Thang University" },
                };
            }
            @foreach (var m in members)
            {
                <div class="col-md-4 sr-reveal">
                    <div class="text-center p-4 bg-white rounded-4 shadow-sm border border-light h-100">
                        <div style="font-size:4rem;margin-bottom:1rem;">@m.Emoji</div>
                        <h5 class="fw-bold mb-1">@m.Name</h5>
                        <div class="text-sr-green fw-semibold mb-1" style="font-size:.9rem;">@m.Role</div>
                        <div class="text-muted" style="font-size:.82rem;">@m.School</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="sr-section-sm">
    <div class="container text-center sr-reveal">
        <h3 class="fw-bold mb-3" data-i18n="about_cta_title">Want to ride with SaigonRide?</h3>
        <p class="text-muted mb-4" data-i18n="about_cta_desc">Join thousands of riders helping make Saigon greener every day.</p>
        <a asp-controller="Account" asp-action="Register"
           class="btn btn-success btn-lg px-5 rounded-pill fw-bold"
           style="box-shadow:0 8px 24px rgba(22,163,74,.3);">
            <i class="bi bi-person-plus me-2"></i><span data-i18n="cta_register">Register Free</span>
        </a>
    </div>
</section>
