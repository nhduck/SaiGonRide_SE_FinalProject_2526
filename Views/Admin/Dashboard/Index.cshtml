@model RentalVehicleService.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var fillPct = (int)(Model.AverageFillRate * 100);
}

<!-- Row 1: Stat Cards -->
<div class="row g-3 mb-4">
    <!-- Total Stations -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 p-3 bg-sr-green-light me-3">
                    <i class="bi bi-geo-alt-fill fs-4 text-sr-green"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Stations</div>
                    <h3 class="mb-0 fw-bold" id="stat-stations">@Model.TotalStations</h3>
                    <small class="text-success"><i class="bi bi-check-circle me-1"></i>Active</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Total Vehicles -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 p-3" style="background: #e0f2fe;">
                    <i class="bi bi-bicycle fs-4" style="color: #0284c7;"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Total Vehicles</div>
                    <h3 class="mb-0 fw-bold" id="stat-vehicles">@Model.TotalVehicles</h3>
                    <small class="text-muted">
                        <span class="text-success">@Model.AvailableVehicles available</span> · @Model.RentedVehicles rented
                    </small>
                </div>
            </div>
        </div>
    </div>
    <!-- Active Rentals -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 p-3" style="background: #fef3c7;">
                    <i class="bi bi-activity fs-4" style="color: #d97706;"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Active Rentals</div>
                    <h3 class="mb-0 fw-bold" id="stat-active">@Model.ActiveRentals</h3>
                    <small class="text-warning"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Realtime</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Today Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 p-3" style="background: #ede9fe;">
                    <i class="bi bi-cash-stack fs-4" style="color: #7c3aed;"></i>
                </div>
                <div class="ms-3">
                    <div class="text-muted small">Today's Revenue</div>
                    <h3 class="mb-0 fw-bold" id="stat-revenue">@Model.TodayRevenue.ToString("N0")đ</h3>
                    <small class="text-muted">VND</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Charts -->
<div class="row g-3 mb-4">
    <!-- Revenue Line Chart -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-semibold mb-0"><i class="bi bi-graph-up me-2"></i>7-Day Revenue</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="280"></canvas>
            </div>
        </div>
    </div>
    <!-- Fill Rate Gauge -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-semibold mb-0"><i class="bi bi-pie-chart me-2"></i>Avg Fill Rate</h6>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <div class="sr-gauge-wrapper mb-3">
                    <canvas id="fillGauge" width="200" height="200"></canvas>
                    <div class="sr-gauge-label">
                        <span class="fs-2 fw-bold">@fillPct%</span>
                    </div>
                </div>
                <div class="text-center">
                    <div class="row text-center g-3">
                        <div class="col-4">
                            <div class="small text-muted">Standard</div>
                            <div class="fw-bold text-sr-green">@Model.StandardVehicles</div>
                        </div>
                        <div class="col-4">
                            <div class="small text-muted">Electric</div>
                            <div class="fw-bold" style="color:#0284c7;">@Model.ElectricVehicles</div>
                        </div>
                        <div class="col-4">
                            <div class="small text-muted">Maintenance</div>
                            <div class="fw-bold text-danger">@Model.MaintenanceVehicles</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Tables -->
<div class="row g-3">
    <!-- Low Fill Stations -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-semibold mb-0"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Stations Needing Vehicles</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.LowFillStations.Any(s => s.FillRate < 0.20))
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Station Name</th>
                                    <th class="text-center">Count</th>
                                    <th class="text-center">Rate</th>
                                    <th class="text-center">Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.LowFillStations.Where(s => s.FillRate < 0.20))
                                {
                                    var pct = (int)(s.FillRate * 100);
                                    <tr>
                                        <td>
                                            <div class="fw-semibold small">@s.Name</div>
                                            <div class="text-muted" style="font-size:0.75rem;">@s.Address</div>
                                        </td>
                                        <td class="text-center align-middle">@s.CurrentCount / @s.TotalCapacity</td>
                                        <td class="text-center align-middle">
                                            <div class="fill-bar" style="width:60px; display:inline-block;">
                                                <div class="fill-bar-inner fill-red" style="width:@(pct)%"></div>
                                            </div>
                                            <div class="small fw-bold text-danger">@pct%</div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="low-inventory-badge">⚠ Dispatch needed</span>
                                        </td>
                                        <td class="align-middle">
                                            <a href="/Admin/Stations/Details/@s.StationId" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-check-circle fs-1 text-success d-block mb-2"></i>
                        All stations are adequately stocked
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Activities -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-semibold mb-0"><i class="bi bi-clock-history me-2"></i>Recent Activities</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentActivities.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Customer</th>
                                    <th>Type</th>
                                    <th>Station</th>
                                    <th>Time</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.RecentActivities)
                                {
                                    var badgeClass = a.Status == "Active" ? "bg-warning text-dark" :
                                                    a.Status == "Completed" ? "bg-success" : "bg-secondary";
                                    var statusText = a.Status == "Active" ? "Active" :
                                                     a.Status == "Completed" ? "Completed" : "Cancelled";
                                    <tr>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center">
                                                <div class="sr-avatar sr-avatar-sm me-2">
                                                    <i class="bi bi-person-fill"></i>
                                                </div>
                                                <span class="small">@a.UserName</span>
                                            </div>
                                        </td>
                                        <td class="align-middle">
                                            <span class="badge @(a.VehicleType == "Electric" ? "bg-primary" : "bg-success") bg-opacity-10 @(a.VehicleType == "Electric" ? "text-primary" : "text-success")">
                                                @(a.VehicleType == "Electric" ? "⚡" : "🚲") @a.VehicleType
                                            </span>
                                        </td>
                                        <td class="align-middle small">@a.StationName</td>
                                        <td class="align-middle small">@a.StartTime.ToString("HH:mm dd/MM")</td>
                                        <td class="align-middle">
                                            <span class="badge @badgeClass rounded-pill">@statusText</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No activities found
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .sr-gauge-wrapper {
            position: relative;
            width: 180px;
            height: 180px;
        }
        .sr-gauge-label {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Revenue Line Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.RevenueByDay.Select(r => $"'{r.DayLabel}'")))],
                datasets: [
                    {
                        label: 'Standard',
                        data: [@string.Join(",", Model.RevenueByDay.Select(r => r.StandardRevenue))],
                        borderColor: '#16a34a',
                        backgroundColor: 'rgba(22, 163, 74, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#16a34a'
                    },
                    {
                        label: 'Electric',
                        data: [@string.Join(",", Model.RevenueByDay.Select(r => r.ElectricRevenue))],
                        borderColor: '#0284c7',
                        backgroundColor: 'rgba(2, 132, 199, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#0284c7'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { usePointStyle: true, padding: 20 }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ctx.dataset.label + ': ' + new Intl.NumberFormat('vi-VN').format(ctx.parsed.y) + 'đ';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(v) { return new Intl.NumberFormat('vi-VN').format(v) + 'đ'; }
                        }
                    }
                }
            }
        });

        // Fill Rate Donut
        const gaugeCtx = document.getElementById('fillGauge').getContext('2d');
        const fillPct = @fillPct;
        const fillColor = fillPct < 60 ? '#16a34a' : (fillPct < 85 ? '#f59e0b' : '#ef4444');
        new Chart(gaugeCtx, {
            type: 'doughnut',
            data: {
                datasets: [{
                    data: [fillPct, 100 - fillPct],
                    backgroundColor: [fillColor, '#e2e8f0'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '75%',
                plugins: { legend: { display: false }, tooltip: { enabled: false } },
                rotation: -90,
                circumference: 360
            }
        });

        // Auto-refresh stats every 30s
        setInterval(async () => {
            try {
                const res = await fetch('/Admin/Dashboard/GetStats');
                const data = await res.json();
                document.getElementById('stat-stations').textContent = data.totalStations;
                document.getElementById('stat-vehicles').textContent = data.totalVehicles;
                document.getElementById('stat-active').textContent = data.activeRentals;
                document.getElementById('stat-revenue').textContent =
                    new Intl.NumberFormat('vi-VN').format(data.todayRevenue) + 'đ';
            } catch (e) {
                console.error('Auto-refresh failed:', e);
            }
        }, 30000);
    </script>
}
