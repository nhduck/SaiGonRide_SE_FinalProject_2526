@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Edit Station";
}

<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <a href="/Admin/Stations" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>Manage Stations</a>
        <span class="text-muted small">/</span>
        <span class="text-muted small">Edit</span>
    </div>
    <h4 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit: @Model.Name</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="StationId" />

            <!-- Validation summary for model wide errors, like TotalCapacity < CurrentCount -->
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-4">
                <!-- Left column -->
                <div class="col-md-7">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Latitude" class="form-label fw-semibold"></label>
                            <input asp-for="Latitude" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Longitude" class="form-label fw-semibold"></label>
                            <input asp-for="Longitude" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Right column -->
                <div class="col-md-5">
                    <!-- Current fill rate visualization -->
                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <label class="form-label fw-semibold mb-0">Station Status</label>
                            <span class="small fw-bold">@((int)(Model.FillRate * 100))%</span>
                        </div>
                        
                        @{ var pct = (int)(Model.FillRate * 100); 
                           var barColorClass = pct < 60 ? "fill-green" : (pct < 85 ? "fill-amber" : "fill-red");
                        }
                        <div class="fill-bar mb-2">
                            <div class="fill-bar-inner @barColorClass" style="width: @pct%"></div>
                        </div>
                        
                        <div class="small text-muted d-flex justify-content-between mb-2">
                            <span>Currently holding: <strong>@Model.CurrentCount</strong> vehicles</span>
                        </div>

                        <!-- Readonly CurrentCount -->
                        <div class="mb-0 visually-hidden">
                            <input asp-for="CurrentCount" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TotalCapacity" class="form-label fw-semibold"></label>
                        <input asp-for="TotalCapacity" class="form-control" />
                        <span asp-validation-for="TotalCapacity" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" role="switch" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-semibold text-dark">
                    <i class="bi bi-save me-1"></i>Save Changes
                </button>
                <a href="/Admin/Stations" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
