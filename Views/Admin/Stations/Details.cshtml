@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Station Details";
    var pct = (int)(Model.FillRate * 100);
    var barColorClass = pct < 60 ? "fill-green" : (pct < 85 ? "fill-amber" : "fill-red");
    var badgeClass = Model.IsLowInventory ? "bg-danger" : (pct > 85 ? "bg-warning text-dark" : "bg-success");
    var badgeText = Model.IsLowInventory ? "Low Stock" : (pct > 85 ? "Full" : "Normal");
}

<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <a href="/Admin/Stations" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>Manage Stations</a>
        <span class="text-muted small">/</span>
        <span class="text-muted small">Details</span>
    </div>
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-info-circle me-2"></i>@Model.Name
            <span class="badge @badgeClass ms-2 fs-6 pb-1 rounded-pill">@badgeText</span>
            @if (!Model.IsActive)
            {
                <span class="badge bg-secondary ms-2 fs-6 pb-1 rounded-pill">Disabled</span>
            }
        </h4>
        <a href="/Admin/Stations/Edit/@Model.StationId" class="btn btn-warning text-dark fw-semibold">
            <i class="bi bi-pencil me-1"></i>Edit Info
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Info Card -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold"><i class="bi bi-card-text me-2"></i>General Information</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless table-sm mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted" style="width: 120px;">Station Name:</td>
                            <td class="fw-semibold">@Model.Name</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Address:</td>
                            <td class="fw-semibold">@Model.Address</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Coordinates:</td>
                            <td>
                                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                                {
                                    <a href="https://www.google.com/maps/search/?api=1&query=@Model.Latitude,@Model.Longitude" target="_blank" class="text-decoration-none">
                                        <i class="bi bi-map me-1"></i>@Model.Latitude, @Model.Longitude
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Not configured</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Status:</td>
                            <td>
                                @if (Model.IsActive)
                                {
                                    <span class="text-success fw-semibold"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="text-muted fw-semibold"><i class="bi bi-x-circle me-1"></i>Suspended</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Stats Card -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold"><i class="bi bi-bar-chart me-2"></i>Capacity Statistics</h6>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-4">
                    <div class="me-4 flex-shrink-0">
                        <!-- Chart JS requires a canvas -->
                        <div style="position: relative; width: 120px; height: 120px;">
                            <canvas id="detailsFillGauge"></canvas>
                            <div style="position: absolute; top:50%; left:50%; transform:translate(-50%, -50%);" class="fw-bold fs-4">
                                @pct%
                            </div>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="text-muted">Current Count:</span>
                            <span class="fw-bold fs-5">@Model.CurrentCount <span class="fs-6 text-muted fw-normal">vehicles</span></span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="text-muted">Total Capacity:</span>
                            <span class="fw-bold fs-5">@Model.TotalCapacity <span class="fs-6 text-muted fw-normal">vehicles</span></span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 mt-2">
                             @{
                                 var standardCount = Model.Vehicles.Count(v => v.Type == RentalVehicleService.Models.VehicleType.Standard && v.State == RentalVehicleService.Models.VehicleState.Available);
                                 var electricCount = Model.Vehicles.Count(v => v.Type == RentalVehicleService.Models.VehicleType.Electric && v.State == RentalVehicleService.Models.VehicleState.Available);
                             }
                            <div class="text-center">
                                <div class="small text-muted mb-1"><i class="bi bi-bicycle me-1"></i>Standard</div>
                                <span class="fw-bold text-success">@standardCount</span>
                            </div>
                            <div class="text-center">
                                <div class="small text-muted mb-1"><i class="bi bi-lightning-charge me-1"></i>Electric</div>
                                <span class="fw-bold text-primary">@electricCount</span>
                            </div>
                            <div class="text-center">
                                <div class="small text-muted mb-1"><i class="bi bi-tools me-1"></i>Maintenance</div>
                                <span class="fw-bold text-danger">@Model.Vehicles.Count(v => v.State == RentalVehicleService.Models.VehicleState.Maintenance)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Vehicles List -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 pb-2 d-flex justify-content-between align-items-center">
        <h6 class="fw-semibold mb-0"><i class="bi bi-list-ul me-2"></i>Available Vehicles at Station</h6>
        <span class="badge bg-light text-dark border">Total: @Model.Vehicles.Count vehicles</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Vehicles.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Model</th>
                            <th>Type</th>
                            <th class="text-center">Battery</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Last Maintenance</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Vehicles.OrderBy(v => v.VehicleId))
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-semibold">#@v.VehicleId</td>
                                <td class="fw-semibold">@v.VehicleModel</td>
                                <td>
                                    @if(v.Type == RentalVehicleService.Models.VehicleType.Standard)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-bicycle me-1"></i>Standard</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary"><i class="bi bi-lightning-charge me-1"></i>Electric</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @{
                                        var bColor = v.BatteryPercentage > 50 ? "success" : (v.BatteryPercentage > 20 ? "warning" : "danger");
                                        var bIcon = v.BatteryPercentage > 50 ? "full" : (v.BatteryPercentage > 20 ? "half" : "empty");
                                    }
                                    <span class="text-@bColor fw-semibold"><i class="bi bi-battery-@bIcon me-1"></i>@v.BatteryPercentage%</span>
                                </td>
                                <td class="text-center">
                                    @switch (v.State)
                                    {
                                        case RentalVehicleService.Models.VehicleState.Available:
                                            <span class="badge bg-success rounded-pill">Available</span>
                                            break;
                                        case RentalVehicleService.Models.VehicleState.Rented:
                                            <span class="badge bg-warning rounded-pill text-dark">Rented</span>
                                            break;
                                        case RentalVehicleService.Models.VehicleState.Charging:
                                            <span class="badge bg-info rounded-pill">Charging</span>
                                            break;
                                        case RentalVehicleService.Models.VehicleState.Maintenance:
                                            <span class="badge bg-danger rounded-pill">Maintenance</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center small text-muted">@v.LastMaintenance.ToString("MM/dd/yyyy")</td>
                                <td class="text-end pe-4">
                                     <a href="/Vehicles/Details/@v.VehicleId" class="btn btn-sm btn-outline-secondary" title="View vehicle">
                                         <i class="bi bi-box-arrow-up-right"></i>
                                     </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-bicycle fs-1 text-muted d-block mb-3 opacity-50"></i>
                <p class="text-muted mb-0">There are no vehicles currently at this station.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Fill Rate Donut
        const gaugeCtx = document.getElementById('detailsFillGauge').getContext('2d');
        const fillPct = @pct;
        const fillColor = fillPct < 60 ? '#16a34a' : (fillPct < 85 ? '#f59e0b' : '#ef4444');
        new Chart(gaugeCtx, {
            type: 'doughnut',
            data: {
                datasets: [{
                    data: [fillPct, 100 - fillPct],
                    backgroundColor: [fillColor, '#e2e8f0'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '75%',
                plugins: { legend: { display: false }, tooltip: { enabled: false } },
                rotation: -90,
                circumference: 360
            }
        });
    </script>
}
