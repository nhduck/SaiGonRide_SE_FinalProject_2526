    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/bootstrap/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/nprogress@0.2.0/nprogress.min.js"></script>

    <script>
        // NProgress
        NProgress.configure({
            showSpinner: false,
            speed: 350,
            minimum: 0.08,
            trickle: true,
            trickleSpeed: 180
        });
        NProgress.start();

        let _npDone = false;
        function _finishNProgress() {
            if (_npDone) return;
            _npDone = true;
            NProgress.done(true);
        }

        if (document.readyState === 'complete') {
            _finishNProgress();
        } else {
            // { once: true } — fires EXACTLY once, auto-removes itself
            window.addEventListener('load', _finishNProgress, { once: true });
        }

        // Start bar on navigation (guard: only real page links)
        document.querySelectorAll(
            'a[href]:not([href^="#"]):not([href^="javascript"]):not([href^="tel"]):not([href^="mailto"]):not([target="_blank"])'
        ).forEach(a => {
            a.addEventListener('click', function () {
                // Only start if navigating away (same origin)
                try {
                    const url = new URL(this.href, location.origin);
                    if (url.origin === location.origin) NProgress.start();
                } catch (_) {}
            });
        });
        document.querySelectorAll('form').forEach(f => {
            f.addEventListener('submit', () => NProgress.start());
        });

        // Theme Toggle Logic
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        function updateThemeIcon(theme) {
            if (!themeIcon) return;
            if (theme === 'dark') {
                themeIcon.classList.remove('bi-moon-stars-fill');
                themeIcon.classList.add('bi-sun-fill');
            } else {
                themeIcon.classList.remove('bi-sun-fill');
                themeIcon.classList.add('bi-moon-stars-fill');
            }
        }

        // Initialize icon
        updateThemeIcon(document.documentElement.getAttribute('data-bs-theme'));

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                const currentTheme = document.documentElement.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                
                document.documentElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('sr-theme', newTheme);
                updateThemeIcon(newTheme);
            });
        }

        // Navbar scroll shrink
        const nav = document.getElementById('mainNav');
        if (nav) {
            window.addEventListener('scroll', () => {
                nav.classList.toggle('sr-navbar-scrolled', window.scrollY > 50);
            }, { passive: true });
        }

        // Scroll-reveal
        const srObserver = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('sr-revealed');
                    srObserver.unobserve(e.target);
                }
            });
        }, { threshold: 0.12 });
        document.querySelectorAll('.sr-reveal').forEach(el => srObserver.observe(el));

    </script>
    <!-- Custom i18n (replaces Google Translate — no toolbar, instant switch) -->
    <script src="~/js/i18n.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

