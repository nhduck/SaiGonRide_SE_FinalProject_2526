@using Microsoft.AspNetCore.Identity
@inject SignInManager<RentalVehicleService.Models.ApplicationUser> SignInManager
@inject UserManager<RentalVehicleService.Models.ApplicationUser> UserManager

@{
    var appUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var displayName = string.IsNullOrWhiteSpace(appUser?.FullName) ? User.Identity?.Name : appUser.FullName;
    var pageTitle   = ViewData["Title"]?.ToString() ?? "Home";
    var metaDesc    = ViewData["MetaDescription"]?.ToString()
                      ?? "SaigonRide – Smart bike & e-scooter rental network across Ho Chi Minh City. Green, convenient, and affordable urban mobility.";
    var ogImage     = ViewData["OgImage"]?.ToString() ?? "/img/og-banner.png";
    var isHomePage  = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && 
                      ViewContext.RouteData.Values["action"]?.ToString() == "Index";

    // Logic to show FAB only on specific pages
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAct  = ViewContext.RouteData.Values["action"]?.ToString();
    var showFab     = (currentCtrl == "Home" && (new[] { "Index", "About", "FAQ", "Guide" }).Contains(currentAct)) || 
                      (currentCtrl == "Account" && currentAct == "Profile") ||
                      (currentCtrl == "Payment");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- SEO -->
    <title>@pageTitle - SaigonRide</title>
    <meta name="description" content="@metaDesc" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="SaigonRide Team" />
    <meta name="keywords" content="bike rental, e-scooter, SaigonRide, Ho Chi Minh City, HCMC, green transport, cycling" />
    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content="@pageTitle - SaigonRide" />
    <meta property="og:description" content="@metaDesc" />
    <meta property="og:image"       content="@ogImage" />
    <meta property="og:url"         content="https://saigonride-web.onrender.com/" />
    <meta property="og:locale"      content="en_US" />
    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@pageTitle - SaigonRide" />
    <meta name="twitter:description" content="@metaDesc" />
    <meta name="twitter:image"       content="https://saigonride-web.onrender.com/img/og-banner.png" />
    <!-- Canonical -->
    <link rel="canonical" href="https://saigonride-web.onrender.com@Context.Request.Path" />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <!-- NProgress -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/nprogress@0.2.0/nprogress.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LayoutStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bike-animation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Styles", required: false)

    <script>
        (function() {
            const savedTheme = localStorage.getItem('sr-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>
    <style>
        #nprogress .bar { background: #16a34a !important; height: 3px; }
        #nprogress .peg  { box-shadow: 0 0 10px #16a34a, 0 0 5px #16a34a !important; }
        #nprogress .spinner-icon {
            border-top-color: #16a34a !important;
            border-left-color: #16a34a !important;
