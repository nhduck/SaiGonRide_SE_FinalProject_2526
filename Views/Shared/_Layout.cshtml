@using Microsoft.AspNetCore.Identity
@inject SignInManager<RentalVehicleService.Models.ApplicationUser> SignInManager
@inject UserManager<RentalVehicleService.Models.ApplicationUser> UserManager

@{
    var appUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var displayName = string.IsNullOrWhiteSpace(appUser?.FullName) ? User.Identity?.Name : appUser.FullName;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SaigonRide - Bike and e-scooter rental in HCMC" />
    <title>@ViewData["Title"] - SaigonRide</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <style>
        /* Premium FAB Styles */
        .fab-wrapper {
            position: fixed;
            bottom: 25px;
            right: 25px;
            z-index: 1050;
        }

        .fab-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background: linear-gradient(135deg, #16a34a, #15803d);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.5rem;
            position: relative;
            z-index: 1001;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            box-shadow: 0 8px 16px rgba(22, 163, 74, 0.3);
        }

        .fab-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 14px 28px rgba(22, 163, 74, 0.4);
        }

        .pulse-animation::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: inherit;
            border-radius: inherit;
            z-index: -1;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { transform: scale(1); opacity: 0.6; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        .fab-icon-main {
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        .fab-icon-close {
            position: absolute;
            opacity: 0;
            transform: rotate(-90deg) scale(0.5);
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            font-size: 1.5rem;
        }

        .fab-checkbox:checked ~ .fab-btn .fab-icon-main {
            opacity: 0;
            transform: rotate(90deg) scale(0);
        }

        .fab-checkbox:checked ~ .fab-btn .fab-icon-close {
            opacity: 1;
            transform: rotate(0) scale(1);
        }

        .fab-checkbox:checked ~ .fab-btn::before {
            animation: none;
            opacity: 0;
        }

        .fab-menu {
            position: absolute;
            bottom: 70px;
            right: 2px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
            align-items: flex-end;
        }

        .fab-item-container {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 12px;
        }

        .fab-item {
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            opacity: 0;
            transform: translateY(20px) scale(0.8);
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            border: none !important;
        }

        .fab-item:hover {
            transform: scale(1.1) !important;
            box-shadow: 0 8px 15px rgba(0,0,0,0.2) !important;
        }

        .fab-checkbox:checked ~ .fab-menu {
            pointer-events: auto;
        }

        .fab-checkbox:checked ~ .fab-menu .fab-item {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        /* Staggered item animation */
        .fab-item-container:nth-child(3) .fab-item { transition-delay: 0.05s; }
        .fab-item-container:nth-child(2) .fab-item { transition-delay: 0.1s; }
        .fab-item-container:nth-child(1) .fab-item { transition-delay: 0.15s; }

        .fab-item-label {
            background: #212529;
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
            opacity: 0;
            pointer-events: none;
            transform: translateX(10px);
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* Staggered label animation */
        .fab-checkbox:checked ~ .fab-menu .fab-item-container:nth-child(3) .fab-item-label { transition-delay: 0.1s; opacity: 1; transform: translateX(0); }
        .fab-checkbox:checked ~ .fab-menu .fab-item-container:nth-child(2) .fab-item-label { transition-delay: 0.15s; opacity: 1; transform: translateX(0); }
        .fab-checkbox:checked ~ .fab-menu .fab-item-container:nth-child(1) .fab-item-label { transition-delay: 0.2s; opacity: 1; transform: translateX(0); }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!--NAVBAR -->
    <nav class="navbar navbar-expand-xl sticky-top sr-navbar">
        <div class="container-fluid px-4 px-xl-5">
            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center text-nowrap" href="/">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
                     stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 flex-shrink-0">
                    <circle cx="5.5" cy="17.5" r="3.5"/>
                    <circle cx="18.5" cy="17.5" r="3.5"/>
                    <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                </svg>
                <span class="sr-brand-text fw-bold">SaigonRide</span>
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Collapsible content -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Nav Links -->
                <ul class="navbar-nav me-auto mb-2 mb-xl-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link text-nowrap d-flex align-items-center" href="/">
                            <i class="bi bi-house-door me-1"></i><span>Home</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-nowrap d-flex align-items-center" href="/#station-search">
                            <i class="bi bi-geo-alt me-1"></i><span>Find Stations</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-nowrap d-flex align-items-center" href="/Home/Guide">
                            <i class="bi bi-info-circle me-1"></i><span>How It Works</span>
                        </a>
                    </li>
                </ul>

                <!-- Search bar -->
                <form class="d-flex me-3 sr-search-form flex-grow-1" style="max-width: 300px;" role="search" action="/" method="get">
                    <div class="input-group flex-nowrap">
                        <input class="form-control text-truncate border-success" type="search" name="query"
                               placeholder="Search for stations..." aria-label="Search" />
                        <button class="btn btn-success flex-shrink-0" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Auth buttons and Language -->
                <div class="d-flex align-items-center gap-2 flex-nowrap">
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-dark btn-sm d-flex align-items-center gap-1 px-3 fw-semibold flex-nowrap" href="/Admin/Dashboard">
                            <i class="bi bi-shield-lock flex-shrink-0"></i>
                            <span class="d-none d-xl-inline text-nowrap">Admin Panel</span>
                        </a>
                    }
                    
                    <!-- Custom Language Dropdown -->
                    <div class="dropdown me-1 d-none d-xl-block">
                        <button class="btn btn-outline-success dropdown-toggle btn-sm d-flex align-items-center gap-1 px-3 text-nowrap" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate flex-shrink-0"></i>
                            <span>Language</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            <li><a class="dropdown-item d-flex align-items-center gap-2" href="javascript:void(0);" onclick="changeLanguage('en')">🇬🇧 English</a></li>
                            <li><a class="dropdown-item d-flex align-items-center gap-2" href="javascript:void(0);" onclick="changeLanguage('vi')">🇻🇳 Tiếng Việt</a></li>
                        </ul>
                    </div>
                    <!-- Hidden Google Translate Element -->
                    <div id="google_translate_element" style="display:none;"></div>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm d-flex align-items-center gap-2 dropdown-toggle sr-user-btn border"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false" style="max-width: 200px;">
                                <div class="sr-avatar flex-shrink-0" style="width:24px; height:24px;">
                                    <i class="bi bi-person-fill" style="font-size: 1rem;"></i>
                                </div>
                                <span class="d-none d-md-inline text-truncate fw-medium" style="max-width: 130px;">@displayName</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person me-2"></i>Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        <i class="bi bi-clock-history me-2"></i>Rental History
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-outline-success btn-sm px-3" asp-controller="Account" asp-action="Login">
                            Log In
                        </a>
                        <a class="btn btn-success btn-sm px-3" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="sr-footer" style="background-color: #1a1a1a; padding: 4rem 0 2rem;">
        <div class="container">
            <div class="row align-items-start">
                <!-- Column 1: Brand -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <div class="d-flex align-items-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                             stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                            <circle cx="5.5" cy="17.5" r="3.5"/>
                            <circle cx="18.5" cy="17.5" r="3.5"/>
                            <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                        </svg>
                        <span class="fs-5 fw-bold text-white">SaigonRide</span>
                    </div>
                    <p class="text-white-50 small" style="line-height: 1.6;">
                        Providing smart, genuine household and mobility solutions with the best value in the market.
                    </p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-white bg-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white bg-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white bg-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>

                <!-- Column 2: Discover -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0 text-md-start">
                    <h6 class="fw-bold mb-3" style="color: #16a34a;">Discover</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/">Home</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/#station-search">Best Products</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/Home/Guide">Hot Promos</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/">Track Order</a></li>
                    </ul>
                </div>

                <!-- Column 3: Support -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0 text-md-start">
                    <h6 class="fw-bold mb-3" style="color: #16a34a;">Support</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/Home/Privacy">Help Center</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/Home/Privacy">Warranty Policy</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/Home/Privacy">Return Policy</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none small" href="/Home/Privacy">Privacy Policy</a></li>
                    </ul>
                </div>

                <!-- Column 4: Contact -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0 text-md-start">
                    <h6 class="fw-bold mb-3" style="color: #16a34a;">Contact Us</h6>
                    <ul class="list-unstyled small text-white-50">
                        <li class="mb-3 d-flex align-items-start">
                            <i class="bi bi-geo-alt me-2 mt-1" style="color: #16a34a;"></i>
                            <span>Millenium Apartment 306F, District 4, Ho Chi Minh City</span>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <i class="bi bi-telephone me-2" style="color: #16a34a;"></i>
                            <span>0932 013 424</span>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <i class="bi bi-envelope me-2" style="color: #16a34a;"></i>
                            <span>tt3145539@gmail.com</span>
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="my-4 border-secondary" />
            <div class="text-center text-white-50 small pb-0">
                &copy; 2026 SaigonRide. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Premium Expandable FAB Menu -->
    <div class="fab-wrapper">
        <input type="checkbox" id="fab-checkbox" class="fab-checkbox d-none" />
        <label class="fab-btn shadow-lg pulse-animation" for="fab-checkbox">
            <i class="bi bi-chat-dots-fill fab-icon-main"></i>
            <i class="bi bi-x-lg fab-icon-close"></i>
        </label>
        
        <div class="fab-menu">
            <!-- Item 1: Facebook -->
            <div class="fab-item-container">
                <span class="fab-item-label">Messenger</span>
                <a href="#" class="btn rounded-circle shadow-sm fab-item text-white" style="background-color: #0084FF;" title="Facebook">
                    <i class="bi bi-messenger"></i>
                </a>
            </div>

            <!-- Item 2: Instagram -->
            <div class="fab-item-container">
                <span class="fab-item-label">Instagram</span>
                <a href="#" class="btn rounded-circle shadow-sm fab-item text-white" style="background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%,#d6249f 60%,#285AEB 90%);" title="Instagram">
                    <i class="bi bi-instagram"></i>
                </a>
            </div>

            <!-- Item 3: Hotline/Call -->
            <div class="fab-item-container">
                <span class="fab-item-label">Gọi Hotline</span>
                <a href="tel:0932013424" class="btn rounded-circle shadow-sm fab-item bg-success text-white" title="Call Us">
                    <i class="bi bi-telephone-fill"></i>
                </a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Google Translate Script -->
    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'en,vi',
                autoDisplay: false
            }, 'google_translate_element');
        }

        function changeLanguage(langCode) {
            // Set cookie for Google Translate
            document.cookie = `googtrans=/en/${langCode}; path=/`;
            document.cookie = `googtrans=/en/${langCode}; domain=.${location.hostname}; path=/`;
            window.location.reload();
        }
    </script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
