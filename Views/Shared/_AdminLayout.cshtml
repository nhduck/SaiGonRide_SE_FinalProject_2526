@using Microsoft.AspNetCore.Identity
@inject SignInManager<RentalVehicleService.Models.ApplicationUser> SignInManager
@inject UserManager<RentalVehicleService.Models.ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var appUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var displayName = appUser?.FullName ?? User.Identity?.Name ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - SaigonRide Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <!-- SIDEBAR -->
        <aside class="sr-sidebar" id="adminSidebar">
            <!-- Brand -->
            <div class="sr-sidebar-brand">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                     stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="5.5" cy="17.5" r="3.5"/>
                    <circle cx="18.5" cy="17.5" r="3.5"/>
                    <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                </svg>
                <span class="fw-bold fs-5">SaigonRide</span>
            </div>

            <!-- Navigation -->
            <nav class="sr-sidebar-nav">
                <a href="/Admin/Dashboard"
                   class="sr-sidebar-link @(currentController == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/Stations"
                   class="sr-sidebar-link @(currentController == "Stations" ? "active" : "")">
                    <i class="bi bi-geo-alt"></i>
                    <span>Manage Stations</span>
                </a>
                <a href="/Admin/Vehicles"
                   class="sr-sidebar-link @(currentController == "Vehicles" ? "active" : "")">
                    <i class="bi bi-bicycle"></i>
                    <span>Manage Vehicles</span>
                </a>
                <a href="/Admin/Users"
                   class="sr-sidebar-link @(currentController == "Users" ? "active" : "")">
                    <i class="bi bi-people"></i>
                    <span>Users</span>
                </a>
                <a href="/Admin/Reports"
                   class="sr-sidebar-link @(currentController == "Reports" ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Reports</span>
                </a>
                <a href="/Admin/Payments"
                   class="sr-sidebar-link @(currentController == "Payments" ? "active" : "")">
                    <i class="bi bi-credit-card"></i>
                    <span>Payments</span>
                </a>

                <hr class="sr-sidebar-divider" />

                <a href="/" class="sr-sidebar-link">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Return to Home</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN AREA -->
        <div class="sr-admin-main">
            <!-- Top bar -->
            <header class="sr-admin-topbar">
                <!-- Mobile toggle -->
                <button class="btn btn-light d-lg-none me-3" type="button" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-5"></i>
                </button>

                <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>

                <div class="ms-auto d-flex align-items-center">
                    <!-- Notifications -->
                    <button class="btn btn-light position-relative me-3" type="button">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                            3
                        </span>
                    </button>

                    <!-- Admin dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center gap-2 dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="sr-avatar sr-avatar-sm">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span class="d-none d-md-inline small">
                                @displayName
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-gear me-2"></i>Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <div class="sr-admin-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('show');
        }
        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(e) {
            const sidebar = document.getElementById('adminSidebar');
            const toggler = e.target.closest('[onclick="toggleSidebar()"]');
            if (!toggler && sidebar.classList.contains('show') && !sidebar.contains(e.target)) {
                sidebar.classList.remove('show');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
