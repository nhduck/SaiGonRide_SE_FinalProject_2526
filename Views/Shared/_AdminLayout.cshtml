@using Microsoft.AspNetCore.Identity
@inject SignInManager<RentalVehicleService.Models.ApplicationUser> SignInManager
@inject UserManager<RentalVehicleService.Models.ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var appUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var displayName = appUser?.FullName ?? User.Identity?.Name ?? "Admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - SaigonRide Admin</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <script>
        (function() {
            const savedTheme = localStorage.getItem('sr-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar Navigation -->
        <aside class="sr-sidebar" id="adminSidebar">
            <!-- Brand -->
            <div class="sr-sidebar-brand">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
                     stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="5.5" cy="17.5" r="3.5"/>
                    <circle cx="18.5" cy="17.5" r="3.5"/>
                    <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                </svg>
                <span class="fw-bold fs-5">SaigonRide</span>
            </div>

            <!-- Navigation -->
            <nav class="sr-sidebar-nav">
                <a href="#" data-url="/AdminDashboard/Dashboard" class="sr-sidebar-link active nav-ajax-link">
                    <i class="bi bi-speedometer2"></i>
                    <span data-i18n="admin_dashboard">Dashboard</span>
                </a>
                <a href="#" data-url="/Stations/Index" class="sr-sidebar-link nav-ajax-link">
                    <i class="bi bi-geo-alt"></i>
                    <span data-i18n="admin_stations">Manage Stations</span>
                </a>
                <a href="#" data-url="/Vehicles/Index" class="sr-sidebar-link nav-ajax-link">
                    <i class="bi bi-bicycle"></i>
                    <span data-i18n="admin_vehicles">Manage Vehicles</span>
                </a>
                <a href="#" data-url="/UserManagements/Index" class="sr-sidebar-link nav-ajax-link">
                    <i class="bi bi-people"></i>
                    <span data-i18n="admin_users">Users</span>
                </a>
                <a href="#" data-url="/AdminDashboard/Reports" class="sr-sidebar-link nav-ajax-link">
                    <i class="bi bi-flag"></i>
                    <span data-i18n="admin_reports">Reports</span>
                </a>

                <div class="mt-auto w-100">
                    <hr class="sr-sidebar-divider" />
                    <a href="/" class="sr-sidebar-link text-danger">
                        <i class="bi bi-box-arrow-left"></i>
                        <span data-i18n="admin_return_home">Return to Home</span>
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <div class="sr-admin-main">
            <!-- Top bar -->
            <header class="sr-admin-topbar">
                <!-- Mobile toggle -->
                <button class="btn btn-light d-lg-none me-3" type="button" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-5"></i>
                </button>

                <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>

                <div class="ms-auto d-flex align-items-center gap-1 gap-md-2">
                    <!-- Language Switcher -->
                    <div class="dropdown d-none d-sm-block">
                        <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-1"
                                type="button" id="adminLangDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate text-success"></i><span class="d-none d-md-inline small">English</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            <li><a class="dropdown-item sr-lang-item d-flex align-items-center gap-2" href="javascript:void(0);" data-lang="en" onclick="changeLanguage('en')">🇬🇧 English</a></li>
                            <li><a class="dropdown-item sr-lang-item d-flex align-items-center gap-2" href="javascript:void(0);" data-lang="vi" onclick="changeLanguage('vi')">🇻🇳 Tiếng Việt</a></li>
                        </ul>
                    </div>

                    <button class="btn btn-light d-none d-sm-flex align-items-center justify-content-center"
                            id="themeToggle" type="button" title="Toggle Theme">
                        <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                    </button>

                    <!-- Notifications -->
                    <div class="dropdown">
                        <button class="btn btn-light position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" onclick="loadNotifications()">
                            <i class="bi bi-bell"></i>
                            <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.6rem;">
                                0
                            </span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-sm p-0" style="width: 320px; border-radius: 0.5rem; overflow: hidden;">
                            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                                <h6 class="mb-0 fw-bold fs-6" data-i18n="admin_notifications">Notifications</h6>
                                <span id="notifStatusBadge" class="badge bg-success rounded-pill px-2 py-1 d-none" style="font-size: 0.7rem;">0 new</span>
                            </div>
                            <div id="notifList" class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                                <div class="p-4 text-center text-muted small">
                                    <div class="spinner-border spinner-border-sm text-success mb-2" role="status"></div>
                                    <div data-i18n="admin_loading">Loading...</div>
                                </div>
                            </div>
                            <div class="p-2 border-top bg-light text-center">
                                <a href="javascript:void(0)" onclick="loadPage('/AdminDashboard/Notifications')" class="text-decoration-none small text-success fw-semibold" data-i18n="admin_view_all_notifications">View All Notifications</a>
                            </div>
                        </div>
                    </div>

                    <!-- Admin dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center gap-2 dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="sr-avatar sr-avatar-sm">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span class="d-none d-md-inline small">
                                @displayName
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-gear me-2"></i><span data-i18n="admin_settings">Settings</span>
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i><span data-i18n="nav_logout">Logout</span>
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <div class="sr-admin-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('show');
        }
        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(e) {
            const sidebar = document.getElementById('adminSidebar');
            const toggler = e.target.closest('[onclick="toggleSidebar()"]');
            if (!toggler && sidebar.classList.contains('show') && !sidebar.contains(e.target)) {
                sidebar.classList.remove('show');
            }
        });

        // AJAX Navigation logic
        function loadPage(url) {
            if (!url || url === '#') return;

            $('.modal').modal('hide');
            $('body').removeClass('modal-open');
            $('.modal-backdrop').remove();

            $('#main').html('<div class="h1 p-4 text-center align-self-center"><span>Loading...</span></div>');

            $('#main').load(url, function (response, status, xhr) {
                if (status === 'error') {
                    $('#main').html('<div class="h1 p-4 text-center align-self-center text-danger">Error ' + xhr.status + ': Page not found</div>');
                } else {
                    // Apply i18n to newly loaded content
                    if (window.changeLanguage && window.getCurrentLang) {
                        window.changeLanguage(window.getCurrentLang());
                    }
                }
            });
        }

        function loadNotifications() {
            $.get('/AdminDashboard/GetNotifications', function (data) {
                const list = $('#notifList');
                list.empty();
                
                if (data && data.length > 0) {
                    $('#notifBadge').text(data.length).removeClass('d-none');
                    $('#notifStatusBadge').text(data.length + ' new').removeClass('d-none');
                    
                    data.forEach(item => {
                        const timeStr = new Date(item.time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                        const title = window.getI18nText ? window.getI18nText(item.titleKey) : item.titleKey;
                        let desc = window.getI18nText ? window.getI18nText(item.descriptionKey) : item.descriptionKey;
                        
                        // Replace placeholders if any
                        desc = desc.replace('{0}', '<strong>' + item.param1 + '</strong>').replace('{1}', '<strong>' + item.param2 + '</strong>');

                        const html = `
                            <div class="list-group-item border-bottom-0 px-3 py-3" style="background-color: ${item.type === 'Rental' ? 'rgba(22,163,74,0.05)' : 'rgba(245,158,11,0.05)'};">
                                <div class="d-flex w-100 justify-content-between mb-1">
                                    <span class="fw-semibold" style="font-size: 0.85rem; color:var(--sr-text-heading);">
                                        <i class="bi ${item.icon} text-${item.iconClass.replace('bg-', '')} me-2"></i>
                                        <span>${title}</span>
                                    </span>
                                    <small class="text-muted">${timeStr}</small>
                                </div>
                                <p class="mb-0 text-muted" style="font-size: 0.8rem; line-height: 1.4;">${desc}</p>
                            </div>
                        `;
                        list.append(html);
                    });
                } else {
                    $('#notifBadge').addClass('d-none');
                    $('#notifStatusBadge').addClass('d-none');
                    list.html('<div class="p-4 text-center text-muted small" data-i18n="admin_no_notifications">No new notifications</div>');
                }
            });
        }

        $(document).ready(function () {
            loadNotifications(); // Initial load
            // Polling for notifications every 60 seconds
            setInterval(loadNotifications, 60000);

            $('.nav-ajax-link').click(function (e) {
                e.preventDefault();
                $('.nav-ajax-link').removeClass('active');
                $(this).addClass('active');

                const url = $(this).data('url');
                loadPage(url);

                if (window.innerWidth < 992) {
                    $('#adminSidebar').removeClass('show');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Theme Toggle Logic
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        function updateThemeIcon(theme) {
            if (!themeIcon) return;
            if (theme === 'dark') {
                themeIcon.classList.remove('bi-moon-stars-fill');
                themeIcon.classList.add('bi-sun-fill');
            } else {
                themeIcon.classList.remove('bi-sun-fill');
                themeIcon.classList.add('bi-moon-stars-fill');
            }
        }

        updateThemeIcon(document.documentElement.getAttribute('data-bs-theme'));

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                const currentTheme = document.documentElement.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('sr-theme', newTheme);
                updateThemeIcon(newTheme);
            });
        }
    </script>
</body>
</html>
