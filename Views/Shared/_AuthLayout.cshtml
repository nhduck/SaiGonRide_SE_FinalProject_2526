@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "SaigonRide";
    var metaDesc  = ViewData["MetaDescription"]?.ToString()
                    ?? "SaigonRide – Smart bike & e-scooter rental network across Ho Chi Minh City.";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - SaigonRide</title>
    <meta name="description" content="@metaDesc" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="SaigonRide Team" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LayoutStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bike-animation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/i18n.js"></script>
    <script>
        (function() {
            const savedTheme = localStorage.getItem('sr-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', savedTheme);
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="overflow-x:hidden;">
    <!-- Floating Switchers -->
    <div style="position:fixed; top:20px; right:20px; z-index:1050; display:flex; gap:10px;">
        <button class="btn btn-white shadow-sm rounded-circle p-0 d-flex align-items-center justify-content-center" 
                id="themeToggle" type="button" style="width:38px; height:38px;">
            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
        </button>

        <div class="dropdown">
            <button class="btn btn-white shadow-sm dropdown-toggle rounded-pill px-3 d-flex align-items-center gap-1" type="button" id="langDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" style="height:38px;">
                <span>🇬🇧 English</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4" aria-labelledby="langDropdownBtn">
                <li><a class="dropdown-item sr-lang-item active fw-semibold" href="javascript:void(0)" onclick="changeLanguage('en')" data-lang="en">🇬🇧 English</a></li>
                <li><a class="dropdown-item sr-lang-item" href="javascript:void(0)" onclick="changeLanguage('vi')" data-lang="vi">🇻🇳 Tiếng Việt</a></li>
            </ul>
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        function updateThemeIcon(theme) {
            if (!themeIcon) return;
            if (theme === 'dark') {
                themeIcon.classList.replace('bi-moon-stars-fill', 'bi-sun-fill');
            } else {
                themeIcon.classList.replace('bi-sun-fill', 'bi-moon-stars-fill');
            }
        }

        updateThemeIcon(document.documentElement.getAttribute('data-bs-theme'));

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                const currentTheme = document.documentElement.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('sr-theme', newTheme);
                updateThemeIcon(newTheme);
            });
        }
    </script>
</body>
</html>
