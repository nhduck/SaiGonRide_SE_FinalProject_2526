@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "SaigonRide";
    var metaDesc  = ViewData["MetaDescription"]?.ToString()
                    ?? "SaigonRide – Smart bike & e-scooter rental network across Ho Chi Minh City.";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - SaigonRide</title>
    <meta name="description" content="@metaDesc" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="SaigonRide Team" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LayoutStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bike-animation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RentalVehicleService.styles.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/i18n.js"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="overflow-x:hidden;">
    <!-- Floating Language Switcher -->
    <div style="position:fixed; top:20px; right:20px; z-index:1050;">
        <div class="dropdown">
            <button class="btn btn-white shadow-sm dropdown-toggle rounded-pill px-3" type="button" id="langDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" style="background: white; border: 1px solid #e2e8f0;">
                <span>🇬🇧 English</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4" aria-labelledby="langDropdownBtn">
                <li><a class="dropdown-item sr-lang-item active fw-semibold" href="javascript:void(0)" onclick="changeLanguage('en')" data-lang="en">🇬🇧 English</a></li>
                <li><a class="dropdown-item sr-lang-item" href="javascript:void(0)" onclick="changeLanguage('vi')" data-lang="vi">🇻🇳 Tiếng Việt</a></li>
            </ul>
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
