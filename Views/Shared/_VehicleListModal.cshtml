@model IEnumerable<RentalVehicleService.Models.Vehicle>
@using RentalVehicleService.Models

<div class="modal-header sr-modal-header border-0 pb-0">
    <div>
        <h5 class="modal-title fw-bold" id="vehicleModalLabel">
            Chọn xe để bắt đầu
        </h5>
        <small class="text-muted">Danh sách xe đang có sẵn tại trạm.</small>
    </div>
    <button type="button" class="btn-close sr-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body px-4">
    @if (!Model.Any())
    {
        <div class="text-center py-4">
            <i class="fa-solid fa-bicycle text-muted fs-1 mb-2 opacity-50"></i>
            <p class="text-muted mb-0">Rất tiếc, loại xe này tại trạm đang tạm hết.</p>
        </div>
    }
    else
    {
        <div class="list-group list-group-flush gap-2">
            @foreach (var vehicle in Model)
            {
                <div class="list-group-item sr-info-card border rounded-3 d-flex justify-content-between align-items-center p-3">
                    <div class="d-flex align-items-center">
                        <div class="sr-icon-wrapper @(vehicle.Type == VehicleType.Electric ? "bg-light-blue text-primary" : "bg-light-green text-success") me-3">
                            <i class="fa-solid @(vehicle.Type == VehicleType.Electric ? "fa-bolt" : "fa-bicycle")"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Mã số: #@vehicle.VehicleId</h6>
                            @if (vehicle.Type == VehicleType.Electric)
                            {
                                <small class="text-muted"><i class="fa-solid fa-battery-three-quarters text-success me-1"></i> Pin: Sẵn sàng</small>
                            }
                            else
                            {
                                <small class="text-muted"><i class="fa-solid fa-check text-success me-1"></i> Trạng thái tốt</small>
                            }
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>

<div class="modal-footer border-0 px-4 pb-4 d-flex justify-content-start">
    <button type="button" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-sm d-flex align-items-center btn-open-scanner" data-station-id="@ViewBag.StationId">
        <i class="bi bi-qr-code-scan fs-5 me-2"></i> Quét mã để thuê
    </button>
</div>