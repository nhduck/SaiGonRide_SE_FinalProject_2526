@{
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
	ViewData["Title"] = "Admin Dashboard";
}

<div id="main" class="container-fluid p-4 min-vh-100 bg-light">
    <!-- Default initial content load (e.g. Dashboard view) -->
    <div class="h1 text-center align-self-center mt-5 text-muted">
        <i class="bi bi-arrow-clockwise me-2" style="display:inline-block; animation: spin 1s linear infinite;"></i>
        <span data-i18n="admin_loading">Loading...</span>
    </div>
</div>

<style>
    @@keyframes spin { 100% { transform: rotate(360deg); } }
</style>

@section Scripts {
	<script>
		$(document).ready(function () {
			// Initially load the first active tab (e.g., Dashboard or Stations)
            // By default, maybe load Stations since we don't have a Dashboard/Index yet
			loadPage('/Stations/Index');
            
            // Mark the stations link as active initially
            $('.nav-ajax-link').removeClass('active');
            $('[data-url="/Stations/Index"]').addClass('active');
		});
	</script>
}