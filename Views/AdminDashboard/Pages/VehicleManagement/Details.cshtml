@model RentalVehicleService.Models.Vehicle

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Vehicle</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.VehicleModel)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.VehicleModel)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BatteryPercentage)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BatteryPercentage)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.State)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.State)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CurrentStationId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CurrentStationId)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.VehicleId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

<div class="card border-0 shadow-sm text-center sr-reveal" style="max-width: 300px; border-radius: 1.5rem; background: #f8fafc; border: 2px dashed #16a34a !important; margin: 2rem auto;">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-1" style="color: #064e3b;">
            <i class="bi bi-bicycle me-1"></i> SaigonRide
        </h5>
        <p class="text-muted small mb-3">Quét mã để mở khóa hành trình</p>

        <div class="bg-white p-2 rounded-3 shadow-sm mx-auto mb-3" style="width: fit-content;">
            <div id="qrcode-container"></div>
        </div>

        <div class="fw-bold fs-3" style="letter-spacing: 2px; color: #0f172a;">
            #@Model.VehicleId
        </div>
        <div class="badge mt-2 px-3 py-2" style="background: rgba(22, 163, 74, 0.1); color: #16a34a;">
            @Model.Type
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script>
        $(document).ready(function () {
            var currentDomain = window.location.origin;
            var unlockUrl = currentDomain + "/Rental/Create?vehicleId=@Model.VehicleId";
            var qrContainer = document.getElementById("qrcode-container");
            if (qrContainer) {
                new QRCode(qrContainer, {
                    text: unlockUrl,
                    width: 160,
                    height: 160,
                    colorDark : "#064e3b",
                    colorLight : "#ffffff",
                    correctLevel : QRCode.CorrectLevel.H
                });
            }
        });
    </script>
}