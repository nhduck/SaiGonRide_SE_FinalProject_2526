@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Configure Station";
}

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold"><i class="bi bi-pencil-square text-primary me-2"></i>Configure Station</h1>
            <p class="text-muted mb-0">Update information and adjust capacity for <strong>@Model.Name</strong></p>
        </div>
        <button onclick="loadPage('/Stations/Index')" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm hover-lift">
            <i class="bi bi-arrow-left me-2"></i>Back to List
        </button>
    </div>

    <div class="row g-4">
        <!-- Form Column -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-primary mb-0"><i class="bi bi-building me-2"></i>Station Details</h5>
                </div>
                <div class="card-body p-4">
                    <form id="stationEditForm">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                        <input type="hidden" asp-for="StationId" />
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control rounded-3" placeholder="Station Name" />
                                    <label asp-for="Name" class="text-muted"><i class="bi bi-tag me-1"></i>Station Name</label>
                                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Address" class="form-control rounded-3" placeholder="Address" />
                                    <label asp-for="Address" class="text-muted"><i class="bi bi-geo-alt me-1"></i>Address location</label>
                                    <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <h6 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Capacity & Status</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="TotalCapacity" class="form-control rounded-3" placeholder="Total Capacity" />
                                    <label asp-for="TotalCapacity" class="text-muted"><i class="bi bi-grid-3x3-gap me-1"></i>Total Capacity</label>
                                    <span asp-validation-for="TotalCapacity" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="CurrentCount" class="form-control rounded-3" placeholder="Current Count" />
                                    <label asp-for="CurrentCount" class="text-muted"><i class="bi bi-bicycle me-1"></i>Current Vehicles Count</label>
                                    <span asp-validation-for="CurrentCount" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4 bg-light p-3 rounded-3 border border-light-subtle d-flex align-items-center shadow-sm">
                            <i class="bi bi-power fs-4 text-primary me-3"></i>
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold">Operational Status</h6>
                                <p class="text-muted mb-0 small">Toggle to enable or disable renting from this station.</p>
                            </div>
                            <div class="form-check form-switch fs-4 mb-0">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="editStatusSwitch">
                            </div>
                        </div>

                        <input type="hidden" asp-for="Latitude" id="editLatitude" />
                        <input type="hidden" asp-for="Longitude" id="editLongitude" />

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex justify-content-end gap-3">
                            <button type="button" class="btn btn-light px-4 rounded-pill fw-medium border hover-lift" onclick="loadPage('/Stations/Index')">Cancel</button>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-medium hover-lift">
                                <i class="bi bi-check2-circle me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Map Column -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-map">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h6 class="fw-bold text-secondary mb-1 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                        <i class="bi bi-map me-1"></i>Location Coordinates
                    </h6>
                    <p class="text-muted small mb-0"><i class="bi bi-info-circle me-1"></i>Click on the map or drag the pin to update the station's coordinates.</p>
                </div>
                <div class="card-body p-3">
                    <div class="border border-primary border-opacity-25 rounded-3 overflow-hidden shadow-sm">
                        <div id="editMap" style="height: 400px; z-index: 1;"></div>
                    </div>
                    <div class="d-flex text-muted fw-medium small mt-3 p-2 bg-light rounded-3">
                        <div class="me-4"><i class="bi bi-geo-alt-fill text-danger me-1"></i>Lat: <span id="editLatDisplay" class="fw-bold">@Model.Latitude</span></div>
                        <div><i class="bi bi-compass text-primary me-1"></i>Lng: <span id="editLngDisplay" class="fw-bold">@Model.Longitude</span></div>
                    </div>
                    <!-- Search box for location -->
                    <div class="mt-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" id="editMapSearch" class="form-control" placeholder="Search for a location...">
                            <button class="btn btn-outline-primary" type="button" id="editMapSearchBtn">
                                <i class="bi bi-geo"></i> Find
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
    .form-floating > label {
        padding-left: 1.25rem;
    }
    .form-control {
        border: 1px solid #e2e8f0;
    }
    .hover-lift {
        transition: transform 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .sticky-map {
        position: sticky;
        top: 20px;
    }
</style>

<script>
    // Load Leaflet dynamically if not already loaded
    function loadLeaflet(callback) {
        if (window.L) { callback(); return; }
        
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);
        
        var script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.onload = callback;
        document.head.appendChild(script);
    }

    loadLeaflet(function() {
        var currentLat = @Model.Latitude;
        var currentLng = @Model.Longitude;
        
        // If coordinates are exactly 0,0, default to Saigon
        if (currentLat === 0 && currentLng === 0) {
            currentLat = 10.7769;
            currentLng = 106.7009;
        }

        var map = L.map('editMap').setView([currentLat, currentLng], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var marker = L.marker([currentLat, currentLng], {draggable: true}).addTo(map);

        function updateEditInputs(lat, lng) {
            document.getElementById('editLatitude').value = lat;
            document.getElementById('editLongitude').value = lng;
            document.getElementById('editLatDisplay').innerText = lat.toFixed(5);
            document.getElementById('editLngDisplay').innerText = lng.toFixed(5);
        }

        marker.on('dragend', function (e) {
            var coords = marker.getLatLng();
            updateEditInputs(coords.lat, coords.lng);
        });

        map.on('click', function (e) {
            marker.setLatLng(e.latlng);
            updateEditInputs(e.latlng.lat, e.latlng.lng);
        });

        // Map search using Nominatim (OpenStreetMap geocoding)
        document.getElementById('editMapSearchBtn').addEventListener('click', function() {
            var query = document.getElementById('editMapSearch').value;
            if (!query) return;
            
            fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(query))
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data && data.length > 0) {
                        var lat = parseFloat(data[0].lat);
                        var lng = parseFloat(data[0].lon);
                        map.setView([lat, lng], 16);
                        marker.setLatLng([lat, lng]);
                        updateEditInputs(lat, lng);
                    } else {
                        alert('Location not found. Try a different search term.');
                    }
                });
        });

        document.getElementById('editMapSearch').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('editMapSearchBtn').click();
            }
        });

        // Fix map rendering when loaded via AJAX
        setTimeout(function() { map.invalidateSize(); }, 200);
    });

    // AJAX form submission
    $('#stationEditForm').on('submit', function(e) {
        e.preventDefault();
        
        var formData = $(this).serialize();
        var stationId = $('input[name="StationId"]').val();
        
        $.ajax({
            url: '/Stations/Edit/' + stationId,
            type: 'POST',
            data: formData,
            success: function(response) {
                if (typeof response === 'object' && response.success) {
                    loadPage('/Stations/Index');
                } else {
                    $('#main').html(response);
                }
            },
            error: function(xhr) {
                console.error("Error updating station:", xhr.statusText);
                alert("An error occurred. Please try again.");
            }
        });
    });
</script>
