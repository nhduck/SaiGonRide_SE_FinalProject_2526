@model IEnumerable<RentalVehicleService.Models.Station>

@{
	ViewData["Title"] = "Manage Stations";
}

<div class="m-3">
	<div class="container-fluid py-4 px-lg-5">
		<!-- Header -->
		<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
			<div>
				<h4 class="fw-bold mb-1"><i class="bi bi-geo-alt-fill text-success me-2"></i><span data-i18n="admin_station_management">Station Management</span></h4>
				<p class="text-muted small mb-0" data-i18n="admin_station_management_subtitle">Manage all rental stations in the network</p>
			</div>
			<button class="btn btn-success shadow-sm flex-shrink-0" onclick="loadPage('/Stations/Create')">
				<i class="bi bi-plus-lg me-1"></i> <span data-i18n="admin_add_station">Add Station</span>
			</button>
		</div>

		<!-- Stat Cards -->
		<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3 mb-5">
			<div class="col">
				<div class="card border-0 shadow-sm stat-card border-start border-primary border-4 h-100">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="text-muted small fw-bold text-uppercase" data-i18n="admin_total_stations">Total Stations</div>
								<div id="totalStationCount" class="h3 fw-bold text-primary mb-0">@ViewBag.TotalStations</div>
							</div>
							<div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
								<i class="bi bi-geo-alt text-primary fs-5"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col">
				<div class="card border-0 shadow-sm stat-card border-start border-success border-4 h-100">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="text-muted small fw-bold text-uppercase" data-i18n="admin_active">Active</div>
								<div id="activeCount" class="h3 fw-bold text-success mb-0">@ViewBag.Active</div>
							</div>
							<div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
								<i class="bi bi-check-circle text-success fs-5"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col">
				<div class="card border-0 shadow-sm stat-card border-start border-warning border-4 h-100">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="text-muted small fw-bold text-uppercase" data-i18n="admin_low_stock">Low Stock</div>
								<div id="lowStockCount" class="h3 fw-bold text-warning mb-0">@ViewBag.LowStock</div>
							</div>
							<div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
								<i class="bi bi-exclamation-triangle text-warning fs-5"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col">
				<div class="card border-0 shadow-sm stat-card border-start border-danger border-4 h-100">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center">
							<div>
								<div class="text-muted small fw-bold text-uppercase" data-i18n="admin_inactive">Inactive</div>
								<div id="inactiveCount" class="h3 fw-bold text-danger mb-0">@ViewBag.Inactive</div>
							</div>
							<div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
								<i class="bi bi-x-circle text-danger fs-5"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Search & Filter Bar -->
		<div class="card border-0 shadow-sm mb-4">
			<div class="card-body">
				<form method="get" class="row g-2">
					<div class="col-lg-4">
						<div class="input-group">
							<span class="input-group-text border-end-0"><i class="bi bi-search text-muted"></i></span>
							<input id="stationSearchBar" type="text" class="form-control border-start-0 ps-0" placeholder="Search by name, address or ID..." data-i18n="[placeholder]admin_search_placeholder">
						</div>
					</div>
					<div class="col-lg-8 d-flex gap-2 flex-wrap justify-content-lg-end">
						<button id="stationClearBTN" class="btn btn-outline-primary d-none">Clear Sort</button>
						<button id="activeBTN" class="stationSortBTN btn btn-outline-success" data-i18n="admin_active">Active</button>
						<button id="lowStockBTN" class="stationSortBTN btn btn-outline-warning" data-i18n="admin_low_stock">Low Stock</button>
						<button id="fullBTN" class="stationSortBTN btn btn-outline-danger" data-i18n="admin_full">Full</button>
						<button id="inactiveBTN" class="stationSortBTN btn btn-outline-secondary" data-i18n="admin_inactive">Inactive</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Table -->
		<div class="card border-0 shadow-sm">
			<div class="table-responsive">
				<div class="scroll-area">
					<table class="table table-hover align-middle mb-0">
						<thead class="sticky-top">
							<tr>
								<th class="ps-4" style="width:50px">#</th>
								<th data-i18n="admin_name">Station Name</th>
								<th data-i18n="admin_address">Address</th>
								<th class="text-center" data-i18n="admin_capacity">Capacity</th>
								<th class="text-center" data-i18n="admin_current">Current</th>
								<th class="text-center" style="width:140px" data-i18n="admin_fill_rate">Fill Rate</th>
								<th class="text-center" data-i18n="admin_inventory">Inventory</th>
								<th class="text-center" data-i18n="admin_status">Status</th>
								<th class="text-center" style="width:140px" data-i18n="admin_actions">Actions</th>
							</tr>
						</thead>
						<tbody id="stationTableBody">
							<partial name="~/Views/AdminDashboard/Pages/Station/_StationTablePartial.cshtml" />
						</tbody>
					</table>
				</div>
			</div>
		</div>

		@if (!Model.Any())
		{
			<div class="text-center py-5">
				<i class="bi bi-geo fs-1 text-muted d-block mb-2"></i>
				<h6 class="text-muted" data-i18n="admin_no_stations">No stations found</h6>
				<button onclick="loadPage('/Stations/Create')" class="btn btn-sm btn-success mt-2" data-i18n="admin_add_station">Add your first station</button>
			</div>
		}
	</div>

	<iframe name="hidden_frame_station" style="display:none;"></iframe>

	<!-- Delete Confirm Modal -->
	<div class="modal fade" id="deleteStationModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header bg-danger text-white">
					<h5 class="modal-title"><i class="bi bi-exclamation-octagon"></i> <span data-i18n="admin_confirm_delete">Confirm Delete</span></h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>

				<div>
					<div class="modal-body text-center py-4">
						<input type="hidden" id="stationIdToConfirm" name="id" />

						<i class="bi bi-trash3 text-danger" style="font-size: 3rem;"></i>
						<h4 class="mt-3" data-i18n="admin_sure">Are you sure?</h4>
						<p class="text-muted">
							You are about to delete station: <br />
							<div>
								Id: <span class="fw-bold" id="stationIdToDisplay"></span>
							</div>
							<div>
								<span data-i18n="admin_name">Name</span>:
								<span class="fw-bold" id="stationNameToDisplay"></span>
							</div>
						</p>
						<small class="text-danger" data-i18n="admin_delete_warning">This action cannot be undone!</small>
					</div>
					<div class="modal-footer justify-content-center">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-i18n="admin_cancel">Cancel</button>
						<button id="confirmDeleteStationBtn" type="button" class="btn btn-danger" data-i18n="admin_yes_delete">Yes, Delete it!</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Warning/Error Modal -->
	<div class="modal fade" id="stationWarningModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content border-0 shadow">
				<div class="modal-header bg-warning text-dark border-0">
					<h5 class="modal-title"><i class="bi bi-shield-exclamation me-2"></i><span data-i18n="admin_cannot_delete_station">Cannot Delete Station</span></h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body text-center py-4">
					<div class="mb-3">
						<div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width:80px;height:80px;">
							<i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 2.5rem;"></i>
						</div>
					</div>
					<h5 class="fw-bold mb-2" data-i18n="admin_deletion_blocked">Deletion Blocked</h5>
					<p id="stationWarningMessage" class="text-muted mb-0 px-3"></p>
				</div>
				<div class="modal-footer justify-content-center border-0 pt-0">
					<button type="button" class="btn btn-warning px-4" data-bs-dismiss="modal" data-i18n="admin_understood">
						<i class="bi bi-check-lg me-1"></i>Understood
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Success Toast -->
	<div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
		<div id="stationSuccessToast" class="toast align-items-center text-bg-success border-0 shadow-lg" role="alert" data-bs-delay="3000">
			<div class="d-flex">
				<div class="toast-body fs-6">
					<i class="bi bi-check-circle-fill me-2"></i>
					<span id="stationSuccessMessage">Station deleted successfully!</span>
				</div>
				<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
			</div>
		</div>
	</div>
</div>

<script>
	// Wrap in IIFE to avoid duplicate declaration errors when reloaded via loadPage()
	(function() {
		// 1. Show Delete Modal (global scope needed for onclick)
		window.prepareDeleteStation = function(id, name) {
			$('#stationIdToConfirm').val(id);
			$('#stationIdToDisplay').text(id);
			$('#stationNameToDisplay').text(name);
			$('#deleteStationModal').modal('show');
		};

		// 2. Update stats
		window.updateStationStats = function() {
			$.ajax({
				url: '/Stations/GetAmountInfo',
				type: 'GET',
				dataType: 'json',
				success: function(data) {
					$("#totalStationCount").text(data.totalStations);
					$("#activeCount").text(data.active);
					$("#lowStockCount").text(data.lowStock);
					$("#inactiveCount").text(data.inactive);
				},
				error: function(xhr) {
					console.error("Error updating stats:", xhr.responseText);
				}
			});
		};

		// Helper: show warning modal
		function showWarning(msg) {
			$('#stationWarningMessage').text(msg);
			$('#stationWarningModal').modal('show');
		}

		// Helper: show success toast
		function showSuccess(msg) {
			$('#stationSuccessMessage').text(msg || 'Station deleted successfully!');
			var toast = new bootstrap.Toast($('#stationSuccessToast')[0]);
			toast.show();
		}

		// 3. AJAX Delete — unbind first to avoid duplicate handlers
		$('#confirmDeleteStationBtn').off('click').on('click', function (e) {
			e.preventDefault();
			var id = $('#stationIdToConfirm').val();
			var token = $('input[name="__RequestVerificationToken"]').val();

			$.ajax({
				url: '/Stations/DeleteConfirmed',
				type: 'POST',
				data: {
					id: id,
					__RequestVerificationToken: token
				},
				success: function(resp) {
					$('#deleteStationModal').modal('hide');
					$('tr[data-id="' + id + '"]').fadeOut(300, function() {
						$(this).remove();
						updateStationStats();
					});
					showSuccess(resp && resp.message ? resp.message : 'Station deleted successfully!');
				},
				error: function(xhr) {
					$('#deleteStationModal').modal('hide');
					var msg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || "Unable to delete station. Please try again.";
					try {
						var resp = JSON.parse(xhr.responseText);
						if (resp.message) msg = resp.message;
					} catch(ex) {}
					// Small delay to let delete modal fully close before opening warning
					setTimeout(function() { showWarning(msg); }, 300);
				}
			});
		});

		// 4. Search & Filter
		var selectedStationStatuses = [];

		$("#stationSearchBar").on("input", function() {
			searchStations();
		});

		$('.stationSortBTN').on("click", function(e) {
			e.preventDefault();
			var status = $(this).text().trim();
			$(this).toggleClass('active-selected');
			toggleStationStatus(status);

			if (selectedStationStatuses.length > 1) {
				$('#stationClearBTN').removeClass('d-none');
			} else {
				$('#stationClearBTN').addClass('d-none');
			}
			if (selectedStationStatuses.length === 4) {
				clearStationSort(e);
			}
		});

		$('#stationClearBTN').on('click', function(e) {
			clearStationSort(e);
		});

		function clearStationSort(e) {
			e.preventDefault();
			selectedStationStatuses = [];
			$('.stationSortBTN').removeClass('active-selected');
			$('#stationClearBTN').addClass('d-none');
			searchStations();
		}

		function toggleStationStatus(statusName) {
			var index = selectedStationStatuses.indexOf(statusName);
			if (index > -1) {
				selectedStationStatuses.splice(index, 1);
			} else {
				selectedStationStatuses.push(statusName);
			}
			searchStations();
		}

		function searchStations() {
			var keyword = $("#stationSearchBar").val();

			$.ajax({
				url: '/Stations/SearchStations',
				type: 'GET',
				data: {
					searchTerm: keyword,
					statuses: selectedStationStatuses
				},
				traditional: true,
				success: function(response) {
					$('#stationTableBody').html(response);
					updateStationStats();
				}
			});
		}
	})();
</script>

<link rel="stylesheet" href="~/css/Station/indexStyle.css" />