@using RentalVehicleService.Models.ViewModels
@model RentalVehicleService.Models.ViewModels.UserManagement

<!-- Details User Modal -->
<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="userDetailsModalLabel">
                    <i class="bi bi-person-lines-fill me-2"></i><span data-i18n="admin_user_details">User Details</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body is loaded via AJAX into this container -->
            <div class="modal-body py-4" id="userDetailsModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted" data-i18n="admin_loading">Loading...</p>
                </div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i><span data-i18n="admin_close">Close</span>
                </button>
                <button type="button" class="btn btn-primary" id="userDetailsEditBtn">
                    <i class="bi bi-pencil me-1"></i><span data-i18n="admin_edit">Edit</span>
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    (function ($) {

        // ════════════════════════════════════════════════════════
        // MODAL DETAILS
        // ════════════════════════════════════════════════════════

        window.ShowUserDetailsModal = function (userId) {
            const loadingText = (window.getI18nText && window.getI18nText('admin_loading')) || 'Loading...';
            $('#userDetailsModalBody').html(
                '<div class="text-center py-4">' +
                '  <div class="spinner-border text-primary" role="status"></div>' +
                '  <p class="mt-2 text-muted">' + loadingText + '</p>' +
                '</div>'
            );

            $('#userDetailsEditBtn').data('id', userId);
            $('#userDetailsModal').modal('show');

            $.ajax({
                url: '/Admin/UserManagements/Details/' + userId,
                type: 'GET',
                success: function (html) {
                    $('#userDetailsModalBody').html(html);
                },
                error: function () {
                    const errorMsg = (window.getI18nText && window.getI18nText('admin_details_error')) || 'Cannot load user details. Please try again.';
                    $('#userDetailsModalBody').html(
                        '<div class="alert alert-danger">' + errorMsg + '</div>'
                    );
                }
            });
        };

        $('#userDetailsEditBtn').on('click', function () {
            var id = $(this).data('id');
            $('#userDetailsModal').modal('hide');
            $('#userDetailsModal').one('hidden.bs.modal', function () {
                if (typeof ShowUserEditModal === 'function') ShowUserEditModal(id);
            });
        });

    })(jQuery);
</script>
