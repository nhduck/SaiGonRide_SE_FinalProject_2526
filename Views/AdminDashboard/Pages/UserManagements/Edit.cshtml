@using RentalVehicleService.Models.ViewModels
@model RentalVehicleService.Models.ViewModels.UserManagement

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title" id="editUserModalLabel">
                    <i class="bi bi-pencil-square me-2"></i><span data-i18n="admin_edit_user">Edit User</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body py-4">
                <div id="editUserAlertArea"></div>

                <form id="editUserForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Hidden ID -->
                    <input type="hidden" id="editUserId" name="Id" />

                    <!-- Section: Account Info -->
                    <p class="text-muted small fw-bold text-uppercase mb-3 border-bottom pb-2">
                        <i class="bi bi-person-badge me-1"></i><span data-i18n="admin_account_info">Account Information</span>
                    </p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><span data-i18n="admin_fullname">Full Name</span> <span class="text-danger">*</span></label>
                            <input type="text" id="editUserFullName" name="FullName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><span data-i18n="admin_username">Username</span> <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">@@</span>
                                <input type="text" id="editUserName" name="UserName" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><span data-i18n="admin_email">Email</span> <span class="text-danger">*</span></label>
                            <input type="email" id="editUserEmail" name="Email" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_phone">Phone Number</label>
                            <input type="text" id="editUserPhone" name="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><span data-i18n="admin_user_type">User Type</span> <span class="text-danger">*</span></label>
                            <select id="editUserType" name="UserType" class="form-select" required>
                                <option value="" data-i18n="admin_select_type">-- Select Type --</option>
                                <option value="Admin">Admin</option>
                                <option value="Staff">Staff</option>
                                <option value="Customer">Customer</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input type="hidden" name="IsLockedOut" value="false" />
                                <input class="form-check-input" type="checkbox" role="switch"
                                       id="editUserIsLockedOut" name="IsLockedOut" value="true" />
                                <label class="form-check-label fw-semibold" for="editUserIsLockedOut">
                                    <i class="bi bi-lock me-1 text-danger"></i><span data-i18n="admin_lock_account">Lock Account</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Identity Documents -->
                    <p class="text-muted small fw-bold text-uppercase mb-3 border-bottom pb-2">
                        <i class="bi bi-card-text me-1"></i><span data-i18n="admin_identity_docs">Identity Documents</span>
                    </p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" data-i18n="admin_cccd">CCCD / National ID</label>
                            <input type="text" id="editUserCCCD" name="CCCD" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" data-i18n="admin_passport">Passport Number</label>
                            <input type="text" id="editUserPassport" name="PassportNumber" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold" data-i18n="admin_nationality">Nationality</label>
                            <input type="text" id="editUserNationality" name="Nationality" class="form-control" />
                        </div>
                    </div>

                    <!-- Section: Roles -->
                    <p class="text-muted small fw-bold text-uppercase mb-3 border-bottom pb-2">
                        <i class="bi bi-shield-check me-1"></i><span data-i18n="admin_roles">Roles</span>
                    </p>

                    <div id="editUserRolesContainer" class="d-flex gap-3 flex-wrap mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Roles" value="Admin" id="editRoleAdmin" />
                            <label class="form-check-label" for="editRoleAdmin">Admin</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Roles" value="Staff" id="editRoleStaff" />
                            <label class="form-check-label" for="editRoleStaff">Staff</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Roles" value="Customer" id="editRoleCustomer" />
                            <label class="form-check-label" for="editRoleCustomer">Customer</label>
                        </div>
                    </div>

                    <!-- Section: Change Password (optional) -->
                    <p class="text-muted small fw-bold text-uppercase mb-3 border-bottom pb-2 mt-4">
                        <i class="bi bi-key me-1"></i><span data-i18n="admin_change_password">Change Password</span> <span class="fw-normal text-muted" data-i18n="admin_leave_blank_keep">(leave blank to keep current)</span>
                    </p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_new_password">New Password</label>
                            <input type="password" name="NewPassword" class="form-control" placeholder="Min. 8 characters" data-i18n="[placeholder]admin_new_password_placeholder" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_confirm_password">Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control" placeholder="Repeat new password" data-i18n="[placeholder]admin_confirm_password_placeholder" />
                        </div>
                    </div>

                </form>
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i><span data-i18n="admin_cancel">Cancel</span>
                </button>
                <button type="submit" form="editUserForm" class="btn btn-secondary" id="editUserSubmitBtn">
                    <i class="bi bi-floppy me-1"></i><span data-i18n="admin_save_changes">Save Changes</span>
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    (function ($) {
        // EDIT MODAL
        window.ShowUserEditModal = function (userId) {
            $('#editUserAlertArea').html('');
            $('#editUserForm')[0].reset();

            $.ajax({
                url: '/Admin/UserManagements/Edit/' + userId,
                type: 'GET',
                success: function (data) {
                    $('#editUserId').val(data.id);
                    $('#editUserFullName').val(data.fullName);
                    $('#editUserName').val(data.userName);
                    $('#editUserEmail').val(data.email);
                    $('#editUserPhone').val(data.phoneNumber);
                    $('#editUserType').val(data.userType);
                    $('#editUserCCCD').val(data.cccd);
                    $('#editUserPassport').val(data.passportNumber);
                    $('#editUserNationality').val(data.nationality);
                    $('#editUserIsLockedOut').prop('checked', data.isLockedOut);

                    $('#editUserRolesContainer input[type="checkbox"]').prop('checked', false);
                    if (data.roles && data.roles.length > 0) {
                        $.each(data.roles, function (i, role) {
                            $('#editUserRolesContainer input[value="' + role + '"]').prop('checked', true);
                        });
                    }

                    $('#editUserModal').modal('show');
                },
                error: function () {
                    const errorMsg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'Cannot load user data. Please try again.';
                    alert(errorMsg);
                }
            });
        };

        $('#editUserForm').on('submit', function (e) {
            e.preventDefault();
            var userId = $('#editUserId').val();
            var $btn   = $('#editUserSubmitBtn');

            const savingText = (window.getI18nText && window.getI18nText('admin_saving')) || 'Saving...';
            $btn.prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm me-1"></span>' + savingText);

            $.ajax({
                url: '/Admin/UserManagements/Edit/' + userId,
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    $('#editUserModal').modal('hide');
                    if (typeof userSearch === 'function') userSearch();
                },
                error: function (xhr) {
                    var msg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'An error occurred. Please try again.';
                    try {
                        var res = JSON.parse(xhr.responseText);
                        if (res.errors) msg = res.errors.join('<br>');
                    } catch (ex) {}

                    $('#editUserAlertArea').html(
                        '<div class="alert alert-danger alert-dismissible fade show py-2 small">' +
                        '  <i class="bi bi-exclamation-triangle me-1"></i>' + msg +
                        '  <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>' +
                        '</div>'
                    );
                },
                complete: function () {
                    const saveText = (window.getI18nText && window.getI18nText('admin_save_changes')) || 'Save Changes';
                    $btn.prop('disabled', false)
                        .html('<i class="bi bi-floppy me-1"></i>' + saveText);
                }
            });
        });

    })(jQuery);
</script>
