@using RentalVehicleService.Models.ViewModels
@model IEnumerable<RentalVehicleService.Models.ViewModels.UserManagement>

@{
    ViewData["Title"] = "User Management";
}

<div class="m-3">
    <div class="container-fluid py-4 px-lg-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-people-fill"></i> <span data-i18n="admin_user_management">User Management</span></h4>
                <p class="text-muted small mb-0" data-i18n="admin_user_management_subtitle">Manage all registered users in the system</p>
            </div>
            <button class="btn btn-success" id="openCreateUserBtn">
                <i class="bi bi-person-plus-fill"></i> <span data-i18n="admin_add_user">Add User</span>
            </button>
        </div>

        <!-- Stats -->
        <div class="row row-cols-1 row-cols-md-3 g-3 mb-5">
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-primary border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_total_users">Total Users</div>
                                <div id="totalUserCount" class="h3 fw-bold text-primary mb-0">@ViewBag.TotalUsers</div>
                            </div>
                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-people-fill text-primary fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-success border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_active">Active</div>
                                <div id="activeUserCount" class="h3 fw-bold text-success mb-0">@ViewBag.ActiveUsers</div>
                            </div>
                            <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-check-circle text-success fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-danger border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_locked">Locked Out</div>
                                <div id="lockedUserCount" class="h3 fw-bold text-danger mb-0">@ViewBag.LockedUsers</div>
                            </div>
                            <div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-lock-fill text-danger fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-warning border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_admins">Admins</div>
                                <div id="adminUserCount" class="h3 fw-bold text-warning mb-0">@ViewBag.Admins</div>
                            </div>
                            <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-shield-check text-warning fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-info border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_customers">Customers</div>
                                <div id="customerUserCount" class="h3 fw-bold text-info mb-0">@ViewBag.Customers</div>
                            </div>
                            <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-person-badge text-info fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-purple border-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_staff">Staff</div>
                                <div id="staffUserCount" class="h3 fw-bold text-purple mb-0">@ViewBag.Staff</div>
                            </div>
                            <div class="bg-purple bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:45px;height:45px;">
                                <i class="bi bi-briefcase text-purple fs-5"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-2">
                    <div class="col-lg-4">
                        <div class="input-group">
                            <span class="input-group-text border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input id="userSearchBar" type="text" name="searchString"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Search by name, email or ID..." data-i18n="[placeholder]admin_search_placeholder">
                        </div>
                    </div>
                    <div class="col-lg-8 d-flex gap-2 flex-wrap justify-content-lg-end">
                        <button id="userClearBTN" class="btn btn-outline-primary d-none" data-i18n="admin_clear_sort">Clear Sort</button>
                        <button id="activeBTN" class="userSortBTN btn btn-outline-success" data-filter="Active" data-i18n="admin_active">Active</button>
                        <button id="lockedBTN" class="userSortBTN btn btn-outline-danger" data-filter="Locked" data-i18n="admin_locked">Locked</button>
                        <button id="adminBTN" class="userSortBTN btn btn-outline-warning" data-filter="Admin" data-i18n="admin_admins">Admin</button>
                        <button id="customerBTN" class="userSortBTN btn btn-outline-info" data-filter="Customer" data-i18n="admin_customers">Customer</button>
                        <button id="staffBTN" class="userSortBTN btn btn-outline-purple" data-filter="Staff" data-i18n="admin_staff">Staff</button>
                    </div>
                </form>
            </div>
        </div>
 
        <!-- Table -->
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <div class="scroll-area">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="sticky-top">
                            <tr>
                                <th class="ps-4" data-i18n="admin_user_id">User ID</th>
                                <th data-i18n="admin_full_name">Full Name</th>
                                <th data-i18n="admin_username">Username</th>
                                <th data-i18n="admin_email">Email</th>
                                <th data-i18n="admin_phone">Phone</th>
                                <th data-i18n="admin_user_type">User Type</th>
                                <th data-i18n="admin_roles">Roles</th>
                                <th data-i18n="admin_status">Status</th>
                                <th class="text-center" data-i18n="admin_actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            <partial name="~/Views/AdminDashboard/Pages/UserManagements/_UserTablePartial.cshtml" />
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <iframe name="hidden_frame" style="display:none;"></iframe>

    <!-- Modals -->
    <partial name="~/Views/AdminDashboard/Pages/UserManagements/Delete.cshtml" />
    <partial name="~/Views/AdminDashboard/Pages/UserManagements/Create.cshtml" model="new RentalVehicleService.Models.ViewModels.UserManagement()" />
    <partial name="~/Views/AdminDashboard/Pages/UserManagements/Edit.cshtml" model="new RentalVehicleService.Models.ViewModels.UserManagement()" />
    <partial name="~/Views/AdminDashboard/Pages/UserManagements/Details.cshtml" model="new RentalVehicleService.Models.ViewModels.UserManagement()" />

</div>

<script>
    (function ($) {

        // STATISTICS - shared across modals via window.updateUserStats

        window.updateUserStats = function () {
            $.ajax({
                url: '/Admin/UserManagements/GetAmountInfo',
                type: 'GET',
                success: function (data) {
                    $('#totalUserCount').text(data.totalUsers);
                    $('#activeUserCount').text(data.activeUsers);
                    $('#lockedUserCount').text(data.lockedUsers);
                    $('#adminUserCount').text(data.admins);
                    $('#customerUserCount').text(data.customers);
                    $('#staffUserCount').text(data.staff);
                }
            });
        };


        // SEARCH & FILTER - shared across modals via window.userSearch

        var selectedUserFilters = [];

        window.userSearch = function () {
            $.ajax({
                url: '/Admin/UserManagements/SearchUsers',
                type: 'GET',
                data: { searchTerm: $('#userSearchBar').val(), filters: selectedUserFilters },
                traditional: true,
                success: function (html) {
                    $('#userTableBody').html(html);
                    window.updateUserStats();
                }
            });
        };

        $('#userSearchBar').on('input', function () {
            window.userSearch();
        });

        $('.userSortBTN').on('click', function (e) {
            e.preventDefault();

            var filterName = $(this).data("filter");
            $(this).toggleClass('active-selected');

            var index = $.inArray(filterName, selectedUserFilters);
            if (index > -1) {
                selectedUserFilters.splice(index, 1);
            } else {
                selectedUserFilters.push(filterName);
            }

            $('#userClearBTN').toggleClass('d-none', selectedUserFilters.length <= 1);

            if (selectedUserFilters.length === 5) {
                clearUserSort(e);
            } else {
                window.userSearch();
            }
        });

        $('#userClearBTN').on('click', function (e) {
            clearUserSort(e);
        });

        function clearUserSort(e) {
            e.preventDefault();
            selectedUserFilters = [];
            $('.userSortBTN').removeClass('active-selected');
            $('#userClearBTN').addClass('d-none');
            window.userSearch();
        }


        // LOCK / UNLOCK QUICK ACTION

        $(document).on('click', '.toggleLockBtn', function () {
            var userId = $(this).data('id');
            var token  = $('input[name="__RequestVerificationToken"]').first().val();
            var $btn   = $(this);

            $btn.prop('disabled', true);

            $.ajax({
                url: '/Admin/UserManagements/ToggleLock',
                type: 'POST',
                data: { id: userId, __RequestVerificationToken: token },
                success: function () {
                    window.userSearch();
                },
                error: function () {
                    const lockError = (window.getI18nText && window.getI18nText('admin_lock_error')) || 'Cannot update lock status. Please try again.';
                    alert(lockError);
                    $btn.prop('disabled', false);
                }
            });
        });


        // ADD USER BUTTON - triggers Create modal

        $('#openCreateUserBtn').on('click', function () {
            if (typeof window.ShowCreateUserModal === 'function') {
                window.ShowCreateUserModal();
            }
        });

    })(jQuery);
</script>

<link rel="stylesheet" href="~/css/User/indexStyle.css?v=1.2" />