@using RentalVehicleService.Models.ViewModels
@model RentalVehicleService.Models.ViewModels.UserManagement

@{
    // This partial is returned as HTML from /Users/Details/{id}
    // It renders inside #userDetailsModalBody
}

<!-- Avatar & Name Header -->
<div class="text-center mb-4">
    <div class="avatar-circle-lg mx-auto mb-3 bg-primary bg-opacity-10 text-primary">
        @(string.IsNullOrEmpty(Model.FullName) ? "?" : Model.FullName[0].ToString().ToUpper())
    </div>
    <h5 class="fw-bold mb-0">@Model.FullName</h5>
    <p class="text-muted small">@@@Model.UserName</p>

    @if (Model.IsLockedOut)
    {
        <span class="badge bg-danger">
            <i class="bi bi-lock-fill me-1"></i>Locked Out
        </span>
    }
    else
    {
        <span class="badge bg-success">
            <i class="bi bi-check-circle-fill me-1"></i>Active
        </span>
    }

    <div class="mt-2">
        @if (Model.Roles != null && Model.Roles.Any())
        {
            foreach (var role in Model.Roles)
            {
                <span class="badge bg-secondary me-1">@role</span>
            }
        }
    </div>
</div>

<hr class="my-3" />

<!-- Info Grid -->
<div class="row g-3">

    <!-- Account Info -->
    <div class="col-12">
        <p class="text-muted small fw-bold text-uppercase mb-2 border-bottom pb-1">
            <i class="bi bi-person-badge me-1"></i>Account Information
        </p>
    </div>

    <div class="col-md-6">
        <label class="text-muted small d-block">User ID</label>
        <span class="font-monospace small">@Model.Id</span>
    </div>

    <div class="col-md-6">
        <label class="text-muted small d-block">User Type</label>
        <span class="badge bg-secondary text-white">@(Model.UserType ?? "—")</span>
    </div>

    <div class="col-md-6">
        <label class="text-muted small d-block">Email</label>
        <a href="mailto:@Model.Email" class="text-decoration-none">
            <i class="bi bi-envelope text-muted me-1"></i>@Model.Email
        </a>
    </div>

    <div class="col-md-6">
        <label class="text-muted small d-block">Phone Number</label>
        <span>
            <i class="bi bi-telephone text-muted me-1"></i>
            @(string.IsNullOrEmpty(Model.PhoneNumber) ? "—" : Model.PhoneNumber)
        </span>
    </div>

    <!-- Identity Documents -->
    <div class="col-12 mt-2">
        <p class="text-muted small fw-bold text-uppercase mb-2 border-bottom pb-1">
            <i class="bi bi-card-text me-1"></i>Identity Documents
        </p>
    </div>

    <div class="col-md-4">
        <label class="text-muted small d-block">CCCD / National ID</label>
        <span>@(string.IsNullOrEmpty(Model.CCCD) ? "—" : Model.CCCD)</span>
    </div>

    <div class="col-md-4">
        <label class="text-muted small d-block">Passport Number</label>
        <span>@(string.IsNullOrEmpty(Model.PassportNumber) ? "—" : Model.PassportNumber)</span>
    </div>

    <div class="col-md-4">
        <label class="text-muted small d-block">Nationality</label>
        <span>@(string.IsNullOrEmpty(Model.Nationality) ? "—" : Model.Nationality)</span>
    </div>

</div>

<style>
    .avatar-circle-lg {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
    }
</style>
