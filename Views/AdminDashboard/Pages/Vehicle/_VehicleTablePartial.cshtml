@model IEnumerable<RentalVehicleService.Models.Vehicle>

@foreach (var item in Model)
{
    <tr data-id="@item.VehicleId">
        <td class="ps-4 fw-bold text-muted">@item.VehicleId</td>
        <td>
            <span class="badge text-dark border">
                <i class="@(item.Type.ToString() == "Electric" ? "bi bi-lightning text-warning" : "bi bi-leaf text-success")"></i> 
                <span data-i18n="@(item.Type.ToString() == "Electric" ? "nav_electric" : "nav_pedal")">@item.Type</span>
            </span>
        </td>
        <td data-i18n="@item.VehicleModel">@item.VehicleModel</td>
        <td data-station-id="@item.CurrentStationId" class="small">
            <i class="bi bi-geo-alt text-danger"></i> @(item.CurrentStation?.Name ?? "In Transit")
        </td>
        <td>
            <div class="d-flex align-items-center">
                <div class="progress flex-grow-1 me-2" style="height: 6px; min-width: 50px;">
                    <div class="progress-bar @(item.BatteryPercentage < 20 ? "bg-danger" : "bg-success")"
                         role="progressbar" style="width: @item.BatteryPercentage%"></div>
                </div>
                <small>@item.BatteryPercentage%</small>
            </div>
        </td>
        <td>
            @{
                var stateStr = item.State.ToString();
                var statusClass = stateStr == "Available" ? "success" :
                                stateStr == "UnAvailable" ? "secondary" :
                                  stateStr == "Rented" ? "purple" :
                                  stateStr == "Maintenance" ? "danger" : "warning";
                var statusKey = "admin_" + stateStr.ToLower();
            }
            <span class="badge rounded-pill bg-@statusClass-subtle text-@statusClass border border-@statusClass">
                <span data-i18n="@statusKey">@stateStr</span>
            </span>
        </td>
        <td class="text-muted small">@item.LastMaintenance.ToString("dd/MM/yyyy")</td>
        <td class="text-center">
            <div class="btn-group shadow-sm">
                <button class="btn btn-outline-primary btn-sm"
                        onclick="ShowDetailsModal(@item.VehicleId)"
                        title="View Details">
                    <i class="bi bi-eye"></i>
                </button>
                <button class="btn btn-outline-warning btn-sm"
                        onclick="ShowEditModal(@item.VehicleId)"
                        title="Edit">
                    <i class="bi bi-pencil-square"></i>
                </button>
                <button class="btn btn-outline-danger btn-sm"
                        onclick="prepareDelete('@item.VehicleId', '@item.VehicleModel')"
                        title="Delete">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </td>
    </tr>
}
