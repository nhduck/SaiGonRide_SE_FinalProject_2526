@using RentalVehicleService.Models
@model IEnumerable<RentalVehicleService.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicle Management";
}

<div class="m-3">
    <div class="container-fluid py-4 px-lg-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-bicycle"></i> <span data-i18n="admin_vehicle_management">Vehicle Management</span></h4>
                <p class="text-muted small mb-0" data-i18n="admin_vehicle_management_subtitle">Manage all vehicles in the network</p>
            </div>
            <button class="btn btn-success" id="openCreateBtn">
                <i class="bi bi-plus-lg"></i> <span data-i18n="admin_add_vehicle">Add Vehicle</span>
            </button>
        </div>

        <!-- Stats -->
        <div class="row row-cols-1 row-cols-md-3 g-3 mb-5">
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-primary border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_total_vehicles">Total Vehicles</div>
                        <div id="totalCount" class="h3 fw-bold text-primary mb-0">@ViewBag.TotalVehicles</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-success border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_available">Available</div>
                        <div id="availableCount" class="h3 fw-bold text-success mb-0">@ViewBag.Available</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-secondary border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_unavailable">Unavailable</div>
                        <div id="unavailableCount" class="h3 fw-bold text-secondary mb-0">@ViewBag.UnAvailable</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-warning border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_charging">Charging</div>
                        <div id="chargingCount" class="h3 fw-bold text-warning mb-0">@ViewBag.Charging</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-danger border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_maintenance">Maintenance</div>
                        <div id="maintenanceCount" class="h3 fw-bold text-danger mb-0">@ViewBag.Maintenance</div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm stat-card border-start border-purple border-4 h-100">
                    <div class="card-body">
                        <div class="text-muted small fw-bold text-uppercase" data-i18n="admin_rented">Rented</div>
                        <div id="rentedCount" class="h3 fw-bold text-purple mb-0">@ViewBag.Rented</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-2">
                    <div class="col-lg-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input id="searchBar" type="text" name="searchString"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Search by model or ID..." data-i18n="[placeholder]admin_search_placeholder">
                        </div>
                    </div>
                    <div class="col-lg-8 d-flex gap-2 flex-wrap justify-content-lg-end">
                        <button id="clearBTN" class="btn btn-outline-primary d-none">Clear Sort</button>
                        <button id="availableBTN" class="sortBTN btn btn-outline-success" data-i18n="admin_available">Available</button>
                        <button id="UnAvailableBTN" class="sortBTN btn btn-outline-secondary" data-i18n="admin_unavailable">UnAvailable</button>
                        <button id="ChargingBTN" class="sortBTN btn btn-outline-warning" data-i18n="admin_charging">Charging</button>
                        <button id="MaintenanceBTN" class="sortBTN btn btn-outline-danger" data-i18n="admin_maintenance">Maintenance</button>
                        <button id="RentedBTN" class="sortBTN btn btn-outline-purple" data-i18n="admin_rented">Rented</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Table -->
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <div class="scroll-area">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th class="ps-4" data-i18n="admin_vehicle_id">Vehicle Id</th>
                                <th data-i18n="nav_guide">Type</th>
                                <th data-i18n="admin_model">Model</th>
                                <th data-i18n="admin_current_station">Current Station</th>
                                <th data-i18n="admin_battery">Battery</th>
                                <th data-i18n="admin_status">Status</th>
                                <th data-i18n="admin_last_maintenance">Last Maintenance</th>
                                <th class="text-center" data-i18n="admin_actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="vehicleTableBody">
                            <partial name="~/Views/AdminDashboard/Pages/Vehicle/_VehicleTablePartial.cshtml" />
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <iframe name="hidden_frame" style="display:none;"></iframe>

    <!-- Station data from server - modals share this via fillStationDropdown() -->
    <script>
            var stationList = [
                @foreach (var s in ViewBag.Stations as List<RentalVehicleService.Models.Station>)
                {
                        @:{ id: @s.StationId, name: "@Html.Raw(s.Name)", address: "@Html.Raw(s.Address)" },
                }
            ];
    </script>

    <!-- Modals - defined AFTER stationList so JS inside modals can access it -->
    <partial name="~/Views/AdminDashboard/Pages/Vehicle/Delete.cshtml" />
    <partial name="~/Views/AdminDashboard/Pages/Vehicle/Create.cshtml" model="new RentalVehicleService.Models.Vehicle()" />
    <partial name="~/Views/AdminDashboard/Pages/Vehicle/Edit.cshtml" model="new RentalVehicleService.Models.Vehicle()" />
    <partial name="~/Views/AdminDashboard/Pages/Vehicle/Details.cshtml" model="new RentalVehicleService.Models.Vehicle()" />

</div>

<script>
         $(document).ready(function () {

        // STATION

        // Populate station dropdown list
        function fillStationDropdown(selectId, selectedId) {
            var $select = $(selectId);
            $select.empty();
            const noStationText = (window.getI18nText && window.getI18nText('admin_no_station')) || '-- No Station --';
            $select.append('<option value="">' + noStationText + '</option>');

            $.each(stationList, function (i, station) {
                var option = $('<option>')
                    .val(station.id)
                    .text('#' + station.id + ' — ' + station.name + ' (' + station.address + ')');

                if (station.id == selectedId) {
                    option.prop('selected', true);
                }

                $select.append(option);
            });
        }

        // Get station name by ID
        function getStationName(stationId) {
            var result = (window.getI18nText && window.getI18nText('admin_no_station')) || 'No Station';
            $.each(stationList, function (i, station) {
                if (station.id == stationId) {
                    result = station.name;
                    return false; // dừng vòng lặp
                }
            });
            return result;
        }

        // Render station names in the table (replaces ID with name)
        function renderStationNames() {
            $('[data-station-id]').each(function () {
                var stationId = $(this).data('station-id');
                var name      = getStationName(stationId);
                $(this).html('<i class="bi bi-geo-alt text-danger"></i> ' + name);
            });
        }


        // DELETE MODAL
        function prepareDelete(vehicleId, vehicleName) {
            $('#idToConfirm').val(vehicleId);
            $('#idToDisplay').text(vehicleId);
            $('#nameToDisplay').text(vehicleName);
            $('#deleteModal').modal('show');
        }

        $('#confirmDeleteBtn').on('click', function () {
            var id    = $('#idToConfirm').val();
            var token = $('input[name="__RequestVerificationToken"]').first().val();

            $.ajax({
                url: '/Vehicles/DeleteConfirmed',
                type: 'POST',
                data: { id: id, __RequestVerificationToken: token },
                success: function () {
                    $('#deleteModal').modal('hide');
                    // Remove row from table with fade effect
                    $('tr[data-id="' + id + '"]').fadeOut(300, function () {
                        $(this).remove();
                        updateStats();
                    });
                },
                error: function () {
                    const deleteError = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'Cannot delete vehicle. Please try again.';
                    alert(deleteError);
                }
            });
        });


        // CREATE MODAL
        function ShowCreateModal() {
            fillStationDropdown('#createStationId', null);
            $('#createModal').modal('show');
        }

        $('#openCreateBtn').on('click', function () {
            ShowCreateModal();
        });


        // DETAILS MODAL
        function ShowDetailsModal(vehicleId) {
            // Show spinner while loading
            $('#detailsModalBody').html(
                '<div class="text-center py-4">' +
                '  <div class="spinner-border text-primary" role="status"></div>' +
                '  <p class="mt-2 text-muted">' + ((window.getI18nText && window.getI18nText('admin_loading')) || 'Loading...') + '</p>' +
                '</div>'
            );

            // Save ID for Edit button usage
            $('#detailsEditBtn').data('id', vehicleId);
            $('#detailsModal').modal('show');

            $.ajax({
                url: '/Vehicles/Details/' + vehicleId,
                type: 'GET',
                success: function (html) {
                    $('#detailsModalBody').html(html);
                },
                error: function () {
                    const errorMsg = (window.getI18nText && window.getI18nText('admin_details_error')) || 'Cannot load vehicle details. Please try again.';
                    $('#detailsModalBody').html(
                        '<div class="alert alert-danger">' + errorMsg + '</div>'
                    );
                }
            });
        }

        // Edit button inside Details modal -> close Details then open Edit
        $('#detailsEditBtn').on('click', function () {
            var id = $(this).data('id');
            $('#detailsModal').modal('hide');
            $('#detailsModal').one('hidden.bs.modal', function () {
                ShowEditModal(id);
            });
        });


        // EDIT MODAL
        function ShowEditModal(vehicleId) {
            $('#editAlertArea').html('');
            $('#editForm')[0].reset();

            $.ajax({
                url: '/Vehicles/Edit/' + vehicleId,
                type: 'GET',
                success: function (data) {
                    // Fill data into form
                    $('#editVehicleId').val(data.vehicleId);
                    $('#editVehicleModel').val(data.vehicleModel);
                    $('#editPrice').val(data.price);
                    $('#editBattery').val(data.batteryPercentage);
                    $('#editState').val(data.state);
                    $('#editType').val(data.type);
                    $('#editLastMaintenance').val(data.lastMaintenance);

                    // Populate station dropdown and pre-select current station
                    fillStationDropdown('#editStationId', data.currentStationId);

                    $('#editModal').modal('show');
                },
                error: function () {
                    const errorMsg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'Cannot load vehicle data. Please try again.';
                    alert(errorMsg);
                }
            });
        }

        // Submit Edit form
        $('#editForm').on('submit', function (e) {
            e.preventDefault();

            var vehicleId = $('#editVehicleId').val();
            var $btn      = $('#editSubmitBtn');

            const savingText = (window.getI18nText && window.getI18nText('admin_saving')) || 'Saving...';
            // Disable button, show spinner
            $btn.prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm me-1"></span>' + savingText);

            $.ajax({
                url: '/Vehicles/Edit/' + vehicleId,
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    $('#editModal').modal('hide');
                    search();
                },
                error: function (xhr) {
                    // Display server error
                    var msg = 'An error occurred. Please try again.';
                    try {
                        var res = JSON.parse(xhr.responseText);
                        if (res.errors) msg = res.errors.join('<br>');
                    } catch (e) {}

                    $('#editAlertArea').html(
                        '<div class="alert alert-danger alert-dismissible fade show py-2 small">' +
                        '  <i class="bi bi-exclamation-triangle me-1"></i>' + msg +
                        '  <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>' +
                        '</div>'
                    );
                },
                complete: function () {
                    // Re-enable button
                    const saveText = (window.getI18nText && window.getI18nText('admin_save_changes')) || 'Save Changes';
                    $btn.prop('disabled', false)
                        .html('<i class="bi bi-floppy me-1"></i>' + saveText);
                }
            });
        });


        // STATISTICS
        function updateStats() {
            $.ajax({
                url: '/Vehicles/GetAmountInfo',
                type: 'GET',
                success: function (data) {
                    $('#totalCount').text(data.totalVehicles);
                    $('#availableCount').text(data.available);
                    $('#unavailableCount').text(data.unAvailable);
                    $('#chargingCount').text(data.charging);
                    $('#maintenanceCount').text(data.maintenance);
                    $('#rentedCount').text(data.rented);
                }
            });
        }


        // SEARCH & FILTER
        var selectedStatuses = [];

        // Search bar
        $('#searchBar').on('input', function () {
            search();
        });

        // Status filter buttons
        $('.sortBTN').on('click', function (e) {
            e.preventDefault();

            var statusName = $(this).text().trim();
            $(this).toggleClass('active-selected');

            // Add or remove from filter list
            var index = $.inArray(statusName, selectedStatuses);
            if (index > -1) {
                selectedStatuses.splice(index, 1);
            } else {
                selectedStatuses.push(statusName);
            }

            // Show/hide Clear button
            if (selectedStatuses.length > 1) {
                $('#clearBTN').removeClass('d-none');
            } else {
                $('#clearBTN').addClass('d-none');
            }

            // Auto-clear if all selected
            if (selectedStatuses.length === 5) {
                clearSort(e);
            } else {
                search();
            }
        });

        // Clear Sort button
        $('#clearBTN').on('click', function (e) {
            clearSort(e);
        });

        function clearSort(e) {
            e.preventDefault();
            selectedStatuses = [];
            $('.sortBTN').removeClass('active-selected');
            $('#clearBTN').addClass('d-none');
            search();
        }

        // Call search API and reload table
        function search() {
            $.ajax({
                url: '/AdminDashboard/SearchVehicles',
                type: 'GET',
                data: { searchTerm: $('#searchBar').val(), statuses: selectedStatuses },
                traditional: true,
                success: function (html) {
                    $('#vehicleTableBody').html(html);
                    renderStationNames();
                    updateStats();
                }
            });
        }

        // INITIALIZATION
        renderStationNames();

        // Expose to global scope for partial views
        window.prepareDelete       = prepareDelete;
        window.ShowCreateModal     = ShowCreateModal;
        window.ShowDetailsModal    = ShowDetailsModal;
        window.ShowEditModal       = ShowEditModal;
        window.fillStationDropdown = fillStationDropdown;
        window.getStationName      = getStationName;

    }); // end document.ready
</script>

<link rel="stylesheet" href="~/css/Vehicle/indexStyle.css" />

<style>
    #RentedBTN.active-selected {
        background-color: #6f42c1 !important;
        border-color: #6f42c1 !important;
        color: #ffffff !important;
    }
</style>