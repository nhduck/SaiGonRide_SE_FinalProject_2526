	@using RentalVehicleService.Models
	@model IEnumerable<RentalVehicleService.Models.Vehicle>

	@{
		ViewData["Title"] = "Vehicle Management";
	}

	<div class="m-3">

		<div class="container-fluid py-4 px-lg-5">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<div>
					<h4 class="fw-bold mb-1"><i class="bi bi-bicycle"></i> Vehicle Management</h4>
					<p class="text-muted small mb-0">Manage all vehicles in the network</p>
				</div>

				<button class="btn btn-success" onclick="ShowCreateModal()">
					<i class="bi bi-plus-lg"></i> Add Vehicle
				</button>
			</div>

			<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-3 mb-5">
    
				<div class="col">
					<div class="card border-0 shadow-sm stat-card border-start border-primary border-4 h-100">
						<div class="card-body">
							<div class="text-muted small fw-bold text-uppercase">Total Vehicles</div>
							<div id="totalCount" class="h3 fw-bold text-primary mb-0">@ViewBag.TotalVehicles</div>
						</div>
					</div>
				</div>

				<div class="col">
					<div class="card border-0 shadow-sm stat-card border-start border-success border-4 h-100">
						<div class="card-body">
							<div class="text-muted small fw-bold text-uppercase">Available</div>
							<div id="availableCount" class="h3 fw-bold text-success mb-0">@ViewBag.Available</div>
						</div>
					</div>
				</div>

				<div class="col">
					<div class="card border-0 shadow-sm stat-card border-start border-warning border-4 h-100">
						<div class="card-body">
							<div class="text-muted small fw-bold text-uppercase">Charging</div>
							<div id="chargingCount" class="h3 fw-bold text-warning mb-0">@ViewBag.Charging</div>
						</div>
					</div>
				</div>

				<div class="col">
					<div class="card border-0 shadow-sm stat-card border-start border-danger border-4 h-100">
						<div class="card-body">
							<div class="text-muted small fw-bold text-uppercase">Maintenance</div>
							<div id="maintenanceCount" class="h3 fw-bold text-danger mb-0">@ViewBag.Maintenance</div>
						</div>
					</div>
				</div>

				<div class="col">
					<div class="card border-0 shadow-sm stat-card border-start border-purple border-4 h-100">
						<div class="card-body">
							<div class="text-muted small fw-bold text-uppercase">Rented</div>
							<div id="rentedCount" class="h3 fw-bold text-purple mb-0">@ViewBag.Rented</div>
						</div>
					</div>
				</div>

			</div>

			<div class="card border-0 shadow-sm mb-4">
				<div class="card-body">
					<form method="get" class="row g-2">
						<div class="col-lg-4">
							<div class="input-group">
								<span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
								<input id="searchBar" type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Search by model or ID...">
							</div>
						</div>
						<div class="col-lg-8 d-flex gap-2 flex-wrap justify-content-lg-end">
							<button id="availableBTN" class="sortBTN btn btn-outline-success">Available</button>
							<button id="ChargingBTN" class="sortBTN btn btn-outline-warning">Charging</button>
							<button id="MaintenanceBTN" class="sortBTN btn btn-outline-danger">Maintenance</button>
							<button id="RentedBTN" class="sortBTN btn btn-outline-purple">Rented</button>
						</div>
					</form>
				</div>
			</div>

			<div class="card border-0 shadow-sm">
				<div class="table-responsive">
					<div class="scroll-area">
						<table class="table table-hover align-middle mb-0">
							<thead class="bg-light sticky-top">
								<tr>
									<th class="ps-4">Vehicle Id</th>
									<th>Type</th>
									<th>Model</th>
									<th>Current Station</th>
									<th>Battery</th>
									<th>Status</th>
									<th>Last Maintenance</th>
									<th class="text-center">Actions</th>
								</tr>
							</thead>
							<tbody id="vehicleTableBody">
								<partial name="~/Views/AdminDashboard/Pages/Vehicle/_VehicleTablePartial.cshtml" />
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>

		<iframe name="hidden_frame" style="display:none;"></iframe>

		<partial name="~/Views/AdminDashboard/Pages/Vehicle/Delete.cshtml" />
		<partial name="~/Views/AdminDashboard/Pages/Vehicle/Create.cshtml" model="new RentalVehicleService.Models.Vehicle()" />
	</div>

	<script>
		// 1. Hiển thị Modal xóa
		function prepareDelete(id, name) {
			$('#idToConfirm').val(id);
			$('#idToDisplay').text(id);
			$('#nameToDisplay').text(name);
			$('#deleteModal').modal('show');
		}

		// 2. Hiển thị Modal thêm mới
		function ShowCreateModal() {
			$('#createModal').modal('show');
		}

		// 3. Cập nhật thống kê
		function updateStats() {
			$.ajax({
				url: '/Vehicles/GetAmountInfo',
				type: 'GET',
				dataType: 'json',
				success: function(data) {
					$("#totalCount").text(data.totalVehicles);
					$("#availableCount").text(data.available);
					$("#chargingCount").text(data.charging);
					$("#maintenanceCount").text(data.maintenance);
					$("#rentedCount").text(data.rented);
				},
				error: function(xhr) {
					console.error("Lỗi cập nhật thống kê:", xhr.responseText);
				}
			});
		}

		// 4. Xử lý xóa xe bằng AJAX
		$('#confirmDeleteBtn').on('click', function () {
			const id = $('#idToConfirm').val();

			const token = $('input[name="__RequestVerificationToken"]').val();

			$.ajax({
				url: '/Vehicles/DeleteConfirmed',
				type: 'POST',
				data: {
					id: id,
					__RequestVerificationToken: token
				},
				success: function() {
					$('#deleteModal').modal('hide');
					// Tìm dòng có data-id tương ứng và xóa đi
					$(`tr[data-id="${id}"]`).fadeOut(300, function() {
						$(this).remove();
						updateStats();
					});
				},
				error: function(xhr) {
					console.error("Lỗi khi xóa:", xhr.statusText);
					alert("Không thể xóa phương tiện. Vui lòng thử lại.");
				}
			});
		});

	// 5. Xử lý tìm kiếm
	let selectedStatuses = [];

	$("#searchBar").on("input", function() {
		search();
	});

	$('.sortBTN').on("click", function(e) {
		e.preventDefault();
		const status = $(this).text().trim();
    
		$(this).toggleClass('active-selected');
    
		toggleStatus(status);
	});

	function toggleStatus(statusName) {
		const index = selectedStatuses.indexOf(statusName);

		if (index > -1) {
			selectedStatuses.splice(index, 1);
		} else {
			selectedStatuses.push(statusName);
		}
		search();
	}

	function search() {
		const keyword = $("#searchBar").val();
    
		$.ajax({
			url: '/AdminDashboard/SearchVehicles',
			type: 'GET',
			data: {
				searchTerm: keyword,
				statuses: selectedStatuses
			},
			traditional: true,
			success: function(response) {
				$('#vehicleTableBody').html(response);
				updateStats();
			}
		});
	}
	</script>

	<link rel="stylesheet" href="~/css/Vehicle/indexStyle.css" />