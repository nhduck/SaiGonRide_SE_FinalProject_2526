@model RentalVehicleService.Models.Vehicle

<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-lg modal-dialog-centered">
		<div class="modal-content border-0 shadow">

			<div class="modal-header border-bottom px-4 py-3">
				<div class="d-flex align-items-center gap-2">
					<div class="rounded-2 bg-primary bg-opacity-10 p-2">
						<i class="bi bi-ev-front text-primary"></i>
					</div>
					<div>
						<h5 class="modal-title mb-0 fw-500" data-i18n="admin_add_new_vehicle">Add New Vehicle</h5>
						<small class="text-muted" data-i18n="admin_fill_info">Please fill in all the required information below</small>
					</div>
				</div>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>

			<form asp-action="Create" method="post">
				<div class="modal-body px-4 py-3">
					<div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
					<div class="row g-3">

						<div class="col-md-6">
							<label asp-for="VehicleModel" class="form-label fw-semibold small text-secondary" data-i18n="admin_model">Vehicle Model</label>
							<input asp-for="VehicleModel" id="VehicleModelInput" class="form-control form-control-sm" placeholder="e.g. VinFast Feliz" data-i18n="[placeholder]admin_model" />
							<span asp-validation-for="VehicleModel" class="text-danger small"></span>
						</div>

						<div class="col-md-6">
							<label asp-for="CurrentStationId" class="form-label fw-semibold small text-secondary" data-i18n="admin_current_station">Current Station ID</label>
							<select asp-for="CurrentStationId" id="createStationId" class="form-select form-select-sm">
								<option value="" data-i18n="admin_no_station">-- No Station --</option>
							</select>
							<span asp-validation-for="CurrentStationId" class="text-danger small"></span>
						</div>

						<div class="col-md-6">
							<label asp-for="Price" id="VehiclePriceInput" class="form-label fw-semibold small text-secondary" data-i18n="admin_price_per_min">Rental Price (VND/hr)</label>
							<div class="input-group input-group-sm">
								<span class="input-group-text bg-light border-end-0">₫</span>
								<input asp-for="Price" class="form-control border-start-0" type="number" placeholder="0" />
							</div>
							<span asp-validation-for="Price" class="text-danger small"></span>
						</div>

						<div class="col-md-6">
							<label asp-for="State" class="form-label fw-semibold small text-secondary" data-i18n="admin_status">Vehicle Status</label>
							<select asp-for="State" id="VehicleStateInput" class="form-select form-select-sm"
									asp-items="Html.GetEnumSelectList<RentalVehicleService.Models.VehicleState>()">
								<option value="" data-i18n="admin_select_status">-- Select Status --</option>
							</select>
							<span asp-validation-for="State" class="text-danger small"></span>
						</div>

						<div class="col-12">
							<label asp-for="BatteryPercentage" class="form-label fw-semibold small text-secondary" data-i18n="admin_battery_percentage">
								Battery Level (%)
							</label>
    
							<div class="d-flex align-items-center gap-3">
								<input type="range"
									   class="form-range"
									   min="0" max="100"
									   id="batteryRange"
									   value="80"
									   oninput="batteryNumber.value = this.value" />

								<input asp-for="BatteryPercentage"
									   type="number"
									   class="form-control"
									   style="width: 80px;"
									   id="batteryNumber"
									   min="0" max="100"
									   value="80"
									   oninput="batteryRange.value = this.value" />
							</div>

							<span asp-validation-for="BatteryPercentage" class="text-danger small"></span>
						</div>
					</div>
				</div>

				<div class="modal-footer border-top px-4 py-3">
					<button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal" data-i18n="admin_close">Close</button>
    
					<button type="submit" id="sunmitBtn" class="btn btn-sm btn-primary px-4">
						<i class="bi bi-check2-circle me-1"></i> <span data-i18n="admin_create">Create</span>
					</button>
				</div>
			</form>

		</div>
	</div>
</div>

<script>
	$(document).ready(function () {
		// Declare jQuery variables
		const $form = $('#createModal form');
		const $saveBtn = $('#sunmitBtn');
		const $batteryNum = $('#batteryNumber');
		const $batteryRange = $('#batteryRange');
		const $modelInput = $('#VehicleModelInput');
		const $stationInput = $('#VehicleStationInput');
		const $priceInput = $('input[name="Price"]');

		// 1. Validation function to enable/disable Save button
	function validationForm() {
		const isModel = $.trim($modelInput.val()) !== "";
		const isPrice = $priceInput.val() !== "" && parseFloat($priceInput.val()) >= 0;
		const isPin   = $batteryNum.val() !== "" && $batteryNum.val() >= 0 && $batteryNum.val() <= 100;

		// Skip isStation since CurrentStationId is nullable in the model
		if (isModel && isPrice && isPin) {
			$saveBtn.prop('disabled', false).removeClass('btn-secondary').addClass('btn-primary');
		} else {
			$saveBtn.prop('disabled', true).removeClass('btn-primary').addClass('btn-secondary');
		}
	}

		// 2. Sync Battery range and number input
		$batteryNum.on('input', function() {
			$batteryRange.val($(this).val());
			validationForm();
		});

		$batteryRange.on('input', function() {
			$batteryNum.val($(this).val());
			validationForm();
		});

		// 3. Listen for changes on other fields
		$form.find('input, select').on('input change', validationForm);

		// 4. Handle AJAX submit
		$form.on('submit', function (e) {
		e.preventDefault();

		$.ajax({
			url: $(this).attr('action'),
			type: 'POST',
			data: $(this).serialize(),
			success: function (res) {
				$('#createModal').modal('hide');

				$.get('/AdminDashboard/SearchVehicles', { searchTerm: '', statuses: [] }, function (html) {
					$('#vehicleTableBody').html(html);
					updateStats();
				});

				$form[0].reset();
				$('#batteryRange').val(80);
				$('#batteryNumber').val(80);
				validationForm();
			},
			error: function (xhr) {
				const errorMsg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'Cannot create vehicle. Please try again.';
				alert(errorMsg);
			}
		});
	});

		validationForm();
	});
</script>