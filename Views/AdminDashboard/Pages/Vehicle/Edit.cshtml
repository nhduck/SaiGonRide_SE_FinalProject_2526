@model RentalVehicleService.Models.Vehicle

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-pencil-square me-2"></i><span data-i18n="admin_edit_vehicle">Edit Vehicle</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editVehicleId" name="VehicleId" />

                <div class="modal-body p-4">
                    <div id="editAlertArea"></div>
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_model">
                                <i class="bi bi-tag me-1 text-primary"></i>Vehicle Model
                            </label>
                            <input type="text" class="form-control" id="editVehicleModel"
                                   name="VehicleModel" placeholder="e.g. Honda Vision" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="nav_guide">
                                <i class="bi bi-lightning-charge me-1 text-primary"></i>Type
                            </label>
                            <select class="form-select" id="editType" name="Type">
                                @foreach (var t in Enum.GetValues(typeof(RentalVehicleService.Models.VehicleType)))
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_price_per_min">
                                <i class="bi bi-currency-dollar me-1 text-primary"></i>Rental Price (VND/min)
                            </label>
                            <input type="number" class="form-control" id="editPrice"
                                   name="Price" min="0" step="any" placeholder="e.g. 500" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_battery">
                                <i class="bi bi-battery-half me-1 text-primary"></i>Battery (%)
                            </label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="editBattery"
                                       name="BatteryPercentage" min="0" max="100" required />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_status">
                                <i class="bi bi-activity me-1 text-primary"></i>State
                            </label>
                            <select class="form-select" id="editState" name="State">
                                @foreach (var s in Enum.GetValues(typeof(RentalVehicleService.Models.VehicleState)))
                                {
                                    <option value="@((int)s)">@s</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_current_station">
                                <i class="bi bi-geo-alt me-1 text-primary"></i>Current Station
                            </label>
                            <!-- JS fillStationDropdown() in Index.cshtml will auto-fill this -->
                            <select class="form-select" id="editStationId" name="CurrentStationId">
                                <option value="" data-i18n="admin_no_station">-- No Station --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold" data-i18n="admin_last_maintenance">
                                <i class="bi bi-wrench me-1 text-primary"></i>Last Maintenance Date
                            </label>
                            <input type="datetime-local" class="form-control"
                                   id="editLastMaintenance" name="LastMaintenance" />
                        </div>

                    </div>
                </div>

                <div class="modal-footer border-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg me-1"></i><span data-i18n="admin_cancel">Cancel</span>
                    </button>
                    <button type="submit" class="btn btn-primary px-4" id="editSubmitBtn">
                        <i class="bi bi-floppy me-1"></i><span data-i18n="admin_save_changes">Save Changes</span>
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
        function ShowEditModal(vehicleId) {
        $('#editAlertArea').html('');
        $('#editForm')[0].reset();

        $.ajax({
            url: '/Vehicles/Edit/' + vehicleId,
            type: 'GET',
            success: function (data) {
                $('#editVehicleId').val(data.vehicleId);
                $('#editVehicleModel').val(data.vehicleModel);
                $('#editPrice').val(data.price);
                $('#editBattery').val(data.batteryPercentage);
                $('#editState').val(data.state);
                $('#editType').val(data.type);
                $('#editLastMaintenance').val(data.lastMaintenance);
                fillStationDropdown('#editStationId', data.currentStationId);
                $('#editModal').modal('show');
            },
            error: function () {
                const errorMsg = (window.getI18nText && window.getI18nText('admin_error_occurred')) || 'Cannot load vehicle data. Please try again.';
                alert(errorMsg);
            }
        });
    }

    $('#editForm').on('submit', function (e) {
        e.preventDefault();

        var vehicleId = $('#editVehicleId').val();
        var $btn      = $('#editSubmitBtn');
        const savingText = (window.getI18nText && window.getI18nText('admin_saving')) || 'Saving...';
    
        $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>' + savingText);

        $.ajax({
            url: '/Vehicles/Edit/' + vehicleId,
            type: 'POST',
            data: $(this).serialize(),
            success: function () {
                $('#editModal').modal('hide');
                search();
            },
            error: function (xhr) {
                var msg = 'An error occurred. Please try again.';
                try {
                    var res = JSON.parse(xhr.responseText);
                    if (res.errors) msg = res.errors.join('<br>');
                } catch (e) {}

                $('#editAlertArea').html(
                    '<div class="alert alert-danger alert-dismissible fade show py-2 small">' +
                    '  <i class="bi bi-exclamation-triangle me-1"></i>' + msg +
                    '  <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>' +
                    '</div>'
                );
            },
            complete: function () {
                const saveText = (window.getI18nText && window.getI18nText('admin_save_changes')) || 'Save Changes';
                $btn.prop('disabled', false).html('<i class="bi bi-floppy me-1"></i>' + saveText);
            }
        });
    });
</script>