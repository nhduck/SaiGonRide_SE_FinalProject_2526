@model RentalVehicleService.Models.Vehicle

<form id="editVehicleForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="VehicleId" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="VehicleModel" class="form-label fw-bold"></label>
            <input asp-for="VehicleModel" class="form-control" />
            <span asp-validation-for="VehicleModel" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Price" class="form-label fw-bold"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="BatteryPercentage" class="form-label fw-bold"></label>
            <input asp-for="BatteryPercentage" class="form-control" type="number" />
            <span asp-validation-for="BatteryPercentage" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="State" class="form-label fw-bold"></label>
            <input asp-for="State" class="form-control" />
            <span asp-validation-for="State" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="CurrentStationId" class="form-label fw-bold"></label>
            <input asp-for="CurrentStationId" class="form-control" />
            <span asp-validation-for="CurrentStationId" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 mt-4">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" onclick="submitEditForm()" class="btn btn-primary px-4">Lưu thay đổi</button>
    </div>
</form>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}