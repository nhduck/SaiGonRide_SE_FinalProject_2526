@model IEnumerable<RentalVehicleService.Models.Station>

@{
    ViewData["Title"] = "Manage Stations";
    var searchTerm = ViewBag.SearchTerm as string;
    var fillFilter = ViewBag.FillFilter as string;
    int totalActive = ViewBag.TotalActive ?? 0;
}

<div class="m-5">
<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-geo-alt me-2"></i>Manage Stations</h4>
        <p class="text-muted small mb-0">Manage all rental stations in the network</p>
    </div>
    <a href="/Admin/Stations/Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i>Add Station
    </a>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
        <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter Bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by name, address..."
                           value="@searchTerm" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="fillFilter" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="normal" selected="@(fillFilter == "normal")">Normal</option>
                    <option value="low" selected="@(fillFilter == "low")">⚠ Low Stock (&lt;20%)</option>
                    <option value="full" selected="@(fillFilter == "full")">🔴 Full (&gt;85%)</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-success w-100" type="submit">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
            </div>
            <div class="col-md-2 text-end">
                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
                    @totalActive active stations
                </span>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3" style="width:40px">#</th>
                            <th>Station Name</th>
                            <th>Address</th>
                            <th class="text-center">Capacity</th>
                            <th class="text-center">Current</th>
                            <th class="text-center" style="width:150px">Fill Rate</th>
                            <th class="text-center">Status</th>
                            <th class="text-center" style="width:120px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int idx = 1;
                        }
                        @foreach (var s in Model)
                        {
                            var pct = (int)(s.FillRate * 100);
                            var barColorClass = pct < 60 ? "fill-green" : (pct < 85 ? "fill-amber" : "fill-red");
                            var badgeClass = s.IsLowInventory ? "bg-danger" : (pct > 85 ? "bg-warning text-dark" : "bg-success");
                            var badgeText = s.IsLowInventory ? "Low Stock" : (pct > 85 ? "Full" : "Normal");

                            <tr>
                                <td class="ps-3 text-muted">@idx</td>
                                <td class="fw-semibold">@s.Name</td>
                                <td class="small text-muted">@s.Address</td>
                                <td class="text-center">@s.TotalCapacity</td>
                                <td class="text-center fw-semibold">@s.CurrentCount</td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-2 justify-content-center">
                                        <div class="fill-bar" style="width:60px; flex-shrink:0;">
                                            <div class="fill-bar-inner @barColorClass" style="width:@pct%"></div>
                                        </div>
                                        <span class="small fw-bold">@pct%</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge @badgeClass rounded-pill">@badgeText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Admin/Stations/Details/@s.StationId" class="btn btn-outline-primary" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/Admin/Stations/Edit/@s.StationId" class="btn btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@s.StationId" method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to disable this station?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            idx++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-geo fs-1 text-muted d-block mb-2"></i>
                <h6 class="text-muted">No stations found</h6>
                <a href="/Admin/Stations/Create" class="btn btn-sm btn-success mt-2">Add your first station</a>
            </div>
        }
    </div>
</div>
</div>