@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Delete Station";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border border-danger border-opacity-25 shadow-lg rounded-4 overflow-hidden position-relative animate-pop-in">
                <!-- Red top bar -->
                <div class="bg-danger p-4 text-center position-relative">
                    <!-- Decor pulse effect -->
                    <div class="position-absolute top-50 start-50 translate-middle" style="width: 100px; height: 100px; background: rgba(255,255,255,0.2); border-radius: 50%; filter: blur(20px);"></div>
                    
                    <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow mb-3 position-relative z-1" style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-triangle-fill text-danger text-gradient" style="font-size: 2.5rem;"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-0 position-relative z-1">Delete Station?</h3>
                    <p class="text-white text-opacity-75 mb-0 mt-1 position-relative z-1">This action cannot be undone.</p>
                </div>
                
                <div class="card-body p-4 p-md-5 bg-white">
                    <p class="text-center text-muted fw-medium mb-4">You are about to permanently delete the following station.</p>
                    
                    <!-- Station Info Block -->
                    <div class="p-4 bg-light rounded-4 border border-light-subtle mb-4 shadow-sm">
                        <div class="d-flex align-items-start mb-3 border-bottom pb-3">
                            <div class="bg-white rounded p-2 shadow-sm me-3 border">
                                <i class="bi bi-tag-fill fs-5 text-secondary"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.5px;">Station Name</div>
                                <div class="fs-5 fw-bold text-dark">@Model.Name</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-start mb-3 border-bottom pb-3">
                            <div class="bg-white rounded p-2 shadow-sm me-3 border">
                                <i class="bi bi-geo-alt-fill fs-5 text-secondary"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.5px;">Address</div>
                                <div class="fw-medium text-dark">@Model.Address</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-start">
                            <div class="bg-white rounded p-2 shadow-sm me-3 border">
                                <i class="bi bi-bicycle fs-5 text-secondary"></i>
                            </div>
                            <div>
                                <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.5px;">Inventory Context</div>
                                <div class="fw-medium text-dark text-danger">@Model.CurrentCount / @Model.TotalCapacity vehicles docked</div>
                            </div>
                        </div>
                    </div>

                    @if (Model.CurrentCount > 0)
                    {
                        <div class="alert alert-warning border border-warning rounded-4 shadow-sm d-flex align-items-center mb-4 p-3 pulse-warning">
                            <i class="bi bi-shield-exclamation fs-2 me-3 text-warning"></i>
                            <div class="small text-dark">
                                <strong class="d-block mb-1">Inventory Warning!</strong>
                                There are still <b>@Model.CurrentCount vehicles</b> docked here. Ensure you relocate these vehicles via the Database before proceeding.
                            </div>
                        </div>
                    }

                    <form asp-action="Delete" class="w-100">
                        <input type="hidden" asp-for="StationId" />
                        <div class="d-flex flex-column flex-md-row gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-light border btn-lg flex-grow-1 rounded-pill fw-bold text-dark hover-lift">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg flex-grow-1 rounded-pill fw-bold shadow hover-lift">
                                <i class="bi bi-trash-fill me-2"></i>Yes, Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift { transition: all 0.2s ease; }
    .hover-lift:hover { transform: translateY(-2px); filter: brightness(1.05); }
    
    .animate-pop-in { animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    @@keyframes popIn {
        0% { opacity: 0; transform: scale(0.95) translateY(10px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }
    .pulse-warning {
        animation: pulseWarning 2s infinite;
    }
    @@keyframes pulseWarning {
        0% { box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.4); }
        70% { box-shadow: 0 0 0 6px rgba(255, 193, 7, 0); }
        100% { box-shadow: 0 0 0 0 rgba(255, 193, 7, 0); }
    }
</style>
