@model RentalVehicleService.Models.Station

@{
    ViewData["Title"] = "Create Station";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold"><i class="bi bi-plus-circle-fill text-success me-2"></i>Create New Station</h1>
            <p class="text-muted mb-0">Add a new docking location to the operational network.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm hover-lift">
            <i class="bi bi-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-success mb-0">Station Info Setup</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control rounded-3 border-success border-opacity-25" placeholder="Station Name" />
                                    <label asp-for="Name" class="text-muted"><i class="bi bi-tag text-success me-1"></i>Station Name</label>
                                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input asp-for="Address" class="form-control rounded-3 border-success border-opacity-25" placeholder="Address" />
                                    <label asp-for="Address" class="text-muted"><i class="bi bi-geo-alt text-success me-1"></i>Address location</label>
                                    <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <h6 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Location Coordinates</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-12">
                                <p class="text-muted small mb-2"><i class="bi bi-info-circle me-1"></i>Click on the map or drag the pin to set the station's exact coordinates.</p>
                                <div class="p-1 border border-success border-opacity-25 rounded-3 bg-light shadow-sm">
                                    <div id="map" style="height: 300px; border-radius: 6px; z-index: 1;"></div>
                                </div>
                                <div class="d-flex text-muted fw-medium small mt-2">
                                    <div class="me-4"><i class="bi bi-geo-alt-fill text-danger me-1"></i>Lat: <span id="latDisplay">10.77690</span></div>
                                    <div><i class="bi bi-compass text-primary me-1"></i>Lng: <span id="lngDisplay">106.70090</span></div>
                                </div>
                                <input type="hidden" asp-for="Latitude" value="10.7769" />
                                <input type="hidden" asp-for="Longitude" value="106.7009" />
                            </div>
                        </div>

                        <h6 class="fw-bold text-secondary mb-3 text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Capacity Setup</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="TotalCapacity" class="form-control rounded-3" placeholder="Total Capacity" value="20" />
                                    <label asp-for="TotalCapacity" class="text-muted"><i class="bi bi-grid-3x3-gap me-1"></i>Total Capacity</label>
                                    <span asp-validation-for="TotalCapacity" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="CurrentCount" class="form-control rounded-3" placeholder="Current Count" value="0" />
                                    <label asp-for="CurrentCount" class="text-muted"><i class="bi bi-bicycle me-1"></i>Initial Vehicles Count</label>
                                    <span asp-validation-for="CurrentCount" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4 bg-light p-3 rounded-3 border border-light-subtle d-flex align-items-center shadow-sm">
                            <i class="bi bi-lightning-charge-fill fs-3 text-success me-3"></i>
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold">Active Immediately</h6>
                                <p class="text-muted mb-0 small">Toggle to make this station visible and operational for users right away.</p>
                            </div>
                            <div class="form-check form-switch fs-4 mb-0">
                                <input class="form-check-input bg-success border-success" type="checkbox" asp-for="IsActive" id="statusSwitch" checked>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="d-flex flex-column flex-sm-row justify-content-end gap-3">
                            <button type="button" class="btn btn-light px-4 rounded-pill fw-bold border hover-lift" onclick="window.history.back();">Cancel</button>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold hover-lift">
                                <i class="bi bi-save me-2"></i>Create Station
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
    }
    .form-floating > label {
        padding-left: 1.25rem;
    }
    .hover-lift {
        transition: transform 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var defaultLat = 10.7769;
            var defaultLng = 106.7009;
            var map = L.map('map').setView([defaultLat, defaultLng], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            var marker = L.marker([defaultLat, defaultLng], {draggable: true}).addTo(map);

            function updateInputs(lat, lng) {
                document.getElementById('Latitude').value = lat;
                document.getElementById('Longitude').value = lng;
                document.getElementById('latDisplay').innerText = lat.toFixed(5);
                document.getElementById('lngDisplay').innerText = lng.toFixed(5);
            }

            marker.on('dragend', function (e) {
                var coords = marker.getLatLng();
                updateInputs(coords.lat, coords.lng);
            });

            map.on('click', function (e) {
                marker.setLatLng(e.latlng);
                updateInputs(e.latlng.lat, e.latlng.lng);
            });
        });
    </script>
}