@using RentalVehicleService.Models
@model RentalVehicleService.Models.BugReport

@{
    var (badgeClass, icon) = Model.Status switch
    {
        BugReport.BugStatus.New        => ("bg-danger-subtle text-danger", "bi-exclamation-circle"),
        BugReport.BugStatus.InProgress => ("bg-warning-subtle text-warning", "bi-arrow-repeat"),
        BugReport.BugStatus.Resolved   => ("bg-success-subtle text-success", "bi-check-circle"),
        BugReport.BugStatus.Closed     => ("bg-secondary-subtle text-secondary", "bi-x-circle"),
        _                              => ("bg-light text-muted", "bi-question-circle")
    };
}

<div class="row g-3">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <span class="text-muted small fw-bold"><span data-i18n="admin_report_num">REPORT #</span>@Model.Id</span>
            <h5 class="fw-bold mt-1 mb-0">@Model.Title</h5>
        </div>
        <span class="badge @badgeClass px-3 py-2 rounded-pill fs-6">
            <i class="bi @icon me-1"></i><span data-i18n="admin_@(Model.Status.ToString().ToLower())">@Model.Status</span>
        </span>
    </div>
    <div class="col-12">
        <label class="form-label fw-semibold small text-secondary text-uppercase" data-i18n="admin_email_col">Reporter Email</label>
        <p class="mb-0"><i class="bi bi-envelope me-2 text-success"></i><a href="mailto:@Model.ReporterEmail" class="text-decoration-none">@Model.ReporterEmail</a></p>
    </div>
    <div class="col-12">
        <label class="form-label fw-semibold small text-secondary text-uppercase" data-i18n="admin_date_col">Submitted Date</label>
        <p class="mb-0"><i class="bi bi-calendar3 me-2 text-muted"></i>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
    <div class="col-12">
        <label class="form-label fw-semibold small text-secondary text-uppercase" data-i18n="admin_desc_col">Description</label>
        <div class="p-3 bg-light rounded border">
            <p class="mb-0" style="white-space: pre-wrap;">@Model.Description</p>
        </div>
    </div>
</div>
