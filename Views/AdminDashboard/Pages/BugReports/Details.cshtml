<!-- Report Details Modal -->
<div class="modal fade" id="reportDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom px-4 py-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-2 bg-info bg-opacity-10 p-2">
                        <i class="bi bi-flag text-info"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0 fw-semibold">Report Details</h5>
                        <small class="text-muted">Full report information</small>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3" id="reportDetailsBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-top px-4 py-3">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function showReportDetails(id) {
        $('#reportDetailsBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
        $('#reportDetailsModal').modal('show');

        $.ajax({
            url: '/BugReports/Details/' + id,
            type: 'GET',
            success: function (html) {
                $('#reportDetailsBody').html(html);
            },
            error: function () {
                $('#reportDetailsBody').html('<div class="alert alert-danger">Cannot load report details.</div>');
            }
        });
    }
</script>
