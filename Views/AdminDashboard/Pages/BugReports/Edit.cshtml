<!-- Report Edit Modal (Update Status) -->
<div class="modal fade" id="reportEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom px-4 py-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-2 bg-primary bg-opacity-10 p-2">
                        <i class="bi bi-pencil-square text-primary"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0 fw-semibold" data-i18n="admin_update_status">Update Report Status</h5>
                        <small class="text-muted" data-i18n="admin_change_status_desc">Change the processing status of this report</small>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="reportEditForm">
                @Html.AntiForgeryToken()
                <div class="modal-body px-4 py-3">
                    <div id="reportEditAlertArea"></div>

                    <input type="hidden" id="editReportId" name="id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-secondary"><span data-i18n="admin_report_num">Report #</span><span id="editReportIdDisplay"></span></label>
                        <p class="fw-bold mb-0" id="editReportTitle"></p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-secondary text-uppercase" data-i18n="admin_status_col">Update Status</label>
                        <select id="editReportStatus" name="Status" class="form-select">
                            <option value="0" data-i18n="admin_new">New</option>
                            <option value="1" data-i18n="admin_inprogress">InProgress</option>
                            <option value="2" data-i18n="admin_resolved">Resolved</option>
                            <option value="3" data-i18n="admin_closed">Closed</option>
                        </select>
                    </div>
                </div>

                <div class="modal-footer border-top px-4 py-3">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal" data-i18n="admin_cancel">Cancel</button>
                    <button type="submit" id="saveReportEditBtn" class="btn btn-sm btn-primary px-4">
                        <i class="bi bi-check2-circle me-1"></i> <span data-i18n="admin_save_status">Save Status</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showReportEditModal(id) {
        $('#reportEditAlertArea').html('');
        $('#reportEditModal').modal('show');

        $.ajax({
            url: '/BugReports/Edit/' + id,
            type: 'GET',
            success: function (data) {
                $('#editReportId').val(data.id);
                $('#editReportIdDisplay').text(data.id);
                $('#editReportTitle').text(data.title);
                $('#editReportStatus').val(data.status);
            },
            error: function () {
                $('#reportEditAlertArea').html('<div class="alert alert-danger">Cannot load report data.</div>');
            }
        });
    }

    $('#reportEditForm').on('submit', function (e) {
        e.preventDefault();
        var id     = $('#editReportId').val();
        var status = $('#editReportStatus').val();
        var token  = $('input[name="__RequestVerificationToken"]').first().val();

        $.ajax({
            url: '/BugReports/Edit',
            type: 'POST',
            data: { id: id, Status: status, __RequestVerificationToken: token },
            success: function () {
                $('#reportEditModal').modal('hide');
                searchReports();
            },
            error: function () {
                $('#reportEditAlertArea').html('<div class="alert alert-danger">Cannot update status. Please try again.</div>');
            }
        });
    });
</script>
