@{
    ViewData["Title"] = "Dashboard";
}

<body class="bg-gray-100 font-sans">

    <div class="flex h-screen">
        <aside class="w-64 bg-slate-900 text-white hidden md:flex flex-col">
            <div class="p-6 text-2xl font-bold text-blue-400">CAR-RENTAL</div>
            <nav class="flex-1 px-4 space-y-2">
                <a href="#" class="block py-2.5 px-4 rounded bg-blue-600"> <i class="fas fa-home mr-2"></i> Dashboard</a>
                <a href="#" class="block py-2.5 px-4 rounded hover:bg-slate-800 transition"> <i class="fas fa-car mr-2"></i> Đội xe</a>
                <a href="#" class="block py-2.5 px-4 rounded hover:bg-slate-800 transition"> <i class="fas fa-calendar-alt mr-2"></i> Đặt chỗ</a>
                <a href="#" class="block py-2.5 px-4 rounded hover:bg-slate-800 transition"> <i class="fas fa-users mr-2"></i> Khách hàng</a>
                <a href="#" class="block py-2.5 px-4 rounded hover:bg-slate-800 transition"> <i class="fas fa-chart-line mr-2"></i> Báo cáo</a>
            </nav>
        </aside>

        <main class="flex-1 flex flex-col overflow-y-auto">
            <header class="bg-white shadow px-6 py-4 flex justify-between items-center">
                <h1 class="text-xl font-semibold text-gray-800">Tổng quan hệ thống</h1>
                <div class="flex items-center space-x-4">
                    <button class="text-gray-500 hover:text-blue-600"><i class="fas fa-bell"></i></button>
                    <div class="w-10 h-10 bg-gray-300 rounded-full border border-gray-400"></div>
                </div>
            </header>

            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                    <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-blue-500">
                        <p class="text-sm text-gray-500 font-medium uppercase">Tổng số xe</p>
                        <p class="text-2xl font-bold">128</p>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-green-500">
                        <p class="text-sm text-gray-500 font-medium uppercase">Đang thuê</p>
                        <p class="text-2xl font-bold">42</p>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-yellow-500">
                        <p class="text-sm text-gray-500 font-medium uppercase">Cần bảo trì</p>
                        <p class="text-2xl font-bold">05</p>
                    </div>
                    <div class="bg-white p-6 rounded-xl shadow-sm border-l-4 border-purple-500">
                        <p class="text-sm text-gray-500 font-medium uppercase">Doanh thu ngày</p>
                        <p class="text-2xl font-bold">4.5M VNĐ</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="p-4 border-b border-gray-100 flex justify-between items-center">
                        <h2 class="font-bold text-gray-700">Đơn thuê xe gần đây</h2>
                        <button class="text-blue-600 text-sm hover:underline">Xem tất cả</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-gray-50 text-gray-600 text-sm uppercase">
                                <tr>
                                    <th class="px-6 py-3">Khách hàng</th>
                                    <th class="px-6 py-3">Mẫu xe</th>
                                    <th class="px-6 py-3">Ngày thuê</th>
                                    <th class="px-6 py-3">Trạng thái</th>
                                    <th class="px-6 py-3 text-right">Giá</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <tr>
                                    <td class="px-6 py-4 font-medium text-gray-900">Nguyễn Văn A</td>
                                    <td class="px-6 py-4">VinFast VF8</td>
                                    <td class="px-6 py-4 text-gray-500">29/04/2024</td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">Đã trả</span>
                                    </td>
                                    <td class="px-6 py-4 text-right font-bold">1.200.000đ</td>
                                </tr>
                                <tr>
                                    <td class="px-6 py-4 font-medium text-gray-900">Trần Thị B</td>
                                    <td class="px-6 py-4">Toyota Cross</td>
                                    <td class="px-6 py-4 text-gray-500">30/04/2024</td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-700">Đang đi</span>
                                    </td>
                                    <td class="px-6 py-4 text-right font-bold">900.000đ</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

</body>
</html>