@model RentalVehicleService.Models.PaymentViewModel
@{
    ViewData["Title"] = "Payment - SaigonRide";
}

@section Styles {
    <!-- Tailwind CSS and Font Integration -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Vehicle/payment.css" />

    <style>
        .pay-card.payment-disabled {
        opacity: 0.4;
        cursor: not-allowed;
        pointer-events: none;
        background-color: #f3f4f6;
        border-color: #d1d5db;
        }

        .pay-card.payment-disabled .check {
        display: none !important;
        }
    </style>
}

<div class="payment-wrapper">
    <div class="invoice-card p-8">

        <!-- Title -->
        <h1 class="invoice-title" data-i18n="pay_title">Thanh Toán</h1>

        <!-- ── Section: Customer Info ── -->
        <div class="mb-5">
            <p class="section-heading mb-3" data-i18n="pay_customer_info">Thông Tin Khách Hàng</p>
            <div class="customer-row">
                <span><span class="font-semibold" data-i18n="pay_name">Tên:</span> @Model.CustomerName</span>
                <span><span class="font-semibold" data-i18n="pay_phone">Số ĐT:</span> @Model.PhoneNumber</span>
                <span><span class="font-semibold" data-i18n="pay_email">Email:</span> @Model.Email</span>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Return Station ── -->
        <div class="mb-5">
            <p class="section-heading mb-3" data-i18n="pay_return_station">Trạm Trả Xe Hiện Tại</p>
            <div class="flex items-start gap-3">
                <div class="pin-wrap mt-0.5">
                    <svg width="18" height="22" viewBox="0 0 18 22" fill="none">
                        <path d="M9 0C4.59 0 1 3.59 1 8c0 6 8 14 8 14s8-8 8-14c0-4.41-3.59-8-8-8z" fill="#16a34a" />
                        <circle cx="9" cy="8" r="3" fill="#fff" />
                    </svg>
                </div>
                <div class="text-sm text-gray-700 leading-relaxed">
                    <p><span class="font-semibold" data-i18n="pay_station">Trạm Trả Xe:</span> @Model.EndStationName</p>
                    <p><span class="font-semibold" data-i18n="pay_address">Địa chỉ:</span> @Model.EndStationAddress</p>
                    <p><span class="font-semibold" data-i18n="pay_vehicle_id">Mã xe:</span> @Model.VehicleModel</p>
                </div>
            </div>
        </div>

        <!-- ── Time Row ── -->
        <div class="time-row mb-5">
            <div class="time-cell">
                <div class="time-label" data-i18n="pay_start_time">Thời gian bắt đầu:</div>
                <div class="time-value">@Model.StartTime.ToString("HH:mm")</div>
            </div>
            <div class="time-cell">
                <div class="time-label" data-i18n="pay_end_time">Thời gian kết thúc:</div>
                <div class="time-value">@Model.StartTime.AddMinutes(Model.TotalMinutes).ToString("HH:mm") (<span data-i18n="pay_estimated">dự kiến</span>)</div>
            </div>
            <div class="time-cell">
                <div class="time-label" data-i18n="pay_total_time">Tổng thời gian:</div>
                <div class="time-value">@Model.TotalMinutes <span data-i18n="pay_minutes">phút</span></div>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Fee Details ── -->
        <div class="mb-5">
            <div class="fee-section">
                <div class="fee-section-label">
                    <p class="section-heading" data-i18n="pay_fee_details">Chi Tiết Phí</p>
                </div>
                <div class="fee-rows">
                    <div class="fee-row">
                        <span class="fee-label"><span data-i18n="pay_time_fee">Phí thời gian</span> (@Model.TotalMinutes <span data-i18n="pay_minutes">phút</span> × @Model.UnitPrice.ToString("N0") VND/<span data-i18n="pay_minutes">phút</span>):</span>
                        <span class="fee-value">@((Model.TotalMinutes * Model.UnitPrice).ToString("N0")) VND</span>
                    </div>
                    @if (Model.DiscountAmount.HasValue && Model.DiscountAmount > 0)
                    {
                        <div class="fee-row">
                            <span class="fee-label" data-i18n="pay_discount_low_stock">Giảm giá trạm SL xe ít:</span>
                            <span class="fee-value discount">-@Model.DiscountAmount.Value.ToString("N0") VND</span>
                        </div>
                    }
                    <hr class="divider my-2" />
                    <div class="fee-row">
                        <span class="fee-total-label" data-i18n="pay_subtotal">Tổng phụ (Subtotal):</span>
                        <span class="fee-total-value">@(Model.FinalFare?.ToString("N0")) VND</span>
                    </div>
                </div>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Promo Code ── -->
        @* <div class="mb-5">
            <div class="coupon-wrap">
                <p class="section-heading" style="width:140px;flex-shrink:0;" data-i18n="pay_promo_code">Mã Giảm Giá</p>
                <div class="coupon-input-wrap">
                    <input class="coupon-input" id="couponInput" placeholder="Nhập mã..." value="" data-i18n="[placeholder]pay_promo_placeholder" />
                    <button type="button" onclick="applyCoupon()" class="coupon-btn" data-i18n="pay_apply">Áp dụng</button>
                </div>
            </div>
            <p class="coupon-msg text-green-600 ml-0" id="couponMsg"></p>
        </div>

        <hr class="divider mb-5" /> *@

        <!-- ── Grand Total ── -->
        <div class="grand-total-row">
            <p class="section-heading" style="font-size:0.97rem;" data-i18n="pay_grand_total">Tổng Cộng Phải Thanh Toán</p>
            <p class="grand-total-amount" id="grandTotal" data-i18n="pay_total_fare" data-i18n-param1="@(Model.FinalFare?.ToString("N0"))">Total: @(Model.FinalFare?.ToString("N0")) VND</p>
        </div>

        <!-- ── Section: Payment Method ── -->
        <div class="mb-7">
            <p class="section-heading mb-4" data-i18n="pay_select_method">Chọn Phương thức Thanh toán</p>
            <div class="pay-cards-wrap">

                <!-- VNPay -->
                <div class="pay-card selected" onclick="selectPay(this)" data-method="VNPay">
                    <span class="check">✓</span>
                    <div class="pay-card-logo">
                        <svg width="80" height="30" viewBox="0 0 80 30" fill="none">
                            <rect x="0" y="2" width="34" height="26" rx="5" fill="#1a237e" />
                            <rect x="36" y="2" width="44" height="26" rx="5" fill="#1565c0" />
                            <polygon points="10,15 17,7 24,15 17,23" fill="#e53935" />
                            <polygon points="17,7 24,15 17,23 10,15" fill="#b71c1c" opacity="0.4" />
                            <text x="38" y="20" font-size="11" font-weight="900" fill="#fff" font-family="Arial">VNPAY</text>
                        </svg>
                    </div>
                    <span class="pay-card-name" data-i18n="pay_vnpay">Ví VNPay</span>
                </div>

                <!-- PayPal -->
                <div class="pay-card" onclick="selectPay(this)" data-method="PayPal">
                    <span class="check">✓</span>
                    <div class="pay-card-logo">
                        <svg width="90" height="24" viewBox="0 0 90 24" fill="none">
                            <text x="0" y="19" font-size="18" font-weight="900" fill="#003087" font-family="Arial">Pay</text>
                            <text x="34" y="19" font-size="18" font-weight="900" fill="#009cde" font-family="Arial">Pal</text>
                        </svg>
                    </div>
                    <span class="pay-card-name" data-i18n="pay_paypal">Tài khoản PayPal</span>
                </div>

            </div>
        </div>
        <!-- ── Confirm Button ── -->
        <form asp-action="ProcessPayment" method="post" id="paymentForm">
            <input type="hidden" name="rentalId" value="@Model.RentalId" />
            <input type="hidden" name="paymentMethod" id="paymentMethodInput" value="VNPay" />
            <input type="hidden" name="couponCode" id="couponCodeInput" value="" />
            <button type="button" class="btn-confirm" onclick="submitPayment()" data-i18n="pay_confirm">
                Xác nhận &amp; Thanh toán
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const BASE_FARE = @(Model.FinalFare ?? 0);
        const RENTAL_ID = @Model.RentalId;
        let couponDiscount = 0;

        // 1. CHẠY KIỂM TRA NGAY KHI LOAD TRANG
        document.addEventListener("DOMContentLoaded", function () {
            checkPaymentMethodAvailability(BASE_FARE);
        });

        // 2. HÀM KIỂM TRA ĐIỀU KIỆN 5K
        function checkPaymentMethodAvailability(currentTotal) {
            const vnpayCard = document.querySelector('.pay-card[data-method="VNPay"]');
            const paypalCard = document.querySelector('.pay-card[data-method="PayPal"]');
            const paymentInput = document.getElementById('paymentMethodInput');

            if (!vnpayCard || !paypalCard) return;

            if (currentTotal < 5000) {
                vnpayCard.classList.add('payment-disabled');
                
                // Nếu đang chọn VNPay mà giá rớt xuống dưới 5k, tự đẩy qua PayPal
                if (paymentInput.value === 'VNPay') {
                    // Xóa class selected hiện tại
                    document.querySelectorAll('.pay-card').forEach(c => c.classList.remove('selected'));
                    // Chọn PayPal
                    paypalCard.classList.add('selected');
                    paymentInput.value = 'PayPal';
                }
            } else {
                vnpayCard.classList.remove('payment-disabled');
            }
        }

        function selectPay(el) {
            // Chặn click nếu thẻ đang bị vô hiệu hóa
            if (el.classList.contains('payment-disabled')) return;

            document.querySelectorAll('.pay-card').forEach(c => c.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('paymentMethodInput').value = el.dataset.method;
        }

        function applyCoupon() {
            const val = document.getElementById('couponInput').value.trim().toUpperCase();
            const msg = document.getElementById('couponMsg');
            document.getElementById('couponCodeInput').value = val;

            if (!val) { msg.textContent = ''; couponDiscount = 0; updateTotal(); return; }

            if (val === 'SAIGONGREEN20') {
                couponDiscount = 10000;
                msg.textContent = 'SAIGONGREEN20 (-10.000 VND)';
                msg.className = 'coupon-msg text-green-600';
            } else {
                couponDiscount = 0;
                msg.textContent = typeof getI18nText === 'function' ? getI18nText('pay_invalid_coupon') : 'Mã không hợp lệ.';
                msg.className = 'coupon-msg text-red-500';
            }
            updateTotal();
        }

        function updateTotal() {
            const total = Math.max(0, BASE_FARE - couponDiscount);
            const formattedTotal = total.toLocaleString('vi-VN');
            const el = document.getElementById('grandTotal');
            if (typeof getI18nText === 'function') {
                el.textContent = getI18nText('pay_total_fare').replace('{0}', formattedTotal);
                el.setAttribute('data-i18n-param1', formattedTotal);
            } else {
                el.textContent = 'Total: ' + formattedTotal + ' VND';
            }
            
            // 3. GỌI LẠI HÀM KIỂM TRA MỖI KHI CẬP NHẬT TỔNG TIỀN
            checkPaymentMethodAvailability(total);
        }

        async function submitPayment() {
            const paymentMethod = document.getElementById('paymentMethodInput').value;
            const totalAmount = Math.max(0, BASE_FARE - couponDiscount);

            // Chặn hoàn toàn hành động submit nếu logic bị qua mặt
            if (paymentMethod === 'VNPay' && totalAmount < 5000) {
                alert("Số tiền tối thiểu để thanh toán VNPay là 5.000 VND. Vui lòng chọn phương thức khác.");
                return;
            }

            if (paymentMethod === 'PayPal') {
                // Call PayPal API to create order
                const finalAmount = (totalAmount / 26310).toFixed(2);
                // Convert VND to USD (approximate)

                try {
                    const response = await fetch('/api/paypal/create-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            rentalId: RENTAL_ID,
                            amount: parseFloat(finalAmount),
                            currency: 'USD',
                            returnUrl: window.location.origin + `/Rental/PaypalReturn?rentalId=${RENTAL_ID}`,
                            cancelUrl: window.location.origin + `/Rental/Payment?id=${RENTAL_ID}`
                        })
                    });
                    const result = await response.json();
                    if (result.success && result.approveUrl) {
                        window.location.href = result.approveUrl;
                    } else {
                        alert('Failed to create PayPal order: ' + (result.error || 'Unknown error'));
                    }
                } catch (error) {
                    alert('Error creating PayPal order: ' + error.message);
                    console.error(error);
                }
            } else {
                // For other payment methods, submit form normally
                document.getElementById('paymentForm').submit();
            }
        }
    </script>
}