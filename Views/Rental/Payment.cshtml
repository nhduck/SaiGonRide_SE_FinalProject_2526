@model RentalVehicleService.Models.PaymentViewModel
@{
    ViewData["Title"] = "Payment - SaigonRide";
}

@section Styles {
    <!-- Tailwind CSS and Font Integration -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Vehicle/payment.css" />
}

<div class="payment-wrapper">
    <div class="invoice-card p-8">

        <!-- Title -->
        <h1 class="invoice-title">Thanh Toán</h1>

        <!-- ── Section: Customer Info ── -->
        <div class="mb-5">
            <p class="section-heading mb-3">Thông Tin Khách Hàng</p>
            <div class="customer-row">
                <span><span class="font-semibold">Tên:</span> @Model.CustomerName</span>
                <span><span class="font-semibold">Số ĐT:</span> @Model.PhoneNumber</span>
                <span><span class="font-semibold">Email:</span> @Model.Email</span>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Return Station ── -->
        <div class="mb-5">
            <p class="section-heading mb-3">Trạm Trả Xe Hiện Tại</p>
            <div class="flex items-start gap-3">
                <div class="pin-wrap mt-0.5">
                    <svg width="18" height="22" viewBox="0 0 18 22" fill="none">
                        <path d="M9 0C4.59 0 1 3.59 1 8c0 6 8 14 8 14s8-8 8-14c0-4.41-3.59-8-8-8z" fill="#16a34a" />
                        <circle cx="9" cy="8" r="3" fill="#fff" />
                    </svg>
                </div>
                <div class="text-sm text-gray-700 leading-relaxed">
                    <p><span class="font-semibold">Trạm Trả Xe:</span> @Model.EndStationName</p>
                    <p><span class="font-semibold">Địa chỉ:</span> @Model.EndStationAddress</p>
                    <p><span class="font-semibold">Mã xe:</span> @Model.VehicleModel</p>
                </div>
            </div>
        </div>

        <!-- ── Time Row ── -->
        <div class="time-row mb-5">
            <div class="time-cell">
                <div class="time-label">Thời gian bắt đầu:</div>
                <div class="time-value">@Model.StartTime.ToString("HH:mm")</div>
            </div>
            <div class="time-cell">
                <div class="time-label">Thời gian kết thúc:</div>
                <div class="time-value">@Model.StartTime.AddMinutes(Model.TotalMinutes).ToString("HH:mm") (dự kiến)</div>
            </div>
            <div class="time-cell">
                <div class="time-label">Tổng thời gian:</div>
                <div class="time-value">@Model.TotalMinutes phút</div>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Fee Details ── -->
        <div class="mb-5">
            <div class="fee-section">
                <div class="fee-section-label">
                    <p class="section-heading">Chi Tiết Phí</p>
                </div>
                <div class="fee-rows">
                    <div class="fee-row">
                        <span class="fee-label">Phí thời gian (@Model.TotalMinutes phút x 1.500 VND/phút):</span>
                        <span class="fee-value">@((Model.TotalMinutes * 1500).ToString("N0")) VND</span>
                    </div>
                    @if (Model.DiscountAmount.HasValue && Model.DiscountAmount > 0)
                    {
                        <div class="fee-row">
                            <span class="fee-label">Giảm giá trạm SL xe ít:</span>
                            <span class="fee-value discount">-@Model.DiscountAmount.Value.ToString("N0") VND</span>
                        </div>
                    }
                    <hr class="divider my-2" />
                    <div class="fee-row">
                        <span class="fee-total-label">Tổng phụ (Subtotal):</span>
                        <span class="fee-total-value">@(Model.FinalFare?.ToString("N0")) VND</span>
                    </div>
                </div>
            </div>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Section: Promo Code ── -->
        <div class="mb-5">
            <div class="coupon-wrap">
                <p class="section-heading" style="width:140px;flex-shrink:0;">Mã Giảm Giá</p>
                <div class="coupon-input-wrap">
                    <input class="coupon-input" id="couponInput" placeholder="Nhập mã..." value="" />
                    <button type="button" onclick="applyCoupon()" class="coupon-btn">Áp dụng</button>
                </div>
            </div>
            <p class="coupon-msg text-green-600 ml-0" id="couponMsg"></p>
        </div>

        <hr class="divider mb-5" />

        <!-- ── Grand Total ── -->
        <div class="grand-total-row">
            <p class="section-heading" style="font-size:0.97rem;">Tổng Cộng Phải Thanh Toán</p>
            <p class="grand-total-amount" id="grandTotal">Total: @(Model.FinalFare?.ToString("N0")) VND</p>
        </div>

        <!-- ── Section: Payment Method ── -->
        <div class="mb-7">
            <p class="section-heading mb-4">Chọn Phương thức Thanh toán</p>
            <div class="pay-cards-wrap">

                <!-- VNPay -->
                <div class="pay-card selected" onclick="selectPay(this)" data-method="VNPay">
                    <span class="check">✓</span>
                    <div class="pay-card-logo">
                        <svg width="80" height="30" viewBox="0 0 80 30" fill="none">
                            <rect x="0" y="2" width="34" height="26" rx="5" fill="#1a237e" />
                            <rect x="36" y="2" width="44" height="26" rx="5" fill="#1565c0" />
                            <polygon points="10,15 17,7 24,15 17,23" fill="#e53935" />
                            <polygon points="17,7 24,15 17,23 10,15" fill="#b71c1c" opacity="0.4" />
                            <text x="38" y="20" font-size="11" font-weight="900" fill="#fff" font-family="Arial">VNPAY</text>
                        </svg>
                    </div>
                    <span class="pay-card-name">Ví VNPay</span>
                </div>

                <!-- PayPal -->
                <div class="pay-card" onclick="selectPay(this)" data-method="PayPal">
                    <span class="check">✓</span>
                    <div class="pay-card-logo">
                        <svg width="90" height="24" viewBox="0 0 90 24" fill="none">
                            <text x="0" y="19" font-size="18" font-weight="900" fill="#003087" font-family="Arial">Pay</text>
                            <text x="34" y="19" font-size="18" font-weight="900" fill="#009cde" font-family="Arial">Pal</text>
                        </svg>
                    </div>
                    <span class="pay-card-name">Tài khoản PayPal</span>
                </div>

                <!-- MoMo -->
                <div class="pay-card" onclick="selectPay(this)" data-method="MoMo">
                    <span class="check">✓</span>
                    <div class="pay-card-logo">
                        <div style="background:#a50064;border-radius:10px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;">
                            <span style="font-weight:900;color:#fff;font-size:1rem;font-family:Arial;">mo</span>
                        </div>
                    </div>
                    <span class="pay-card-name">Ví MoMo</span>
                </div>

                <!-- Visa / Mastercard -->
                <div class="pay-card" onclick="selectPay(this)" data-method="Card">
                    <span class="check">✓</span>
                    <div class="pay-card-logo" style="gap:6px;">
                        <svg width="44" height="28" viewBox="0 0 44 28" fill="none">
                            <rect width="44" height="28" rx="4" fill="#1a1f71" />
                            <text x="5" y="20" font-size="12" font-weight="900" fill="#fff" font-family="Arial" letter-spacing="1">VISA</text>
                        </svg>
                        <svg width="34" height="28" viewBox="0 0 34 28" fill="none">
                            <circle cx="13" cy="14" r="12" fill="#eb001b" />
                            <circle cx="21" cy="14" r="12" fill="#f79e1b" />
                            <path d="M17 5.3a12 12 0 010 17.4A12 12 0 0117 5.3z" fill="#ff5f00" />
                        </svg>
                    </div>
                    <span class="pay-card-name">Thẻ Quốc tế</span>
                </div>

            </div>
        </div>

        <!-- ── Confirm Button ── -->
        <form asp-action="ProcessPayment" method="post">
            <input type="hidden" name="rentalId" value="@Model.RentalId" />
            <input type="hidden" name="paymentMethod" id="paymentMethodInput" value="VNPay" />
            <input type="hidden" name="couponCode" id="couponCodeInput" value="" />
            <button type="submit" class="btn-confirm">
                Xác nhận &amp; Thanh toán
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        const BASE_FARE = @(Model.FinalFare ?? 0);
        let couponDiscount = 0;

        function selectPay(el) {
            document.querySelectorAll('.pay-card').forEach(c => c.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('paymentMethodInput').value = el.dataset.method;
        }

        function applyCoupon() {
            const val = document.getElementById('couponInput').value.trim().toUpperCase();
            const msg = document.getElementById('couponMsg');
            document.getElementById('couponCodeInput').value = val;

            if (!val) {
                msg.textContent = '';
                couponDiscount = 0;
                updateTotal();
                return;
            }

            if (val === 'SAIGONGREEN20') {
                couponDiscount = 10000;
                msg.textContent = 'SAIGONGREEN20 (-10.000 VND)';
                msg.className = 'coupon-msg text-green-600';
            } else {
                couponDiscount = 0;
                msg.textContent = 'Mã không hợp lệ.';
                msg.className = 'coupon-msg text-red-500';
            }
            updateTotal();
        }

        function updateTotal() {
            const total = Math.max(0, BASE_FARE - couponDiscount);
            document.getElementById('grandTotal').textContent =
                'Total: ' + total.toLocaleString('vi-VN') + ' VND';
        }
    </script>
}
