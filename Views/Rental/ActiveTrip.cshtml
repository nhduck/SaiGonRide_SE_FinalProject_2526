@model RentalVehicleService.Models.Rental
@{
    ViewData["Title"] = "Active Trip - SaigonRide";
    Layout = "_Layout";

    if (Model == null)
    {
        <p>Loading trip information...</p>
        return;
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Vehicle/activeTrip.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="active-trip-container">
    <div class="container py-4">
        <!-- Status Header -->
        <div class="trip-header mb-4">
            <h1 class="fw-bold">Current Rental</h1>
            <div class="d-flex align-items-center gap-3 mt-2">
                <span class="status-badge">
                    <span class="dot">●</span> TRIP IN PROGRESS
                </span>
                <span class="trip-id text-white-50">#SR-1234</span>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Column: Main Dashboard -->
            <div class="col-lg-8">
                <div class="main-dashboard-card text-center d-flex flex-column justify-content-between">
                    <div>
                        <div class="timer-display" id="timer">00 : 00 : 00</div>

                        <div class="row stats-row mt-4">
                            <!-- Cột Quãng đường -->
                            <div class="col-6 border-end">
                                <p class="stat-label">Distance</p>
                                <p class="stat-sub-label">Trip Length</p>
                                <h3 class="stat-value" id="distance">0.00 km</h3>
                            </div>
        
                            <!-- Cột Tính tiền -->
                            <div class="col-6">
                                <p class="stat-label">Estimated Cost</p>
                                <p class="stat-sub-label">Current Charges</p>
                                <!-- Truyền data-price-per-minute cho JS -->
                                <h3 class="stat-value" id="cost" data-price-per-minute="@(Model.Vehicle?.Price ?? 1000)">0 VND</h3>
                            </div>
                        </div>
                    </div>

                    <div class="action-buttons mt-5">
                        <form asp-action="Edit" asp-controller="Rental" method="post">
                            <input type="hidden" name="id" value="@Model.RentalId" />

                            <div class="dropoff-section mb-4">
                                <label class="dropoff-label"><i class="fas fa-map-marker-alt text-danger me-2"></i>Select Drop-off Station:</label>
                                <select name="endStationId" class="form-select border-success" required>
                                    <option value="">-- Choose a station to drop bike --</option>
                                    <option value="1">Trạm Bến Thành</option>
                                    <option value="2">Trạm Bến Nhà Rồng</option>
                                    <option value="3">Trạm Thảo Cầm Viên</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-end-trip w-100 mb-3">
                                <i class="far fa-dot-circle me-1"></i> FINISH TRIP
                            </button>
                        </form>

                        <button type="button" class="btn btn-lock-temporary w-100">
                            <i class="fas fa-lock me-1"></i> Temporary Lock
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Column: Bike Info & Map -->
            <div class="col-lg-4 d-flex flex-column gap-4">
                <!-- Bike Preview Card -->
                <div class="info-card bike-preview-card">
                    <span class="bike-tag">SR-2024</span>
                    <img src="~/img/green-bike-side.png" alt="SaigonRide Bike" class="img-fluid bike-img">
                </div>

                <!-- Battery Status Card -->
                <div class="info-card battery-card">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold text-dark">Battery Level</span>
                        <span class="fw-bold text-success">85%</span>
                    </div>
                    <div class="progress mb-2" style="height: 10px; border-radius: 5px;">
                        <div class="progress-bar bg-success" style="width: 85%"></div>
                    </div>
                    <small class="text-muted"><i class="fas fa-bolt text-warning me-1"></i> Approx. 30 km left</small>
                </div>

                <!-- Live Map Card -->
                <div class="info-card map-card overflow-hidden">
                    <div id="trip-map" style="height: 180px; background: #e9ecef;">
                        <img src="~/img/map-mockup.png" class="w-100 h-100" style="object-fit: cover;" alt="Route Map" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/rentalManager.js" asp-append-version="true"></script>
}