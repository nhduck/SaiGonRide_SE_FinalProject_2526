@model RentalVehicleService.Models.Rental

@{
    ViewData["Title"] = "Confirm Ride - SaigonRide";
}

<div class="container mt-5">
    <div class="card mx-auto shadow-sm" style="max-width: 450px; border-radius: 20px; border: none;">
        <div class="card-header bg-success text-white text-center py-3" style="border-radius: 20px 20px 0 0;">
            <h4 class="mb-0">Ready to Ride?</h4>
        </div>

        <div class="card-body p-4 text-center">
            <!-- Thông tin tóm tắt từ ViewBag (đã lấy ở Controller) -->
            <div class="mb-4">
                <h6 class="text-muted text-uppercase small">Station</h6>
                <p class="fw-bold fs-5 text-dark">@ViewBag.StationAddress</p>
            </div>

            <div class="mb-4">
                <h6 class="text-muted text-uppercase small">Vehicle</h6>
                <p class="fw-bold fs-5 text-dark">@ViewBag.VehicleModel</p>
            </div>

            <div class="alert alert-light border-0" style="background-color: #f8f9fa; border-radius: 15px;">
                <p class="mb-1 text-muted">Price Rate</p>
                <span class="fw-bold text-success">1,500 VND / min</span>
            </div>

            <!-- Form gửi lệnh POST -->
            <form action="/Rental/Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" name="vehicleId" value="@ViewBag.VehicleId" />
                <input type="hidden" name="startStationId" value="@ViewBag.StartStationId" />

                <input type="hidden" name="confirm" value="true" />

                <!-- Nút bấm chính -->
                <button type="submit" class="btn btn-success btn-lg w-100 py-3 mt-3"
                        style="border-radius: 30px; font-weight: bold; letter-spacing: 1px; box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);">
                    START TRIP NOW
                </button>
            </form>

            <a asp-action="Index" asp-controller="Home" class="btn btn-link text-muted mt-3">Cancel</a>
        </div>
    </div>
</div>

