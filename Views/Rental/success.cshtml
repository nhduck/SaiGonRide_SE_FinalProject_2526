@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thanh toán thành công - SaigonRide</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  
  <link rel="stylesheet" href="~/css/Vehicle/success.css" />
</head>
<body class="flex flex-col">

<main class="flex-grow flex items-center justify-center px-4 py-12">
  <div class="max-w-md w-full flex flex-col items-center">

    <div class="text-center mb-8">
      <div class="check-circle">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
          <path d="M10 27L21 38L42 16" stroke="#FFD700" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1 class="font-black text-3xl text-gray-900 mb-1 success-title" data-i18n="pay_success_title">Thanh toán thành công!</h1>
      <p class="text-gray-500 font-medium text-lg" data-i18n="pay_success_subtitle">Payment Successful!</p>
    </div>

    <div class="congrats-card w-full mb-8 text-left">
      <p class="font-bold text-gray-900 text-[15px] mb-2" data-i18n="pay_congrats">Chúc mừng bạn đã hoàn thành chuyến đi!</p>
      <p class="text-gray-600 text-sm" data-i18n="pay_thanks">Cảm ơn bạn vì đã lựa chọn SaigonRide để Move Green.</p>
    </div>

    <div class="w-full">
      <a href="@Url.Action("Index", "Home")" class="btn-home no-underline">
        🏠 <span data-i18n="pay_back_home">Về trang chủ</span>
      </a>
    </div>

  </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/i18n.js"></script>
</body>
</html>