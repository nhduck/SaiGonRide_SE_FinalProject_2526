@model RentalVehicleService.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Log In";
    ViewData["MetaDescription"] = "Log in to your SaigonRide account to rent bikes and e-scooters across Ho Chi Minh City.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    .sr-login-page { min-height: 100vh; display: flex; }
    .sr-login-left {
        background: linear-gradient(155deg, #064e3b 0%, #065f46 45%, #047857 80%, #065f46 100%);
        display: flex; flex-direction: column; justify-content: center;
        align-items: center; padding: 4rem 3rem; position: relative; overflow: hidden;
    }
    .sr-login-left::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03' fill-rule='evenodd'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
    }
    .login-blob {
        position: absolute; border-radius: 50%;
        filter: blur(70px); pointer-events: none;
    }
    .login-blob-1 { width:350px;height:350px;background:rgba(74,222,128,.2);top:-100px;right:-80px; }
    .login-blob-2 { width:250px;height:250px;background:rgba(14,165,233,.15);bottom:-60px;left:-60px; }

    @@keyframes shake-x {
        0%,100% { transform:translateX(0); }
        20%      { transform:translateX(-6px); }
        40%      { transform:translateX(6px); }
        60%      { transform:translateX(-4px); }
        80%      { transform:translateX(4px); }
    }
    .shake { animation: shake-x .4s ease; }

    .sr-login-right {
        display: flex; align-items: center; justify-content: center;
        padding: 3rem 2rem; flex: 1;
    }
    .sr-login-card {
        width: 100%; max-width: 440px;
        background: var(--sr-card-bg);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.04);
        padding: 2.75rem 2.5rem;
        animation: cardIn .5s cubic-bezier(.4,0,.2,1) both;
    }
    @@keyframes cardIn {
        from { opacity:0;transform:translateY(24px) scale(.97); }
        to   { opacity:1;transform:none; }
    }
    .sr-divider {
        display:flex;align-items:center;gap:1rem;color:#94a3b8;
        font-size:.82rem;margin:1.25rem 0;
    }
    .sr-divider::before,.sr-divider::after {
        content:'';flex:1;height:1px;background:var(--sr-card-border);
    }
</style>

<div class="sr-login-page">
    <!-- Left panel -->
    <div class="col-lg-5 d-none d-lg-block sr-login-left">
        <div class="login-blob login-blob-1"></div>
        <div class="login-blob login-blob-2"></div>

        <div class="text-center position-relative" style="z-index:1;">
            <!-- Logo -->
            <div class="d-flex align-items-center justify-content-center gap-2 mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
                     stroke="#4ade80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="5.5" cy="17.5" r="3.5"/>
                    <circle cx="18.5" cy="17.5" r="3.5"/>
                    <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                </svg>
                <span class="text-white fw-bold fs-4">SaigonRide</span>
            </div>

            <!-- SVG BIKE ANIMATION -->
            <div class="sr-bike-scene mx-auto mb-4" style="position:relative;width:280px;height:180px;">
                <!-- Speed lines -->
                <div class="sr-speed-lines" style="bottom:40px;left:-60px;">
                    <svg width="70" height="50" viewBox="0 0 70 50" fill="none">
                        <line x1="0" y1="8" x2="60" y2="8" stroke="rgba(74,222,128,0.5)" stroke-width="2" stroke-linecap="round"/>
                        <line x1="0" y1="19" x2="50" y2="19" stroke="rgba(74,222,128,0.3)" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="0" y1="30" x2="65" y2="30" stroke="rgba(74,222,128,0.2)" stroke-width="1" stroke-linecap="round"/>
                    </svg>
                </div>

                <!-- Dust -->
                <div class="sr-dust-wrap" style="bottom:20px;left:-5px;">
                    <svg width="50" height="25" viewBox="0 0 50 25">
                        <circle cx="8" cy="18" r="4" fill="rgba(74,222,128,0.25)"/>
                        <circle cx="20" cy="13" r="3" fill="rgba(74,222,128,0.18)"/>
                        <circle cx="34" cy="19" r="3.5" fill="rgba(74,222,128,0.12)"/>
                    </svg>
                </div>

                <!-- Bike SVG -->
                <div class="sr-bike-svg-wrap" style="bottom:20px;right:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 200" width="260" height="165" style="overflow:visible;">
                        <defs>
                            <linearGradient id="loginFrameGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#4ade80;stop-opacity:1"/>
                                <stop offset="50%" style="stop-color:#16a34a;stop-opacity:1"/>
                                <stop offset="100%" style="stop-color:#14532d;stop-opacity:1"/>
                            </linearGradient>
                            <filter id="loginGlow">
                                <feGaussianBlur stdDeviation="2" result="blur"/>
                                <feComposite in="SourceGraphic" in2="blur" operator="over"/>
                            </filter>
                            <filter id="loginShadow">
                                <feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="#166534" flood-opacity="0.5"/>
                            </filter>
                        </defs>
                        <!-- Rear wheel -->
                        <g transform="translate(82,148)">
                            <g>
                                <animateTransform attributeName="transform" type="rotate"
                                    from="0 0 0" to="360 0 0"
                                    dur="0.45s" begin="1.75s" repeatCount="indefinite"/>
                                <circle r="52" fill="#111827" stroke="#1f2937" stroke-width="2"/>
                                <circle r="46" fill="none" stroke="#374151" stroke-width="4"/>
                                <circle r="41" fill="#1a1f2e" stroke="#374151" stroke-width="1.5"/>
                                <circle r="6" fill="#374151" stroke="#6b7280" stroke-width="1.5"/>
                                <circle r="3" fill="#9ca3af"/>
                                <g stroke="#6b7280" stroke-width="1.3" opacity="0.8">
                                    <line x1="0" y1="-6" x2="0" y2="-41"/>
                                    <line x1="0" y1="6" x2="0" y2="41"/>
                                    <line x1="-6" y1="0" x2="-41" y2="0"/>
                                    <line x1="6" y1="0" x2="41" y2="0"/>
                                    <line x1="-4" y1="-4" x2="-29" y2="-29"/>
                                    <line x1="4" y1="-4" x2="29" y2="-29"/>
                                    <line x1="-4" y1="4" x2="-29" y2="29"/>
                                    <line x1="4" y1="4" x2="29" y2="29"/>
                                </g>
                                <circle r="16" fill="none" stroke="#374151" stroke-width="7" stroke-dasharray="5 3" opacity="0.55"/>
                            </g>
                        </g>
                        <g transform="translate(238,148)">
                            <g>
                                <animateTransform attributeName="transform" type="rotate"
                                    from="0 0 0" to="360 0 0"
                                    dur="0.45s" begin="1.75s" repeatCount="indefinite"/>
                                <circle r="52" fill="#111827" stroke="#1f2937" stroke-width="2"/>
                                <circle r="46" fill="none" stroke="#374151" stroke-width="4"/>
                                <circle r="41" fill="#1a1f2e" stroke="#374151" stroke-width="1.5"/>
                                <circle r="6" fill="#374151" stroke="#6b7280" stroke-width="1.5"/>
                                <circle r="3" fill="#9ca3af"/>
                                <g stroke="#6b7280" stroke-width="1.3" opacity="0.8">
                                    <line x1="0" y1="-6" x2="0" y2="-41"/>
                                    <line x1="0" y1="6" x2="0" y2="41"/>
                                    <line x1="-6" y1="0" x2="-41" y2="0"/>
                                    <line x1="6" y1="0" x2="41" y2="0"/>
                                    <line x1="-4" y1="-4" x2="-29" y2="-29"/>
                                    <line x1="4" y1="-4" x2="29" y2="-29"/>
                                    <line x1="-4" y1="4" x2="-29" y2="29"/>
                                    <line x1="4" y1="4" x2="29" y2="29"/>
                                </g>
                                <circle r="16" fill="none" stroke="#374151" stroke-width="7" stroke-dasharray="5 3" opacity="0.55"/>
                            </g>
                        </g>
                        <!-- Body -->
                        <g class="sr-bike-body-group">
                            <line x1="82" y1="148" x2="158" y2="153" stroke="url(#loginFrameGrad)" stroke-width="7" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <circle cx="158" cy="153" r="9" fill="#1f2937" stroke="#374151" stroke-width="2"/>
                            <circle cx="158" cy="153" r="17" fill="none" stroke="#4b5563" stroke-width="2.5" stroke-dasharray="4 3"/>
                            <circle cx="158" cy="153" r="6" fill="#374151" stroke="#6b7280" stroke-width="1.5"/>
                            <line x1="158" y1="153" x2="148" y2="90" stroke="url(#loginFrameGrad)" stroke-width="8" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <line x1="212" y1="97" x2="158" y2="153" stroke="url(#loginFrameGrad)" stroke-width="8" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <line x1="148" y1="90" x2="212" y2="97" stroke="url(#loginFrameGrad)" stroke-width="7" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <line x1="148" y1="90" x2="82" y2="148" stroke="url(#loginFrameGrad)" stroke-width="6" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <line x1="212" y1="97" x2="238" y2="148" stroke="url(#loginFrameGrad)" stroke-width="7" stroke-linecap="round" filter="url(#loginShadow)"/>
                            <rect x="206" y="89" width="12" height="22" rx="5" fill="url(#loginFrameGrad)" stroke="#166534" stroke-width="1"/>
                            <text x="175" y="141" font-family="Arial" font-size="8.5" font-weight="900" fill="rgba(255,255,255,0.92)"
                                  transform="rotate(-46,175,141)" letter-spacing="0.6">SaigonRide</text>
                            <line x1="148" y1="90" x2="141" y2="70" stroke="#374151" stroke-width="5" stroke-linecap="round"/>
                            <path d="M 125 69 Q 141 64 157 68 Q 149 73 141 72 Q 133 73 125 69 Z" fill="#1f2937" stroke="#4b5563" stroke-width="1.5"/>
                            <line x1="212" y1="93" x2="224" y2="79" stroke="#374151" stroke-width="5" stroke-linecap="round"/>
                            <path d="M 218 77 Q 224 73 230 75 Q 236 79 238 87 Q 236 91 232 89" fill="none" stroke="#1f2937" stroke-width="5" stroke-linecap="round"/>
                            <circle cx="188" cy="118" r="3.5" fill="rgba(74,222,128,0.7)" filter="url(#loginGlow)"/>
                        </g>
                    </svg>
                </div>

                <!-- Glow ring -->
                <div class="sr-glow-ring"></div>
                <!-- Lightning burst -->
                <div class="sr-lightning-burst" style="top:-15px;right:60px;">
                    <svg width="48" height="64" viewBox="0 0 60 80" fill="none">
                        <polygon points="35,0 20,38 32,38 18,80 50,28 36,28 52,0" fill="#facc15" opacity="0.95"/>
                    </svg>
                </div>
                <!-- Mini lightning -->
                <div class="sr-mini-lightning" style="top:-10px;right:72px;">
                    <svg width="22" height="30" viewBox="0 0 28 38" fill="none">
                        <polygon points="17,0 9,18 15,18 8,38 24,13 17,13 25,0" fill="#facc15"/>
                    </svg>
                </div>
                <!-- Sparks -->
                <div class="sr-idle-sparks" style="top:15px;right:55px;">
                    <div class="sr-spark"></div>
                    <div class="sr-spark"></div>
                    <div class="sr-spark"></div>
                    <div class="sr-spark"></div>
                </div>
            </div>

            <h3 class="text-white fw-bold mb-2" style="font-size:1.7rem;" data-i18n="auth_login_welcome">Welcome Back, Rider!</h3>
            <p class="text-white-50 mb-4" style="max-width:300px;line-height:1.65;font-size:.95rem;margin:auto;" data-i18n="auth_login_subtitle">
                Log in to continue your green journey across Saigon.
            </p>

            <!-- Stats badges -->
            <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">
                <div class="sr-glass px-3 py-2 text-center">
                    <div class="text-white fw-bold fs-5">50+</div>
                    <div class="text-white-50" style="font-size:.75rem;" data-i18n="auth_stats_stations">Stations</div>
                </div>
                <div class="sr-glass px-3 py-2 text-center">
                    <div class="text-white fw-bold fs-5">500+</div>
                    <div class="text-white-50" style="font-size:.75rem;" data-i18n="auth_stats_vehicles">Vehicles</div>
                </div>
                <div class="sr-glass px-3 py-2 text-center">
                    <div class="text-white fw-bold fs-5">24/7</div>
                    <div class="text-white-50" style="font-size:.75rem;" data-i18n="auth_stats_support">Support</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: form -->
    <div class="col-12 col-lg-7 sr-login-right">
        <div class="sr-login-card">
            <div class="text-center mb-4">
                <div class="d-lg-none mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
                         stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="5.5" cy="17.5" r="3.5"/>
                        <circle cx="18.5" cy="17.5" r="3.5"/>
                        <path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>
                    </svg>
                </div>
                <h2 class="fw-bold mb-1" style="font-size:1.6rem;" data-i18n="auth_login_header">Log In</h2>
                <p class="text-muted mb-0" style="font-size:.9rem;"><span data-i18n="auth_login_subheader">Welcome back!</span> <span>👋</span></p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert d-flex align-items-center gap-2 rounded-3 mb-4 py-2 border-0"
                     style="background:rgba(22,163,74,0.1);color:var(--sr-green);">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    @TempData["SuccessMessage"]
                </div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert d-flex align-items-start gap-2 rounded-3 mb-4 py-2 border-0 shake"
                     id="loginError" style="background:rgba(239,68,68,0.1);color:#ef4444;">
                    <i class="bi bi-exclamation-triangle-fill fs-5 mt-1"></i>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <form asp-action="Login" method="post" id="loginForm">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold" style="font-size:.875rem;" data-i18n="auth_email">Email</label>
                    <div class="input-group sr-input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control py-2" data-i18n="[placeholder]auth_email_placeholder" placeholder="name@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold" style="font-size:.875rem;" data-i18n="auth_password">Password</label>
                    <div class="input-group sr-input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control py-2" placeholder="••••••••"
                               id="loginPassword" autocomplete="current-password" />
                        <button class="btn btn-outline-secondary border-start-0" type="button"
                                onclick="togglePwd('loginPassword', this)" tabindex="-1">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check mb-0">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe">
                        <label class="form-check-label text-muted" for="rememberMe" style="font-size:.875rem;" data-i18n="auth_remember_me">
                            Remember me
                        </label>
                    </div>
                    <a asp-action="ForgotPassword" class="text-sr-green text-decoration-none fw-medium" style="font-size:.875rem;" data-i18n="auth_forgot_pwd">
                        Forgot password?
                    </a>
                </div>

                <button type="submit" class="btn btn-success w-100 py-2 fw-bold rounded-3 mb-3"
                        id="loginBtn" style="font-size:1rem;letter-spacing:.02em;box-shadow:0 4px 16px rgba(22,163,74,.3);">
                    <i class="bi bi-box-arrow-in-right me-2"></i><span data-i18n="auth_login_btn">Log In</span>
                </button>
            </form>

            <div class="sr-divider" data-i18n="auth_or">OR</div>

            <div class="text-center">
                <span class="text-muted" style="font-size:.9rem;" data-i18n="auth_no_account">Don't have an account?</span>
                <a asp-controller="Account" asp-action="Register"
                   class="fw-bold text-sr-green text-decoration-none ms-1" style="font-size:.9rem;">
                    <span data-i18n="auth_register_link">Register free</span> <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <p class="text-center text-muted mt-4 mb-0" style="font-size:.75rem;">
                <span data-i18n="auth_policy_agree">By logging in, you agree to our</span>
                <a href="/Home/Privacy" class="text-sr-green text-decoration-none" data-i18n="auth_privacy_policy">Privacy Policy</a>
                <span data-i18n="admin_and">and</span>
                <a href="/Home/Privacy" class="text-sr-green text-decoration-none" data-i18n="auth_terms_of_service">Terms of Service</a>.
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd(id, btn) {
        const inp = document.getElementById(id);
        const ico = btn.querySelector('i');
        inp.type = inp.type === 'password' ? 'text' : 'password';
        ico.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
    }
    document.getElementById('loginForm')?.addEventListener('submit', function () {
        const btn = document.getElementById('loginBtn');
        const loggingInText = typeof getI18nText === 'function' ? getI18nText('auth_logging_in') : 'Logging in...';
        btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>${loggingInText}`;
        btn.disabled = true;
    });
</script>
}
