@model RentalVehicleService.Models.ViewModels.ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="sr-auth-page">
    <!-- Left Panel -->
    <div class="col-lg-5 d-none d-lg-flex sr-auth-left">
        <div class="text-center px-4">
            <div class="mb-4">
                <img src="/images/security-guard.png" alt="Security Guard" class="img-fluid shadow-lg" style="max-width: 280px; border-radius: 32px; transform: perspective(1000px) rotateY(-5deg);">
            </div>
            <h1 class="display-5 fw-bold mb-3" data-i18n="auth_reset_header_left">Security First!</h1>
            <p class="lead opacity-75" data-i18n="auth_reset_subtitle_left">Enter the 6-digit code we sent to your email and choose a strong new password to secure your account.</p>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="col-12 col-lg-7 sr-auth-right">
        <div class="sr-auth-card">
            <a href="/" class="sr-auth-logo">
                <img src="/favicon.svg" width="40" height="40" alt="Logo">
                <span>SaigonRide</span>
            </a>

            <h2 class="sr-auth-title" data-i18n="auth_reset_header">Reset Your Password</h2>
            <p class="sr-auth-subtitle" data-i18n="auth_reset_subheader">Complete the form below to set a new password.</p>

            <div class="alert alert-warning d-flex align-items-center gap-2 mb-4 rounded-4 border-0 py-3">
                <i class="bi bi-info-circle-fill"></i>
                <small data-i18n="auth_otp_sent_msg">We've sent a 6-digit OTP to your email. It expires in 3 minutes.</small>
            </div>

            <form asp-action="ResetPassword" method="post" id="resetPasswordForm">
                <input type="hidden" asp-for="Email" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <!-- OTP Step -->
                <div id="otpStep" style="@(ViewData.ModelState.ErrorCount > 0 && ViewData.ModelState.ContainsKey("OTP") == false ? "display:none;" : "")">
                    <label class="form-label fw-semibold" data-i18n="auth_otp_code">OTP Code</label>
                    <div class="sr-auth-input-group input-group mb-2">
                        <span class="input-group-text"><i class="bi bi-hash"></i></span>
                        <input asp-for="OTP" id="otpInput" class="form-control text-center fw-bold letter-spacing-lg" 
                               placeholder="0 0 0 0 0 0" maxlength="6" style="font-size: 1.25rem;" required />
                    </div>
                    <div id="otpError" class="text-danger small mb-3" style="display:none;" data-i18n="auth_otp_invalid">Invalid or expired OTP code.</div>
                    
                    <button type="button" id="verifyOtpBtn" class="btn btn-sr-green w-100 sr-auth-btn mb-4">
                        <i class="bi bi-shield-check me-2"></i>
                        <span data-i18n="auth_verify_otp">Verify OTP</span>
                    </button>
                </div>

                <!-- Password Step (Hidden by default) -->
                <div id="passwordStep" style="@(ViewData.ModelState.ErrorCount > 0 && ViewData.ModelState.ContainsKey("OTP") == false ? "" : "display:none;")">
                    <div class="mb-4 text-success d-flex align-items-center gap-2 small fw-semibold">
                        <i class="bi bi-check-circle-fill"></i>
                        <span data-i18n="auth_otp_verified">OTP Verified</span>
                    </div>

                    <label class="form-label fw-semibold" data-i18n="auth_new_password">New Password</label>
                    <div class="sr-auth-input-group input-group mb-1">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="NewPassword" id="newPassword" type="password" class="form-control" placeholder="••••••••" required />
                        <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePassword(this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div id="passwordStrengthError" class="text-danger small mb-3" style="display:none;" data-i18n="auth_password_strength_error">Password must be at least 8 characters long and include letters, numbers, and special characters.</div>

                    <label class="form-label fw-semibold" data-i18n="auth_confirm_new_password">Confirm New Password</label>
                    <div class="sr-auth-input-group input-group mb-1">
                        <span class="input-group-text"><i class="bi bi-check2-circle"></i></span>
                        <input asp-for="ConfirmPassword" id="confirmPassword" type="password" class="form-control" placeholder="••••••••" required />
                        <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePassword(this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div id="passwordMismatchError" class="text-danger small mb-4" style="display:none;" data-i18n="auth_password_mismatch">Passwords do not match.</div>

                    <button type="submit" id="resetBtn" class="btn btn-sr-green w-100 sr-auth-btn mb-4">
                        <i class="bi bi-check-circle me-2"></i>
                        <span data-i18n="auth_reset_btn">Reset Password</span>
                    </button>
                </div>

                <div class="sr-auth-footer">
                    <a asp-action="Login" class="text-decoration-none text-sr-green fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i>
                        <span data-i18n="auth_back_to_login">Back to Log In</span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(btn) {
            const input = btn.parentElement.querySelector('input');
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        function validatePasswordStrength(password) {
            const minLength = 8;
            const hasLetter = /[a-zA-Z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSpecial = /[!@@#$%^&*(),.?":{}|<>]/.test(password);
            return password.length >= minLength && hasLetter && hasNumber && hasSpecial;
        }

        $(document).ready(function() {
            $('#verifyOtpBtn').click(function() {
                const btn = $(this);
                const otp = $('#otpInput').val();
                const email = $('input[name="Email"]').val();
                const otpError = $('#otpError');

                if (!otp || otp.length < 6) return;

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>' + (window.getI18nText ? getI18nText('auth_verifying') : 'Verifying...'));
                otpError.hide();

                $.ajax({
                    url: '/Account/VerifyResetOTP',
                    type: 'POST',
                    data: { email: email, otp: otp },
                    success: function(resp) {
                        if (resp.success) {
                            $('#otpStep').fadeOut(300, function() {
                                $('#passwordStep').fadeIn(300);
                            });
                        } else {
                            otpError.text(resp.message || (window.getI18nText ? getI18nText('auth_otp_invalid') : 'Invalid OTP')).show();
                            btn.prop('disabled', false).html('<i class="bi bi-shield-check me-2"></i><span data-i18n="auth_verify_otp">' + (window.getI18nText ? getI18nText('auth_verify_otp') : 'Verify OTP') + '</span>');
                        }
                    },
                    error: function() {
                        otpError.text('Connection error.').show();
                        btn.prop('disabled', false).html('<i class="bi bi-shield-check me-2"></i><span data-i18n="auth_verify_otp">' + (window.getI18nText ? getI18nText('auth_verify_otp') : 'Verify OTP') + '</span>');
                    }
                });
            });

            $('#resetPasswordForm').on('submit', function(e) {
                const password = $('#newPassword').val();
                const confirm = $('#confirmPassword').val();
                let isValid = true;

                // Strength check
                if (!validatePasswordStrength(password)) {
                    $('#passwordStrengthError').show();
                    isValid = false;
                } else {
                    $('#passwordStrengthError').hide();
                }

                // Match check
                if (password !== confirm) {
                    $('#passwordMismatchError').show();
                    isValid = false;
                } else {
                    $('#passwordMismatchError').hide();
                }

                if (!isValid) {
                    e.preventDefault();
                    return false;
                }

                $('#resetBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>' + (window.getI18nText ? getI18nText('auth_verifying') : 'Processing...'));
            });

            // Handle Enter key on OTP input
            $('#otpInput').on('keypress', function(e) {
                if (e.which == 13) {
                    e.preventDefault();
                    $('#verifyOtpBtn').click();
                }
            });
        });
    </script>
}
