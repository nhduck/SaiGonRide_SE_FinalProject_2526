@model RentalVehicleService.Models.ViewModels.RegisterConfirmViewModel

@{
    ViewData["Title"] = "Verify Email";
}

<style>
    .verify-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #064e3b 0%, #0f172a 50%, #1e1b4b 100%);
        position: relative;
        overflow: hidden;
        padding: 2rem 1rem;
    }

    .verify-wrapper::before {
        content: '';
        position: absolute;
        top: -120px;
        right: -120px;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: rgba(22, 163, 74, .15);
        filter: blur(80px);
    }

    .verify-wrapper::after {
        content: '';
        position: absolute;
        bottom: -80px;
        left: -80px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: rgba(14, 165, 233, .1);
        filter: blur(60px);
    }

    .verify-card {
        background: rgba(255, 255, 255, .06);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, .12);
        border-radius: 24px;
        padding: 48px 40px;
        width: 100%;
        max-width: 460px;
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 50px rgba(0, 0, 0, .25);
    }

    .verify-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #16a34a, #22d3ee);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 2rem;
        box-shadow: 0 12px 30px rgba(22, 163, 74, .35);
        animation: pulse-icon 2s ease-in-out infinite;
    }

    @@keyframes pulse-icon {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    .verify-title {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 8px;
    }

    .verify-subtitle {
        color: rgba(255, 255, 255, .6);
        font-size: .92rem;
        text-align: center;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .verify-subtitle strong {
        color: #4ade80;
    }

    .code-inputs {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 28px;
    }

    .code-inputs input {
        width: 52px;
        height: 60px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: 700;
        border: 2px solid rgba(255, 255, 255, .15);
        border-radius: 14px;
        background: rgba(255, 255, 255, .08);
        color: #fff;
        outline: none;
        transition: all .25s;
        caret-color: #4ade80;
    }

    .code-inputs input:focus {
        border-color: #4ade80;
        background: rgba(74, 222, 128, .08);
        box-shadow: 0 0 20px rgba(74, 222, 128, .2);
    }

    .code-inputs input::placeholder {
        color: rgba(255, 255, 255, .2);
    }

    .btn-verify {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #16a34a, #15803d);
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all .3s;
        box-shadow: 0 8px 24px rgba(22, 163, 74, .35);
    }

    .btn-verify:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(22, 163, 74, .45);
    }

    .btn-verify:active {
        transform: translateY(0);
    }

    .resend-section {
        text-align: center;
        margin-top: 20px;
    }

    .resend-section span {
        color: rgba(255, 255, 255, .5);
        font-size: .88rem;
    }

    .resend-section button {
        background: none;
        border: none;
        color: #4ade80;
        font-weight: 600;
        cursor: pointer;
        font-size: .88rem;
        text-decoration: underline;
        transition: color .2s;
    }

    .resend-section button:hover {
        color: #86efac;
    }

    .timer-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(239, 68, 68, .15);
        color: #fca5a5;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: .82rem;
        font-weight: 600;
        margin-bottom: 24px;
    }

    .alert-glass {
        background: rgba(239, 68, 68, .12);
        border: 1px solid rgba(239, 68, 68, .3);
        color: #fca5a5;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: .88rem;
        margin-bottom: 20px;
    }

    .alert-glass-success {
        background: rgba(22, 163, 74, .12);
        border: 1px solid rgba(22, 163, 74, .3);
        color: #86efac;
    }

    .alert-glass-info {
        background: rgba(14, 165, 233, .12);
        border: 1px solid rgba(14, 165, 233, .3);
        color: #7dd3fc;
    }

    /* Toast notification */
    .toast-notify {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 9999;
        min-width: 300px;
        padding: 16px 20px;
        border-radius: 14px;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, .3);
        transform: translateX(120%);
        transition: transform .4s cubic-bezier(.175,.885,.32,1.275);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .toast-notify.show {
        transform: translateX(0);
    }

    .toast-notify.toast-success {
        background: rgba(22, 163, 74, .9);
        border: 1px solid rgba(74, 222, 128, .4);
        color: #fff;
    }

    .toast-notify.toast-error {
        background: rgba(220, 38, 38, .9);
        border: 1px solid rgba(252, 165, 165, .4);
        color: #fff;
    }

    .toast-notify.toast-info {
        background: rgba(14, 165, 233, .9);
        border: 1px solid rgba(125, 211, 252, .4);
        color: #fff;
    }

    .toast-notify i {
        font-size: 1.3rem;
    }

    .toast-notify .toast-text {
        font-size: .9rem;
        font-weight: 600;
    }
</style>

<!-- Toast container -->
<div id="toastNotify" class="toast-notify toast-info">
    <i class="bi bi-info-circle-fill"></i>
    <span class="toast-text" id="toastText"></span>
</div>

<div class="verify-wrapper">
    <div class="verify-card">
        <div class="verify-icon">📧</div>
        <h1 class="verify-title">Verify Your Email</h1>
        <p class="verify-subtitle">
            We've sent a 6-digit verification code to<br/>
            <strong>@Model.Email</strong>
        </p>

        <div class="text-center">
            <div class="timer-badge">
                <i class="bi bi-clock"></i>
                <span id="countdown">15:00</span>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-glass">
                <i class="bi bi-exclamation-circle me-1"></i>@TempData["ErrorMessage"]
            </div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert-glass alert-glass-info">
                <i class="bi bi-info-circle me-1"></i>@TempData["InfoMessage"]
            </div>
        }

        <div asp-validation-summary="All" class="alert-glass"></div>

        <form asp-action="RegisterConfirm" method="post" id="verifyForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Code" id="hiddenCode" />

            <div class="code-inputs">
                <input type="text" maxlength="1" class="code-digit" data-index="0" inputmode="numeric" pattern="[0-9]" autofocus />
                <input type="text" maxlength="1" class="code-digit" data-index="1" inputmode="numeric" pattern="[0-9]" />
                <input type="text" maxlength="1" class="code-digit" data-index="2" inputmode="numeric" pattern="[0-9]" />
                <input type="text" maxlength="1" class="code-digit" data-index="3" inputmode="numeric" pattern="[0-9]" />
                <input type="text" maxlength="1" class="code-digit" data-index="4" inputmode="numeric" pattern="[0-9]" />
                <input type="text" maxlength="1" class="code-digit" data-index="5" inputmode="numeric" pattern="[0-9]" />
            </div>

            <button type="submit" class="btn-verify" id="btnVerify">
                <i class="bi bi-shield-check me-2"></i>Verify
            </button>
        </form>

        <div class="resend-section">
            <span>Didn't receive the code?</span>
            <form asp-action="ResendCode" method="post" style="display:inline;" id="resendForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" id="resendBtn">Resend Code</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-focus & auto-advance for 6-digit code inputs
    const digits = document.querySelectorAll('.code-digit');
    const hiddenCode = document.getElementById('hiddenCode');

    function updateHiddenCode() {
        let code = '';
        digits.forEach(d => code += d.value);
        hiddenCode.value = code;
    }

    digits.forEach((input, i) => {
        input.addEventListener('input', (e) => {
            const val = e.target.value.replace(/\D/g, '');
            e.target.value = val.slice(-1);
            updateHiddenCode();
            if (val && i < 5) digits[i + 1].focus();
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && i > 0) {
                digits[i - 1].focus();
                digits[i - 1].value = '';
                updateHiddenCode();
            }
        });

        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const paste = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
            paste.split('').forEach((ch, idx) => {
                if (digits[idx]) digits[idx].value = ch;
            });
            updateHiddenCode();
            if (paste.length === 6) digits[5].focus();
        });
    });

    // Countdown timer (15 minutes)
    let timeLeft = 15 * 60;
    const countdownEl = document.getElementById('countdown');
    const timer = setInterval(() => {
        timeLeft--;
        const mins = Math.floor(timeLeft / 60);
        const secs = timeLeft % 60;
        countdownEl.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        if (timeLeft <= 0) {
            clearInterval(timer);
            countdownEl.textContent = 'Expired';
            countdownEl.parentElement.style.background = 'rgba(239,68,68,.25)';
            countdownEl.parentElement.style.color = '#f87171';
        }
    }, 1000);

    // Toast notification helper
    function showToast(message, type) {
        const toast = document.getElementById('toastNotify');
        const text = document.getElementById('toastText');
        toast.className = 'toast-notify toast-' + type;
        text.textContent = message;

        // Icon
        const icon = toast.querySelector('i');
        if (type === 'success') icon.className = 'bi bi-check-circle-fill';
        else if (type === 'error') icon.className = 'bi bi-x-circle-fill';
        else icon.className = 'bi bi-info-circle-fill';

        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 4000);
    }

    // Show toast from TempData
    @if (TempData["InfoMessage"] != null)
    {
        <text>showToast("@TempData["InfoMessage"]", "info");</text>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <text>showToast("@TempData["ErrorMessage"]", "error");</text>
    }

    // Resend button with toast
    document.getElementById('resendBtn')?.addEventListener('click', function(e) {
        showToast('Sending a new verification code...', 'info');
    });
</script>
}
