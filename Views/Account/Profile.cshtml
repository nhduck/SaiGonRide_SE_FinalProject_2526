@model RentalVehicleService.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    ViewData["MetaDescription"] = "Manage your SaigonRide profile, personal information and account settings.";

    // Avatar initials
    var initials = string.IsNullOrWhiteSpace(Model.FullName)
        ? "?"
        : string.Join("", Model.FullName.Trim().Split(' ', System.StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0].ToString().ToUpper()));

    var userTypeIcon  = Model.UserType == "Tourist" ? "✈️" : "🏙️";
    var userTypeBadge = Model.UserType == "Tourist" ? "Tourist" : "Local Resident";
}

<style>
    /* Profile page */
    .sr-profile-hero {
        background: linear-gradient(135deg, #064e3b 0%, #065f46 50%, #0f172a 100%);
        padding: 3.5rem 0 7rem;
        position: relative;
        overflow: hidden;
    }
    .sr-profile-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(22,163,74,.15) 0%, transparent 70%),
            url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/svg%3E");
    }
    .sr-profile-blob {
        position: absolute; border-radius: 50%; filter: blur(70px); pointer-events: none;
    }
    .sr-profile-blob-1 { width:320px;height:320px;background:rgba(74,222,128,.14);top:-80px;right:-80px; }
    .sr-profile-blob-2 { width:220px;height:220px;background:rgba(14,165,233,.1);bottom:-40px;left:-60px; }

    /* Avatar circle */
    .sr-profile-avatar {
        width: 100px; height: 100px; border-radius: 50%;
        background: linear-gradient(135deg, #16a34a, #15803d);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.4rem; font-weight: 800; color: #fff;
        border: 4px solid rgba(255,255,255,.25);
        box-shadow: 0 12px 30px rgba(0,0,0,.25);
        letter-spacing: -.02em;
        flex-shrink: 0;
    }

    /* Floating card pulled up from hero */
    .sr-profile-card-wrap {
        margin-top: -4.5rem;
        position: relative;
        z-index: 2;
    }

    /* Stat boxes */
    .sr-profile-stat {
        text-align: center;
        padding: 1.25rem;
        border-radius: 14px;
        background: var(--sr-gray-50);
        border: 1px solid var(--sr-gray-100);
        transition: var(--sr-transition);
    }
    .sr-profile-stat:hover {
        background: var(--sr-green-50);
        border-color: var(--sr-green-light);
        transform: translateY(-2px);
    }
    .sr-profile-stat-val {
        font-size: 1.6rem; font-weight: 800;
        background: linear-gradient(135deg, #16a34a, #059669);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text; line-height: 1.1; display: block;
    }

    /* Section tabs */
    .sr-profile-tabs .nav-link {
        color: var(--sr-gray-500); font-weight: 500;
        border: none; border-bottom: 2px solid transparent;
        border-radius: 0; padding: .75rem 1.25rem;
        transition: var(--sr-transition);
    }
    .sr-profile-tabs .nav-link.active {
        color: var(--sr-green); border-bottom-color: var(--sr-green); background: transparent;
    }
    .sr-profile-tabs .nav-link:hover { color: var(--sr-green); }

    /* Input hover glow */
    .sr-profile-input:focus {
        border-color: var(--sr-green) !important;
        box-shadow: 0 0 0 .15rem rgba(22,163,74,.18) !important;
    }

    @@keyframes profile-in {
        from { opacity:0; transform:translateY(18px); }
        to   { opacity:1; transform:none; }
    }
    .profile-animate { animation: profile-in .5s cubic-bezier(.4,0,.2,1) both; }
</style>

<!-- HERO STRIP -->
<div class="sr-profile-hero">
    <div class="sr-profile-blob sr-profile-blob-1"></div>
    <div class="sr-profile-blob sr-profile-blob-2"></div>

    <div class="container position-relative">
        <div class="d-flex flex-column flex-sm-row align-items-center align-items-sm-start gap-4 profile-animate">
            <!-- Avatar -->
            <div class="sr-profile-avatar">@initials</div>

            <!-- Name & meta -->
            <div class="text-center text-sm-start">
                <h1 class="text-white fw-bold mb-1" style="font-size:1.8rem;letter-spacing:-.02em;">@Model.FullName</h1>
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-sm-start mt-2">
                    <span class="sr-glass px-3 py-1 text-white-50" style="font-size:.82rem;">
                        <i class="bi bi-envelope me-1 text-white-50"></i>@Model.Email
                    </span>
                    <span class="sr-glass px-3 py-1 text-white-50" style="font-size:.82rem;">
                        @userTypeIcon &nbsp;@userTypeBadge
                    </span>
                    <span class="sr-glass px-3 py-1" style="font-size:.82rem;color:#4ade80;">
                        <i class="bi bi-check-circle-fill me-1"></i>Verified Account
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<div class="container sr-profile-card-wrap pb-5">

    @* Success / error alerts *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert d-flex align-items-center gap-2 rounded-3 mb-4 border-0 shadow-sm profile-animate"
             style="background:#f0fdf4;color:#166534;">
            <i class="bi bi-check-circle-fill fs-5"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ── Left: Stats sidebar ── -->
        <div class="col-lg-3">
            <div class="bg-white rounded-4 shadow-sm border p-3 mb-4 profile-animate" style="animation-delay:.05s;">
                <p class="text-muted fw-semibold mb-3" style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;">Activity</p>
                <div class="d-flex flex-column gap-2">
                    <div class="sr-profile-stat">
                        <span class="sr-profile-stat-val">0</span>
                        <span class="text-muted mt-1 d-block" style="font-size:.8rem;">Total Rides</span>
                    </div>
                    <div class="sr-profile-stat">
                        <span class="sr-profile-stat-val">0km</span>
                        <span class="text-muted mt-1 d-block" style="font-size:.8rem;">Distance</span>
                    </div>
                    <div class="sr-profile-stat">
                        <span class="sr-profile-stat-val">0g</span>
                        <span class="text-muted mt-1 d-block" style="font-size:.8rem;">CO₂ Saved</span>
                    </div>
                </div>
            </div>

            <!-- Quick links -->
            <div class="bg-white rounded-4 shadow-sm border p-3 profile-animate" style="animation-delay:.1s;">
                <p class="text-muted fw-semibold mb-3" style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;">Quick Links</p>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 py-2 text-muted d-flex align-items-center gap-2" style="font-size:.875rem;">
                        <i class="bi bi-clock-history text-sr-green fs-5"></i>Rental History
                    </a>
                    <a href="/Home/FAQ" class="list-group-item list-group-item-action border-0 px-0 py-2 text-muted d-flex align-items-center gap-2" style="font-size:.875rem;">
                        <i class="bi bi-question-circle text-sr-green fs-5"></i>Help & FAQ
                    </a>
                    <a href="/Home/Privacy" class="list-group-item list-group-item-action border-0 px-0 py-2 text-muted d-flex align-items-center gap-2" style="font-size:.875rem;">
                        <i class="bi bi-shield-check text-sr-green fs-5"></i>Privacy Policy
                    </a>
                </div>
            </div>
        </div>

        <!-- Right: Profile form -->
        <div class="col-lg-9">
            <div class="bg-white rounded-4 shadow-sm border overflow-hidden profile-animate" style="animation-delay:.08s;">

                <!-- Tab nav -->
                <ul class="nav sr-profile-tabs border-bottom px-4 pt-2">
                    <li class="nav-item">
                        <button class="nav-link active" id="tab-info" data-bs-toggle="tab" data-bs-target="#pane-info" type="button">
                            <i class="bi bi-person me-1"></i>Personal Info
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="tab-identity" data-bs-toggle="tab" data-bs-target="#pane-identity" type="button">
                            <i class="bi bi-card-text me-1"></i>Identity
                        </button>
                    </li>
                </ul>

                <div class="tab-content p-4 p-md-5">

                    <!-- Tab 1: Personal Info -->
                    <div class="tab-pane fade show active" id="pane-info">
                        <form asp-action="Profile" method="post" id="profileForm">
                            <input type="hidden" asp-for="UserType" />
                            <input type="hidden" asp-for="Email" />

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4 border-0" style="background:#fef2f2;"></div>

                            <div class="row g-4 mb-4">
                                <!-- Full Name -->
                                <div class="col-md-6">
                                    <label asp-for="FullName" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                    <div class="input-group sr-input-group">
                                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                                        <input asp-for="FullName" class="form-control py-2 sr-profile-input" placeholder="John Doe" />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger" style="font-size:.8rem;"></span>
                                </div>

                                <!-- Email (readonly) -->
                                <div class="col-md-6">
                                    <label asp-for="Email" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-muted"><i class="bi bi-envelope"></i></span>
                                        <input asp-for="Email" class="form-control py-2 bg-light text-muted" readonly disabled />
                                    </div>
                                    <span class="text-muted" style="font-size:.78rem;"><i class="bi bi-info-circle me-1"></i>Email address cannot be changed</span>
                                </div>

                                <!-- Phone -->
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                    <div class="input-group sr-input-group">
                                        <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                        <input asp-for="PhoneNumber" class="form-control py-2 sr-profile-input" placeholder="+84 901 234 567" />
                                    </div>
                                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size:.8rem;"></span>
                                </div>

                                <!-- Account Type -->
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" style="font-size:.875rem;">Account Type</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light text-muted">@userTypeIcon</span>
                                        <input type="text" class="form-control py-2 bg-light text-muted" value="@userTypeBadge" readonly disabled />
                                    </div>
                                </div>
                            </div>

                            <!-- Save button -->
                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-success px-5 py-2 fw-bold rounded-3"
                                        id="saveBtn" style="box-shadow:0 4px 14px rgba(22,163,74,.3);">
                                    <i class="bi bi-save me-2"></i>Save Changes
                                </button>
                                <a href="/" class="btn btn-outline-secondary px-4 py-2 rounded-3 fw-semibold">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>

                    <!-- Tab 2: Identity -->
                    <div class="tab-pane fade" id="pane-identity">
                        <form asp-action="Profile" method="post">
                            <input type="hidden" asp-for="UserType" />
                            <input type="hidden" asp-for="Email" />
                            <input type="hidden" asp-for="FullName" />
                            <input type="hidden" asp-for="PhoneNumber" />

                            @if (Model.UserType == "Tourist")
                            {
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label asp-for="PassportNumber" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                        <div class="input-group sr-input-group">
                                            <span class="input-group-text"><i class="bi bi-passport"></i></span>
                                            <input asp-for="PassportNumber" class="form-control py-2 sr-profile-input" />
                                        </div>
                                        <span asp-validation-for="PassportNumber" class="text-danger" style="font-size:.8rem;"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Nationality" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                        <div class="input-group sr-input-group">
                                            <span class="input-group-text"><i class="bi bi-globe"></i></span>
                                            <input asp-for="Nationality" class="form-control py-2 sr-profile-input" />
                                        </div>
                                        <span asp-validation-for="Nationality" class="text-danger" style="font-size:.8rem;"></span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="row g-4">
                                    <div class="col-md-8">
                                        <label asp-for="CCCD" class="form-label fw-semibold" style="font-size:.875rem;"></label>
                                        <div class="input-group sr-input-group">
                                            <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                            <input asp-for="CCCD" class="form-control py-2 sr-profile-input" placeholder="012345678910" />
                                        </div>
                                        <span asp-validation-for="CCCD" class="text-danger" style="font-size:.8rem;"></span>
                                    </div>
                                    <div class="col-md-4 d-flex align-items-end">
                                        <div class="d-flex align-items-center gap-2 p-3 rounded-3 w-100" style="background:var(--sr-green-50);border:1px solid var(--sr-green-light);">
                                            <i class="bi bi-shield-check text-sr-green fs-4"></i>
                                            <span class="text-sr-green fw-semibold" style="font-size:.85rem;">Verified ✓</span>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="mt-4">
                                <button type="submit" class="btn btn-success px-5 py-2 fw-bold rounded-3"
                                        style="box-shadow:0 4px 14px rgba(22,163,74,.3);">
                                    <i class="bi bi-save me-2"></i>Update Identity
                                </button>
                            </div>
                        </form>
                    </div>

                </div><!-- /tab-content -->
            </div><!-- /card -->

            <!-- Danger Zone -->
            <div class="bg-white rounded-4 shadow-sm border mt-4 p-4 profile-animate" style="animation-delay:.15s;">
                <h6 class="fw-bold mb-1" style="color:#991b1b;">⚠️ Danger Zone</h6>
                <p class="text-muted mb-3" style="font-size:.875rem;">Permanently delete your account. This action cannot be undone.</p>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 fw-semibold px-4">
                        <i class="bi bi-box-arrow-right me-2"></i>Log Out
                    </button>
                </form>
                <button type="button" class="btn btn-outline-danger btn-sm rounded-3 fw-semibold px-4 ms-2"
                        data-bs-toggle="modal" data-bs-target="#deleteModal" disabled title="Coming soon">
                    <i class="bi bi-trash me-2"></i>Delete Account
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.getElementById('profileForm')?.addEventListener('submit', function () {
        const btn = document.getElementById('saveBtn');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
        btn.disabled = true;
    });
</script>
}
