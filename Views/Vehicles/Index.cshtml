@model IEnumerable<RentalVehicleService.Models.Vehicle>

@{
	ViewData["Title"] = "Vehicle Managemen";
}
<div class="containe m-5 border-dark">
	<h1><i class="bi bi-bicycle"></i> Vehicle Management</h1>

	<div class="d-flex justify-content-end m-3">
		<a asp-action="Create" class="btn btn-primary">Create New</a>
	</div>

	<div class="container d-flex justify-content-lg-between px-lg-5">
		<div class="card">
			<div class=" card-body">
				<div class="card-title text-primary fw-bold">Total Vehicles</div>
				<div class="card-text text-primary text-center fw-bold">@ViewBag.TotalVehicles</div>
			</div>
		</div>
		<div class="card">
			<div class=" card-body">
				<div class="card-title text-success fw-bold">Available</div>
				<div class="card-text text-success text-center fw-bold">@ViewBag.TotalVehicles</div>
			</div>
		</div>
		<div class="card">
			<div class=" card-body">
				<div class="card-title text-warning fw-bold">Charging</div>
				<div class="card-text text-warning text-center fw-bold">@ViewBag.TotalVehicles</div>
			</div>
		</div>
		<div class="card">
			<div class=" card-body">
				<div class="card-title text-danger fw-bold">Under Maintenance</div>
				<div class="card-text text-danger text-center fw-bold">@ViewBag.TotalVehicles</div>
			</div>
		</div>
	</div>

	<div class="d-flex gap-2 mb-3 m-4">
		<input type="text" class="form-control" placeholder="Search...">
		<button class="btn btn-outline-dark text-nowrap">Search</button>
		<button class="btn btn-outline-dark text-nowrap">Available</button>
		<button class="btn btn-outline-dark text-nowrap">Rented</button>
		<button class="btn btn-outline-dark text-nowrap">Charing</button>
		<button class="btn btn-outline-dark text-nowrap">Maintenance</button>
	</div>

	<table class="table">
		<thead>
			<tr>
				<th>
					Vehicle Id
				</th>
				<th>
					Type
				</th>
				<th>
					Model
				</th>
				<th>
					Current Station
				</th>
				<th>
					Condition
				</th>
				<th>
					Status
				</th>
				<th>
					Action
				</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var item in Model)
			{
				<tr>
					<td>
						@Html.DisplayFor(modelItem => item.VehicleId)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.VehicleModel)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.Price)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.BatteryPercentage)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.State)
					</td>
					<td>
						@Html.DisplayFor(modelItem => item.CurrentStationId)
					</td>
					<td>
						<a asp-action="Edit" asp-route-id="@item.VehicleId" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
						<a asp-action="Details" asp-route-id="@item.VehicleId" class="btn btn-outline-secondary btn-sm"><i class="bi bi-info-circle"></i> Details</a>
						<a asp-action="Delete" asp-route-id="@item.VehicleId" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</a>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>
